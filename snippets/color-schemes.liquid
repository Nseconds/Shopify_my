{% style %}
  {% for scheme in settings.color_schemes -%}
    {% assign scheme_classes = scheme_classes | append: ', .color-' | append: scheme.id %}
    {% if forloop.index == 1 %}
      :root,
    {% endif %}
    {% assign background_brightness = scheme.settings.background | color_brightness %}
    {% if background_brightness < 64 %}
      {% assign opacity_5_15 = 0.15 %}
      {% assign opacity_10_25 = 0.25 %}
      {% assign opacity_35_55 = 0.55 %}
      {% assign opacity_40_60 = 0.60 %}
      {% assign opacity_30_60 = 0.60 %}
      {%- assign card_bg = scheme.settings.background | color_lighten: 6 -%}
    {% else %}
      {% assign opacity_5_15 = 0.05 %}
      {% assign opacity_10_25 = 0.1 %}
      {% assign opacity_35_55 = 0.35 %}
      {% assign opacity_40_60 = 0.40 %}
      {% assign opacity_30_60 = 0.30 %}
      {%- assign card_bg = scheme.settings.background | color_darken: 4 -%}
    {% endif %}
    {%- assign primary_hover = scheme.settings.primary | color_darken: 15 -%}
    {%- assign pb_hover_bg = scheme.settings.primary_button_background | color_darken: 10 -%}
    {%- assign pb_hover_border = scheme.settings.primary_button_border | color_darken: 10 -%}
    {%- assign sb_hover_bg = scheme.settings.secondary_button_background | color_darken: 8 -%}
    {%- assign sb_hover_border = scheme.settings.secondary_button_border | color_darken: 8 -%}
    {%- assign input_hover_bg = scheme.settings.input_background | color_darken: 5 -%}
    {%- assign var_hover_bg = scheme.settings.variant_background_color | color_darken: 5 -%}
    {%- assign sel_var_hover_bg = scheme.settings.selected_variant_background_color | color_darken: 10 -%}
    .color-{{ scheme.id }} {
        --color-background: rgb({{ scheme.settings.background.rgba }});
        --color-card-background: rgb({{ card_bg.rgba }});
        /* RGB values only to apply different opacities - Relative color values are not supported in iOS < 16.4 */
        --color-background-rgb: {{ scheme.settings.background.rgb }};
        --color-background-secondary: rgb({{ scheme.settings.background_secondary.rgba }});
        --opacity-5-15: {{ opacity_5_15 }};
        --opacity-10-25: {{ opacity_10_25 }};
        --opacity-35-55: {{ opacity_35_55 }};
        --opacity-40-60: {{ opacity_40_60 }};
        --opacity-30-60: {{ opacity_30_60 }};
        --color-foreground: rgb({{ scheme.settings.foreground.rgba }});
        --color-foreground-rgb: {{ scheme.settings.foreground.rgb }};
        --color-foreground-heading: rgb({{ scheme.settings.foreground_heading.rgba | default: scheme.settings.foreground.rgba }});
        --color-foreground-heading-rgb: {{ scheme.settings.foreground_heading.rgb | default: scheme.settings.foreground.rgb }};
        --color-primary: rgb({{ scheme.settings.primary.rgba }});
        --color-primary-rgb: {{ scheme.settings.primary.rgb }};
        --color-primary-hover: rgb({{ primary_hover.rgba }});
        --color-primary-hover-rgb: {{ primary_hover.rgb }};
        --color-border: rgb({{ scheme.settings.border.rgba }});
        --color-border-rgb: {{ scheme.settings.border.rgb }};
        --color-shadow: rgb({{ scheme.settings.shadow.rgba }});
        --color-shadow-rgb: {{ scheme.settings.shadow.rgb }};
        --color-primary-button-text: rgb({{ scheme.settings.primary_button_text.rgba }});
        --color-primary-button-background: rgb({{ scheme.settings.primary_button_background.rgba }});
        --color-primary-button-border: rgb({{ scheme.settings.primary_button_border.rgba }});
        --color-primary-button-hover-text: rgb({{ scheme.settings.primary_button_text.rgba }});
        --color-primary-button-hover-background: rgb({{ pb_hover_bg.rgba }});
        --color-primary-button-hover-border: rgb({{ pb_hover_border.rgba }});
        --color-secondary-button-text: rgb({{ scheme.settings.secondary_button_text.rgba }});
        --color-secondary-button-background: rgb({{ scheme.settings.secondary_button_background.rgba }});
        --color-secondary-button-border: rgb({{ scheme.settings.secondary_button_border.rgba }});
        --color-secondary-button-hover-text: rgb({{ scheme.settings.secondary_button_text.rgba }});
        --color-secondary-button-hover-background: rgb({{ sb_hover_bg.rgba }});
        --color-secondary-button-hover-border: rgb({{ sb_hover_border.rgba }});
        --color-input-background: rgb({{ scheme.settings.input_background.rgba }});
        --color-input-text: rgb({{ scheme.settings.input_text_color.rgba }});
        --color-input-text-rgb: {{ scheme.settings.input_text_color.rgb }};
        --color-input-border: rgb({{ scheme.settings.input_border_color.rgba }});
        --color-input-hover-background: rgb({{ input_hover_bg.rgba }});
        --color-variant-background: rgb({{ scheme.settings.variant_background_color.rgba }});
        --color-variant-border: rgb({{ scheme.settings.variant_border_color.rgba }});
        --color-variant-text: rgb({{ scheme.settings.variant_text_color.rgba }});
        --color-variant-text-rgb: {{ scheme.settings.variant_text_color.rgb }};
        --color-variant-hover-background: rgb({{ var_hover_bg.rgba }});
        --color-variant-hover-text: rgb({{ scheme.settings.variant_text_color.rgba }});
        --color-variant-hover-border: rgb({{ scheme.settings.variant_border_color.rgba }});
        --color-selected-variant-background: rgb({{ scheme.settings.selected_variant_background_color.rgba }});
        --color-selected-variant-border: rgb({{ scheme.settings.selected_variant_border_color.rgba }});
        --color-selected-variant-text: rgb({{ scheme.settings.selected_variant_text_color.rgba }});
        --color-selected-variant-hover-background: rgb({{ sel_var_hover_bg.rgba }});
        --color-selected-variant-hover-text: rgb({{ scheme.settings.selected_variant_text_color.rgba }});
        --color-selected-variant-hover-border: rgb({{ scheme.settings.selected_variant_border_color.rgba }});

        /* Gradient colors - fall back to primary/background when scheme has no gradient set */
        {%- assign grad1 = scheme.settings.gradient_1 | default: scheme.settings.primary -%}
        {%- assign grad2 = scheme.settings.gradient_2 | default: scheme.settings.primary -%}
        {%- assign grad3 = scheme.settings.gradient_3 | default: scheme.settings.primary -%}
        {%- assign grad_text = scheme.settings.gradient_text_color | default: scheme.settings.background -%}
        --color-gradient-1: {{ grad1 }};
        --color-gradient-2: {{ grad2 }};
        --color-gradient-3: {{ grad3 }};
        --color-gradient-text: {{ grad_text }};
        --color-wave: {{ scheme.settings.wave_color | default: scheme.settings.primary }};
        --color-card-gradient: linear-gradient(135deg, {{ grad1 }}, {{ grad2 }}, {{ grad3 }});

        --input-disabled-background-color: rgb(var(--color-foreground-rgb) / var(--opacity-10));
        --input-disabled-border-color: rgb(var(--color-foreground-rgb) / var(--opacity-5-15));
        --input-disabled-text-color: rgb(var(--color-foreground-rgb) / var(--opacity-50));
        --color-foreground-muted: rgb(var(--color-foreground-rgb) / var(--opacity-60));
        --font-h1--color: var(--color-foreground-heading);
        --font-h2--color: var(--color-foreground-heading);
        --font-h3--color: var(--color-foreground-heading);
        --font-h4--color: var(--color-foreground-heading);
        --font-h5--color: var(--color-foreground-heading);
        --font-h6--color: var(--color-foreground-heading);

        /* Shadows */
        {% if settings.drawer_drop_shadow %}
          --shadow-drawer: 0px 4px 20px rgb(var(--color-shadow-rgb) / var(--opacity-15));
        {% endif %}
        {% if settings.popover_drop_shadow %}
          --shadow-blur: 20px;
          --shadow-popover: 0px 4px 20px rgb(var(--color-shadow-rgb) / var(--opacity-15));
        {% endif %}
      }

      {% if settings.style_mode == 'gradient' %}
        /* Override primary accent + button vars so all icons, stars, pills auto-use gradient */
        .color-{{ scheme.id }} {
          --color-primary: var(--color-gradient-1);
          --color-primary-hover: var(--color-gradient-2);
          --color-primary-button-background: var(--color-card-gradient);
          --color-primary-button-text: var(--color-gradient-text);
          --color-primary-button-border: transparent;
        }
        .color-{{ scheme.id }} .button:not(.button-secondary, .button-unstyled):hover,
        .color-{{ scheme.id }}.button:not(.button-secondary, .button-unstyled):hover,
        .color-{{ scheme.id }} button.shopify-payment-button__button--unbranded:hover:not([disabled]) {
          opacity: 0.9;
        }
      {% else %}
        /* In flat mode: remap gradient vars to flat equivalents so nothing accidentally
           uses gradient colors. Any element still referencing these vars gets flat colors. */
        .color-{{ scheme.id }} {
          --color-gradient-1: var(--color-primary);
          --color-gradient-2: var(--color-primary);
          --color-gradient-3: var(--color-primary);
          --color-gradient-text: var(--color-foreground);
          --color-card-gradient: var(--color-card-background);
        }
      {% endif %}
  {% endfor %}

  {{ scheme_classes | prepend: 'body' }} {
    color: var(--color-foreground);
    background-color: var(--color-background);
  }

  {% if settings.style_mode == 'gradient' %}
    /* Ensure gradient vars propagate to blocks/sections without an explicit .color-* ancestor */
    :root {
      --color-primary: var(--color-gradient-1);
      --color-primary-hover: var(--color-gradient-2);
      --color-primary-button-background: var(--color-card-gradient);
      --color-primary-button-text: var(--color-gradient-text);
      --color-primary-button-border: transparent;
    }
  {% else %}
    /* In flat mode: remap gradient vars to flat equivalents on :root too (covers ai-gen blocks
       that have no .color-* ancestor but may still reference gradient vars) */
    :root {
      --color-gradient-1: var(--color-primary);
      --color-gradient-2: var(--color-primary);
      --color-gradient-3: var(--color-primary);
      --color-gradient-text: var(--color-foreground);
      --color-card-gradient: var(--color-card-background);
    }
  {% endif %}

{% endstyle %}
