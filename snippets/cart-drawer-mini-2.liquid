<style>
  div#forge-error {
    position: fixed;
    top: 0px;
    left: 0px;
    bottom: 0px;
    right: 0px;
    background: #fff;
    z-index: 99999999;
    display: flex;
    align-items: center;
    padding: 30px 20px;
    justify-content: center;
  }
  #forge-error .forge-error-content {
    max-width: 700px;
    margin: 0px auto;
    display: flex;
    align-items: center;
    flex-direction: column;
    text-align: center;
  }
  #forge-error h2 {
    color: #1f3879;
    font-family: Inter;
    font-size: 40px;
    font-weight: 700;
    line-height: 70.19px;
    margin-bottom: 0px;
    text-align: center;
    text-underline-position: from-font;
    text-decoration-skip-ink: none;
  }
  #forge-error .forge-error-text {
    color: #303030;
    font-family: Inter, sans-serif;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.6;
    margin: 24px 0;
    text-align: center;
  }
  #forge-error .forge-error-text p {
    margin: 16px 0;
    color: #555;
    font-size: 16px;
    line-height: 1.7;
  }
  .forge-buttons > a {
    box-shadow: 0px 1px 0px 0px #e3e3e3 inset, 1px 0px 0px 0px #e3e3e3 inset, -1px 0px 0px 0px #e3e3e3 inset,
      0px -1px 0px 0px #b5b5b5 inset;
    background: #ffffff;
    display: block;
    padding: 15px 20px;
    min-width: 200px;
    font-size: 14px;
    font-weight: 550;
    line-height: 16px;
    text-align: center;
    text-underline-position: from-font;
    text-decoration-skip-ink: none;
    font-variation-settings: 'slnt' 0;
    color: #303030;
    text-decoration: none;
    border-radius: 7px;
  }
  .forge-buttons > a:last-child {
    background: #303030;
    color: #fff;
    box-shadow: 0px 1px 0px 0px #000000 inset, 0px -1px 0px 1px #000000 inset, -2px 0px 0px 0px #ffffff33 inset,
      2px 0px 0px 0px #ffffff33 inset, 0px 2px 0px 0px #ffffff33 inset;
  }

  .forge-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }
</style>

<script>
  // use IIFE for license check to isolate scope and state
  (function () {
    console.log('Checking authentication status...');
    const forgeEl = function({ customErrorMessage }) {
      return `<div id="forge-error">
      <div class="forge-error-content">
          <div class="forge-error-image">
              <svg width="256" height="256" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Background -->
                <rect x="0" y="0" width="256" height="256" rx="48" fill="#020617"/>
                <rect x="10" y="10" width="236" height="236" rx="44" fill="#020617"/>
                <rect x="10" y="10" width="236" height="236" rx="44" stroke="#1E293B" stroke-width="4"/>
                <!-- Forge base -->
                <rect x="56" y="96" width="144" height="104" rx="20" fill="#020617" stroke="#38BDF8" stroke-width="4"/>
                <!-- Top plate -->
                <rect x="44" y="88" width="168" height="16" rx="8" fill="#020617" stroke="#38BDF8" stroke-width="3"/>
                <!-- Chimney -->
                <rect x="96" y="52" width="32" height="40" rx="8" fill="#020617" stroke="#38BDF8" stroke-width="3"/>
                <rect x="92" y="46" width="40" height="8" rx="4" fill="#38BDF8"/>
                <!-- Inner furnace opening -->
                <rect x="80" y="112" width="96" height="72" rx="18" fill="#020617" stroke="#0EA5E9" stroke-width="3"/>
                <!-- Glow / embers -->
                <radialGradient id="glow" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse" gradientTransform="translate(128 172) rotate(90) scale(40 60)">
                  <stop offset="0" stop-color="#F97316" stop-opacity="0.95"/>
                  <stop offset="0.6" stop-color="#F97316" stop-opacity="0.25"/>
                  <stop offset="1" stop-color="#020617" stop-opacity="0"/>
                </radialGradient>
                <rect x="84" y="130" width="88" height="52" rx="16" fill="url(#glow)"/>
                <!-- Face: eyes -->
                <circle cx="108" cy="138" r="6" fill="#E5E7EB"/>
                <circle cx="148" cy="138" r="6" fill="#E5E7EB"/>
                <!-- Sad mouth -->
                <path d="M108 164C114 158 122 155 128 155C134 155 142 158 148 164" stroke="#E5E7EB" stroke-width="3" stroke-linecap="round" fill="none"/>
                <!-- Tear -->
                <path d="M152 144C157 148 159 152 159 156C159 159 157.5 162 155 163.5C152.5 165 150 165 148 164" fill="#38BDF8" fill-opacity="0.9"/>
                <!-- Little crack on the forge (extra sad) -->
                <path d="M96 120L92 132L98 140L94 150" stroke="#38BDF8" stroke-width="2" stroke-linecap="round"/>
              </svg>
              </div>
              <div class="forge-error-text">
               ${customErrorMessage}
                  <div class="forge-buttons">
                      <a target="_blank" href="javascript: void(0)" id="forge-btn-billing">Open Billing</a>
                      <a target="_blank" href="javascript: void(0)" id="forge-btn-dashboard">Go to Forge</a>
                  </div>
              </div>
          </div>
      </div>`;
    }

    const forgeUrl = `https://forge-prod-11402474925.us-central1.run.app/api/license/verify`

    function showForgeError({ customErrorMessage }) {
      const errorContainer = document.createElement('div');
      errorContainer.innerHTML = forgeEl({ customErrorMessage });
      document.body.appendChild(errorContainer);
      errorContainer.setAttribute('style', 'display:block !important');
      errorContainer.scrollIntoView();

      document.getElementById("forge-error").setAttribute("style", "display: flex !important");
      const billingBtn = document.getElementById('forge-btn-billing');
      const dashboardBtn = document.getElementById('forge-btn-dashboard');
      billingBtn.href = `https://admin.shopify.com/store/${Shopify.shop.replace(".myshopify.com", "")}/apps/forge-ai/app/settings`;
      dashboardBtn.href = `https://admin.shopify.com/store/${Shopify.shop.replace(".myshopify.com", "")}/apps/forge-ai`;
    }

    function checkLicense() {
      const inThemeEditor = Shopify?.designMode;
      const inPreviewMode = Shopify?.PreviewBarInjector;
      const inAdminMode = Shopify?.AdminBarInjector;
      const previewBarPresent = !!document.getElementById('PBarNextFrameWrapper'); // doesn't appear in development stores

      if (inThemeEditor || inPreviewMode || inAdminMode || previewBarPresent) {
        // DO license check
      } else {
        return; // DON'T do license check
      }

      const defaultErrorMessage = `
        <h2>Your Forge AI Theme License is Inactive</h2>
        <p>
            Your Forge AI theme license is inactive because your subscription has ended or a billing issue occurred. Please open the Forge AI app to restore your theme license.
        </p>`

      const shopDomain = Shopify?.shop;

      if (!shopDomain) {
        showForgeError({ customErrorMessage: defaultErrorMessage });
        return;
      }

      fetch(forgeUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          shop: shopDomain,
          theme_id: Shopify?.theme?.id,
        }),
      })
        .then(function (res) {
          return res.json();
        })
        .then(function (data) {
          if (!data.success) {
            showForgeError({ customErrorMessage: defaultErrorMessage });
          }
        })
        .catch(function () {
          showForgeError({ customErrorMessage: 'Error when verifying Theme License. <br/> Please notify support' });
        });
    }

    // Check when DOM is ready and handle case where script is loaded after DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setTimeout(checkLicense, 2000);
      });
    } else {
      setTimeout(checkLicense, 2000);
    }
  })();
</script>
