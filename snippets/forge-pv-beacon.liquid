{% comment %}
  Forge first-party page-view beacon. PDP only.

  Privacy posture:
    - Only fires on storefront product pages (not editor, preview, admin)
    - Respects Shopify Customer Privacy API consent
    - Honors DNT and Sec-GPC headers (server-side)
    - First-party cookies only; no third-party tracking
    - IP and User-Agent never sent in clear; server hashes them with a
      daily-rotating, shop-scoped salt

  Bot detection signals collected for the server filter:
    navigator.webdriver, navigator.plugins.length, navigator.cookieEnabled,
    window.chrome presence, viewport/screen dims, languages, timezone,
    page load timing.

  Endpoint: https://forge-prod-11402474925.us-central1.run.app/api/pv
{% endcomment %}

{%- if template.name == 'product' -%}
<script>
  (function () {
    if (window.__forgePvBeaconFired) return;
    window.__forgePvBeaconFired = true;

    // ── Gate: skip editor / preview / admin contexts ────────────────────────
    var sh = window.Shopify || {};
    if (sh.designMode || sh.PreviewBarInjector || sh.AdminBarInjector) return;
    if (document.getElementById('PBarNextFrameWrapper')) return;

    // ── Gate: respect Customer Privacy API consent (if present) ─────────────
    try {
      var cp = sh.customerPrivacy;
      if (cp && typeof cp.analyticsProcessingAllowed === 'function') {
        if (!cp.analyticsProcessingAllowed()) return;
      }
    } catch (e) { /* if the API throws, fall through and fire */ }

    var ENDPOINT = 'https://forge-prod-11402474925.us-central1.run.app/api/pv';
    var SHOP = {{ shop.permanent_domain | json }};
    var PRODUCT_ID = {{ product.id | json }};
    var PRODUCT_HANDLE = {{ product.handle | json }};

    // ── First-party UUIDs in cookies (replaces _shopify_y, _shopify_s) ──────
    function uuid() {
      if (window.crypto && crypto.randomUUID) {
        try { return crypto.randomUUID(); } catch (e) {}
      }
      // RFC4122-ish fallback
      return ([1e7]+-1e3+-4e3+-8e3+-1e11).replace(/[018]/g, function (c) {
        return (c ^ (window.crypto && crypto.getRandomValues
          ? crypto.getRandomValues(new Uint8Array(1))[0] : (Math.random() * 256))
          & 15 >> c / 4).toString(16);
      });
    }

    function readCookie(name) {
      var parts = document.cookie.split('; ');
      for (var i = 0; i < parts.length; i++) {
        var kv = parts[i].split('=');
        if (kv[0] === name) return decodeURIComponent(kv.slice(1).join('='));
      }
      return null;
    }

    function writeCookie(name, value, maxAgeSeconds) {
      var attrs = '; Path=/; SameSite=Lax';
      if (location.protocol === 'https:') attrs += '; Secure';
      if (maxAgeSeconds) attrs += '; Max-Age=' + maxAgeSeconds;
      document.cookie = name + '=' + encodeURIComponent(value) + attrs;
    }

    var CID_COOKIE = 'forge_cid';
    var SID_COOKIE = 'forge_sid';
    var TWO_YEARS = 60 * 60 * 24 * 365 * 2;
    var THIRTY_MIN = 60 * 30;

    var clientId = readCookie(CID_COOKIE);
    if (!clientId) {
      clientId = uuid();
      writeCookie(CID_COOKIE, clientId, TWO_YEARS);
    }
    var sessionId = readCookie(SID_COOKIE);
    if (!sessionId) {
      sessionId = uuid();
    }
    // Always refresh session cookie so it slides while the visitor is active
    writeCookie(SID_COOKIE, sessionId, THIRTY_MIN);

    // ── Capability + bot-detection signals ──────────────────────────────────
    var nav = navigator || {};
    var scr = screen || {};
    var loadMs = 0;
    try {
      var navEntry = performance && performance.getEntriesByType
        ? performance.getEntriesByType('navigation')[0] : null;
      if (navEntry && navEntry.responseEnd && navEntry.startTime != null) {
        loadMs = Math.max(0, Math.round(navEntry.responseEnd - navEntry.startTime));
      } else if (performance && performance.timing && performance.timing.responseEnd) {
        loadMs = Math.max(0, performance.timing.responseEnd - performance.timing.navigationStart);
      }
    } catch (e) {}

    var payload = {
      shop: SHOP,
      page_type: 'product',
      product_id: PRODUCT_ID != null ? String(PRODUCT_ID) : null,
      product_handle: PRODUCT_HANDLE,
      url: location.pathname + location.search,
      referrer: document.referrer || null,
      client_id: clientId,
      session_id: sessionId,
      webdriver: !!nav.webdriver,
      plugins_count: (nav.plugins && nav.plugins.length) || 0,
      cookie_enabled: !!nav.cookieEnabled,
      chrome: !!window.chrome,
      viewport_w: window.innerWidth || 0,
      viewport_h: window.innerHeight || 0,
      screen_w: scr.width || 0,
      screen_h: scr.height || 0,
      dpr: window.devicePixelRatio || 1,
      language: nav.language || null,
      languages_count: (nav.languages && nav.languages.length) || 0,
      tz_offset: new Date().getTimezoneOffset(),
      load_ms: loadMs,
      ts: new Date().toISOString()
    };

    function send() {
      try {
        var body = JSON.stringify(payload);
        // sendBeacon is non-blocking and survives page unload.
        // Use text/plain so it's a CORS-safelisted "simple" request - this
        // avoids the preflight that would otherwise be blocked because
        // sendBeacon always sends with credentials:include. The server
        // parses the body as JSON regardless of content-type.
        if (nav.sendBeacon) {
          var blob = new Blob([body], { type: 'text/plain;charset=UTF-8' });
          if (nav.sendBeacon(ENDPOINT, blob)) return;
        }
        // Fallback: fetch with text/plain too, again to skip preflight
        fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=UTF-8' },
          body: body,
          keepalive: true,
          credentials: 'omit',
          mode: 'cors'
        }).catch(function () { /* swallow */ });
      } catch (e) { /* never block the storefront */ }
    }

    // Defer until the browser is idle so we don't compete with paint/LCP
    if (window.requestIdleCallback) {
      requestIdleCallback(send, { timeout: 3000 });
    } else {
      setTimeout(send, 500);
    }
  })();
</script>
{%- endif -%}
