{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-social-proof-badge-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-social-proof-badge__container-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: var(--color-background, {{ block.settings.background_color }});
    border-radius: var(--style-border-radius-cards);
    {% if block.settings.show_border %}
      border: {{ block.settings.border_width }}px solid var(--color-border, {{ block.settings.border_color }});
    {% endif %}
  }

  .ai-social-proof-badge__stars-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.star_spacing }}px;
  }

  .ai-social-proof-badge__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    flex-shrink: 0;
  }

  .ai-social-proof-badge__star-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: var(--color-primary, {{ block.settings.star_color }});
  }

  .ai-social-proof-badge__text-{{ ai_gen_id }} {
    color: var(--color-foreground, {{ block.settings.text_color }});
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    line-height: 1.3;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-social-proof-badge__container-{{ ai_gen_id }} {
      gap: {{ block.settings.spacing | times: 0.8 }}px;
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-social-proof-badge__star-{{ ai_gen_id }} {
      width: {{ block.settings.star_size | times: 0.8 }}px;
      height: {{ block.settings.star_size | times: 0.8 }}px;
    }

    .ai-social-proof-badge__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-social-proof-badge-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-social-proof-badge__container-{{ ai_gen_id }}">
    <div class="ai-social-proof-badge__stars-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        <div class="ai-social-proof-badge__star-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
      {% endfor %}
    </div>
    <div class="ai-social-proof-badge__text-{{ ai_gen_id }}">
      {{ block.settings.badge_text }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Social proof badge",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "15,000+ Satisfied Customers"
    },
    {
      "type": "header",
      "content": "Stars"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "star_spacing",
      "label": "Star spacing",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#c9a690"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 2,
      "step": 0.1,
      "unit": "px",
      "default": 0.3
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#6b5d56"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Gap between stars and text",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show border",
      "default": false
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e8ddd4"
    }
  ],
  "presets": [
    {
      "name": "Social proof badge"
    }
  ]
}
{% endschema %}
