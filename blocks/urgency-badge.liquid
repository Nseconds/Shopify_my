{% doc %}
  Inline urgency message with a pulsing dot and a pseudo-random “units left” count derived from
  the current second (updates on each full page render).
{% enddoc %}

{% liquid
  assign ai_gen_id = block.id | replace: '_', '-' | downcase
  assign random_seed = 'now' | date: '%s' | modulo: 100
  assign units_left = random_seed | modulo: block.settings.max_units | plus: block.settings.min_units
%}

{% style %}
  .ai-urgency-badge-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-urgency-badge__container-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: 700;
    font-family: var(--font-heading-family);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-urgency-badge__dot-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    background-color: {{ block.settings.dot_color }};
    border-radius: 50%;
    flex-shrink: 0;
    animation: ai-urgency-pulse-{{ ai_gen_id }} 1.5s ease-in-out infinite;
  }

  .ai-urgency-badge__dot-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.dot_color }};
    border-radius: 50%;
    opacity: 0.6;
    animation: ai-urgency-ripple-{{ ai_gen_id }} 1.5s ease-out infinite;
  }

  @keyframes ai-urgency-pulse-{{ ai_gen_id }} {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(0.9);
    }
  }

  @keyframes ai-urgency-ripple-{{ ai_gen_id }} {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.6;
    }
    100% {
      transform: translate(-50%, -50%) scale(2.5);
      opacity: 0;
    }
  }

  .ai-urgency-badge__text-{{ ai_gen_id }} {
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    .ai-urgency-badge__container-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
      gap: 8px;
    }

    .ai-urgency-badge__dot-{{ ai_gen_id }} {
      width: {{ block.settings.dot_size | times: 0.85 }}px;
      height: {{ block.settings.dot_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-urgency-badge-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-urgency-badge__container-{{ ai_gen_id }}">
    <span class="ai-urgency-badge__dot-{{ ai_gen_id }}"></span>
    <span class="ai-urgency-badge__text-{{ ai_gen_id }}">
      {{ block.settings.prefix_text }} {{ units_left }} {{ block.settings.suffix_text }}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Urgency badge",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "prefix_text",
      "label": "Prefix text",
      "default": "Selling fast -"
    },
    {
      "type": "text",
      "id": "suffix_text",
      "label": "Suffix text",
      "default": "units left today"
    },
    {
      "type": "range",
      "id": "min_units",
      "label": "Minimum units",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "max_units",
      "label": "Maximum units",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#22c55e"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Blinking dot"
    },
    {
      "type": "range",
      "id": "dot_size",
      "label": "Dot size",
      "min": 6,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#22c55e"
    }
  ],
  "presets": [
    {
      "name": "Urgency badge"
    }
  ]
}
{% endschema %}
