{%- comment -%}
  Preview-only mirror of the Forge AI Reviews "Review Box" app embed block.

  In production, the section is emitted as a `_blocks` container with a block
  of type `shopify://apps/forge-ai-store-builder[-dev]/blocks/review-box/<uuid>`,
  and Shopify renders this widget via the installed Forge AI Store Builder app
  (source: extensions/bundle-ui/blocks/review-box.liquid).

  The local theme preview renderer (`app/services/render-liquid/index.ts`)
  strips the `shopify://apps/.../blocks/<name>/<uuid>` URI down to `<name>`
  and resolves it to this file so the editor/preview shows the same widget.
{%- endcomment -%}

{%- liquid
  if product == blank
    assign product = closest.product
  endif
  if product == blank and template.name == 'index'
    assign product = collections.all.products.first
  endif
-%}
{%- capture api_base -%}{%- render 'forge-reviews-api-base' -%}{%- endcapture -%}
{%- assign show_sample = false -%}
{%- if block.settings.show_sample_data and request.design_mode -%}
  {%- assign show_sample = true -%}
{%- endif -%}

{%- if product.featured_image -%}
  {%- assign forge_review_product_image = product.featured_image | image_url: width: 280 -%}
{%- endif -%}

<div
  class="forge-reviews-root"
  data-api-base="{{ api_base }}"
  data-shop="{{ shop.permanent_domain }}"
  data-product="{{ product.id }}"
>
  <forge-reviews
    data-mode="box"
    data-api-base="{{ api_base }}"
    data-shop="{{ shop.permanent_domain }}"
    data-product="{{ product.id }}"
    data-product-image="{{ forge_review_product_image }}"
    data-product-title="{{ product.title | escape }}"
    data-per-page="{{ block.settings.per_page }}"
    data-stars-color="{{ block.settings.stars_color }}"
    data-alignment="{{ block.settings.alignment | default: 'center' }}"
    data-show-pagination="{% if block.settings.show_pagination == false %}0{% else %}1{% endif %}"
    data-show-count="{% if block.settings.show_count == false %}0{% else %}1{% endif %}"
    {% if show_sample %}data-sample="1"{% endif %}
  >
    {% render 'forge-reviews-i18n' %}
  </forge-reviews>
</div>

<script src="{{ 'forge-reviews.js' | asset_url }}" defer></script>
{{ 'forge-reviews.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Forge Reviews Box",
  "settings": [
    { "type": "range", "id": "per_page", "label": "Reviews per page", "min": 5, "max": 20, "step": 1, "default": 10 },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination",
      "info": "Lets shoppers page through older reviews. Hide to only ever show the most recent page.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show number of reviews",
      "info": "Hide to omit the total review count shown next to the average rating.",
      "default": true
    },
    { "type": "color", "id": "stars_color", "label": "Stars color", "default": "#f5a623" },
    {
      "type": "select",
      "id": "alignment",
      "label": "Header alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    { "type": "header", "content": "Preview" },
    {
      "type": "checkbox",
      "id": "show_sample_data",
      "label": "Show sample data",
      "info": "Displays example reviews in the theme editor only. Real shoppers never see this.",
      "default": false
    }
  ]
}
{% endschema %}
