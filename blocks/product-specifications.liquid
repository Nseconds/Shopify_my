{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .product-specs-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .product-specs__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-specs__divider-{{ ai_gen_id }} {
    height: 1px;
    background-color: var(--color-border, {{ block.settings.divider_color }});
    margin: 8px 0;
  }

  .product-specs__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: {{ block.settings.spec_spacing }}px 24px;
  }

  .product-specs__label-{{ ai_gen_id }} {
    font-size: 14px;
    color: var(--color-foreground, {{ block.settings.spec_label_color }});
    font-weight: 600;
  }

  .product-specs__value-{{ ai_gen_id }} {
    font-size: 14px;
    color: var(--color-foreground-muted, var(--color-foreground, {{ block.settings.spec_value_color }}));
  }

  .product-specs__show-more-{{ ai_gen_id }} {
    margin-top: 12px;
  }

  .product-specs__show-more-link-{{ ai_gen_id }} {
    font-size: 14px;
    color: var(--color-foreground-muted, {{ block.settings.show_more_color }});
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .product-specs__show-more-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .product-specs__hidden-{{ ai_gen_id }} {
    display: none;
  }

  .product-specs__hidden-{{ ai_gen_id }}.active {
    display: contents;
  }

  @media screen and (max-width: 749px) {
    .product-specs__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .product-specs__label-{{ ai_gen_id }} {
      font-weight: 600;
    }

    .product-specs__value-{{ ai_gen_id }} {
      margin-bottom: 8px;
    }
  }
{% endstyle %}

<product-specifications class="product-specs-{{ ai_gen_id }}" data-show-more-text="{{ block.settings.show_more_text }}" data-show-less-text="{{ block.settings.show_less_text }}" {{ block.shopify_attributes }}>
  <div class="product-specs__container-{{ ai_gen_id }}">
    {% if block.settings.show_divider %}
      <div class="product-specs__divider-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="product-specs__grid-{{ ai_gen_id }}">
      {% if block.settings.spec_1_label != blank %}
        <div class="product-specs__label-{{ ai_gen_id }}">{{ block.settings.spec_1_label }}</div>
        <div class="product-specs__value-{{ ai_gen_id }}">{{ block.settings.spec_1_value }}</div>
      {% endif %}

      {% if block.settings.spec_2_label != blank %}
        <div class="product-specs__label-{{ ai_gen_id }}">{{ block.settings.spec_2_label }}</div>
        <div class="product-specs__value-{{ ai_gen_id }}">{{ block.settings.spec_2_value }}</div>
      {% endif %}

      {% if block.settings.spec_3_label != blank %}
        <div class="product-specs__label-{{ ai_gen_id }}">{{ block.settings.spec_3_label }}</div>
        <div class="product-specs__value-{{ ai_gen_id }}">{{ block.settings.spec_3_value }}</div>
      {% endif %}

      {% if block.settings.spec_4_label != blank %}
        <div class="product-specs__label-{{ ai_gen_id }}">{{ block.settings.spec_4_label }}</div>
        <div class="product-specs__value-{{ ai_gen_id }}">{{ block.settings.spec_4_value }}</div>
      {% endif %}

      <div class="product-specs__hidden-{{ ai_gen_id }}">
        {% if block.settings.spec_5_label != blank %}
          <div class="product-specs__label-{{ ai_gen_id }}">{{ block.settings.spec_5_label }}</div>
          <div class="product-specs__value-{{ ai_gen_id }}">{{ block.settings.spec_5_value }}</div>
        {% endif %}

        {% if block.settings.spec_6_label != blank %}
          <div class="product-specs__label-{{ ai_gen_id }}">{{ block.settings.spec_6_label }}</div>
          <div class="product-specs__value-{{ ai_gen_id }}">{{ block.settings.spec_6_value }}</div>
        {% endif %}

        {% if block.settings.spec_7_label != blank %}
          <div class="product-specs__label-{{ ai_gen_id }}">{{ block.settings.spec_7_label }}</div>
          <div class="product-specs__value-{{ ai_gen_id }}">{{ block.settings.spec_7_value }}</div>
        {% endif %}

        {% if block.settings.spec_8_label != blank %}
          <div class="product-specs__label-{{ ai_gen_id }}">{{ block.settings.spec_8_label }}</div>
          <div class="product-specs__value-{{ ai_gen_id }}">{{ block.settings.spec_8_value }}</div>
        {% endif %}
      </div>
    </div>

    {% assign has_hidden_specs = false %}
    {% if block.settings.spec_5_label != blank or block.settings.spec_6_label != blank or block.settings.spec_7_label != blank or block.settings.spec_8_label != blank %}
      {% assign has_hidden_specs = true %}
    {% endif %}

    {% if has_hidden_specs and block.settings.show_more_enabled %}
      <div class="product-specs__show-more-{{ ai_gen_id }}">
        <button class="product-specs__show-more-link-{{ ai_gen_id }}" data-show-more data-specs-show-more>
          {{ block.settings.show_more_text }}
        </button>
      </div>
    {% endif %}
  </div>
</product-specifications>

<script>
  (function() {
    if (customElements.get('product-specifications')) return;

    class ProductSpecifications extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.showMoreButton = this.querySelector('[data-specs-show-more]');
        this.hiddenSpecs = this.querySelector('[class*="product-specs__hidden-"]');
        this.showMoreText = this.dataset.showMoreText || 'Show More';
        this.showLessText = this.dataset.showLessText || 'Show Less';

        if (this.showMoreButton && this.hiddenSpecs) {
          this.showMoreButton.addEventListener('click', this.toggleSpecs.bind(this));
        }
      }

      toggleSpecs() {
        const isExpanded = this.hiddenSpecs.classList.contains('active');

        if (isExpanded) {
          this.hiddenSpecs.classList.remove('active');
          this.showMoreButton.textContent = this.showMoreText;
        } else {
          this.hiddenSpecs.classList.add('active');
          this.showMoreButton.textContent = this.showLessText;
        }
      }
    }

    customElements.define('product-specifications', ProductSpecifications);
  })();
</script>

