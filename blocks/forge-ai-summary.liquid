{%- liquid
  if product == blank
    assign product = closest.product
  endif
  if product == blank and template.name == 'index'
    assign product = collections.all.products.first
  endif
-%}
{%- capture api_base -%}{%- render 'forge-reviews-api-base' -%}{%- endcapture -%}
{%- assign show_sample = false -%}
{%- if block.settings.show_sample_data and request.design_mode -%}
  {%- assign show_sample = true -%}
{%- endif -%}

<forge-reviews
  data-mode="summary"
  data-api-base="{{ api_base }}"
  data-shop="{{ shop.permanent_domain }}"
  data-product="{{ product.id }}"
  data-summary-heading="{{ block.settings.heading | escape }}"
  data-summary-heading-size="{{ block.settings.heading_size | default: 'medium' }}"
  data-summary-show-badge="{% if block.settings.show_ai_badge == false %}0{% else %}1{% endif %}"
  data-summary-show-pros="{% if block.settings.show_pros == false %}0{% else %}1{% endif %}"
  data-summary-show-cons="{% if block.settings.show_cons == false %}0{% else %}1{% endif %}"
  data-summary-layout="{{ block.settings.layout | default: 'side-by-side' }}"
  data-summary-card-style="{{ block.settings.card_style | default: 'card' }}"
  data-summary-accent-color="{{ block.settings.accent_color }}"
  data-alignment="{{ block.settings.alignment | default: 'left' }}"
  data-stars-color="{{ block.settings.accent_color }}"
  {% if show_sample %}data-sample="1"{% endif %}
>
  {% render 'forge-reviews-i18n' %}
</forge-reviews>

<script src="{{ 'forge-reviews.js' | asset_url }}" defer></script>
{{ 'forge-reviews.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "t:blocks.forge_ai_summary.name",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What customers are saying" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "card_style",
      "label": "Container style",
      "default": "card",
      "options": [
        { "value": "card", "label": "Card (background + border)" },
        { "value": "plain", "label": "Plain (no background)" }
      ]
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Pros & cons layout",
      "default": "side-by-side",
      "options": [
        { "value": "side-by-side", "label": "Side by side" },
        { "value": "stacked", "label": "Stacked" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_pros",
      "label": "Show pros",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cons",
      "label": "Show cons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_ai_badge",
      "label": "Show AI generated badge",
      "info": "Adds a small badge for transparency that the summary is AI generated.",
      "default": true
    },

    { "type": "header", "content": "Color" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#f5a623" },

    { "type": "header", "content": "Preview" },
    {
      "type": "checkbox",
      "id": "show_sample_data",
      "label": "Show sample data",
      "info": "Displays an example AI summary in the theme editor only. Real shoppers never see this.",
      "default": false
    }
  ]
}
{% endschema %}
