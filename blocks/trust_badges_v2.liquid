{% assign ai_gen_id = block.id | replace: '_', '-' | downcase %}
{% assign ai_gen_id_js = block.id | replace: '_', '' | replace: '-', '' | downcase %}
{% if block.settings.icon_use_theme_primary %}
  {% assign trust_icon_paint = 'var(--color-primary, ' | append: block.settings.icon_color | append: ')' %}
{% else %}
  {% assign trust_icon_paint = block.settings.icon_color %}
{% endif %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.badge_spacing }}px;
    flex-wrap: wrap;
    padding: {{ block.settings.container_padding }}px;
  }

  .ai-trust-badge-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.icon_text_gap }}px;
    padding: {{ block.settings.badge_padding }}px;
    background: var(--color-background, {{ block.settings.badge_background }});
    border-radius: var(--style-border-radius-cards);
    border: {{ block.settings.border_width }}px solid var(--color-border, {{ block.settings.border_color }});
    box-shadow: 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_blur }}px {{ block.settings.glow_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    flex: 1;
    min-width: {{ block.settings.min_badge_width }}px;
    max-width: {{ block.settings.max_badge_width }}px;
  }

  .ai-trust-badge-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.glow_intensity | plus: 4 }}px {{ block.settings.glow_blur | plus: 8 }}px {{ block.settings.glow_color }};
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ trust_icon_paint }};
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {% if block.settings.icon_fill_color == blank %}transparent{% else %}{{ block.settings.icon_fill_color }}{% endif %};
  }

  .ai-trust-badge-text-{{ ai_gen_id }} {
    text-align: center;
    color: var(--color-foreground, {{ block.settings.text_color }});
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges-container-{{ ai_gen_id }} {
      gap: {{ block.settings.badge_spacing | times: 0.7 }}px;
    }

    .ai-trust-badge-{{ ai_gen_id }} {
      padding: {{ block.settings.badge_padding | times: 0.8 }}px;
      min-width: {{ block.settings.min_badge_width | times: 0.8 }}px;
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-trust-badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<trust-badges-{{ ai_gen_id }} class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badges-container-{{ ai_gen_id }}">
    {% if block.settings.badge_1_enabled %}
      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          {% if block.settings.badge_1_icon == 'shield' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          {% elsif block.settings.badge_1_icon == 'check' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          {% elsif block.settings.badge_1_icon == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% elsif block.settings.badge_1_icon == 'truck' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13"></rect>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
              <circle cx="5.5" cy="18.5" r="2.5"></circle>
              <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
          {% elsif block.settings.badge_1_icon == 'lock' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          {% endif %}
        </div>
        {% if block.settings.badge_1_text != blank %}
          <div class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_1_text }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.badge_2_enabled %}
      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          {% if block.settings.badge_2_icon == 'shield' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          {% elsif block.settings.badge_2_icon == 'check' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          {% elsif block.settings.badge_2_icon == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% elsif block.settings.badge_2_icon == 'truck' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13"></rect>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
              <circle cx="5.5" cy="18.5" r="2.5"></circle>
              <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
          {% elsif block.settings.badge_2_icon == 'lock' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          {% endif %}
        </div>
        {% if block.settings.badge_2_text != blank %}
          <div class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_2_text }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.badge_3_enabled %}
      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          {% if block.settings.badge_3_icon == 'shield' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          {% elsif block.settings.badge_3_icon == 'check' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          {% elsif block.settings.badge_3_icon == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% elsif block.settings.badge_3_icon == 'truck' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13"></rect>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
              <circle cx="5.5" cy="18.5" r="2.5"></circle>
              <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
          {% elsif block.settings.badge_3_icon == 'lock' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
