      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#ffa02a"
    },
    {
      "type": "checkbox",
      "id": "icon_use_theme_primary",
      "label": "Use theme primary color for icons",
      "default": true,
      "info": "When enabled, icons follow the theme’s primary color and Icon color is only used if primary is unavailable. Turn off to always use Icon color."
    },
    {
      "type": "color",
      "id": "icon_fill_color",
      "label": "Icon fill (CSS)",
      "default": "rgba(0,0,0,0)",
      "info": "Separate CSS fill on the SVG. Default is transparent so strokes and currentColor (from Icon color) control the shape. Choose a color to tint or solid-fill the icon; outline icons may look filled when this is not transparent."
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Icon to text gap",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "range",
      "id": "text_size",
