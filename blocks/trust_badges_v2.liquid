      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "min_badge_width",
      "label": "Min badge width",
      "min": 80,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "max_badge_width",
      "label": "Max badge width",
      "min": 150,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "header",
      "content": "Badge style"
    },
    {
      "type": "range",
      "id": "badge_padding",
      "label": "Badge padding",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Background",
      "default": "#fff9f2"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#ffa02a"
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Glow intensity",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "glow_blur",
      "label": "Glow blur",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "rgba(255, 160, 42, 0.3)"
    },
    {
      "type": "range",
      "id": "hover_lift",
      "label": "Hover lift",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Icon"
