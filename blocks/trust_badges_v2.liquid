            </svg>
          {% endif %}
        </div>
        {% if block.settings.badge_3_text != blank %}
          <div class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_3_text }}</div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</trust-badges-{{ ai_gen_id }}>

<script>
  (function() {
    class TrustBadges{{ ai_gen_id_js }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('trust-badges-{{ ai_gen_id }}', TrustBadges{{ ai_gen_id_js }});
  })();
</script>

{% schema %}
{
