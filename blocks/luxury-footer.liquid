{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-footer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-luxury-footer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-luxury-footer-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-luxury-footer-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.link_spacing }}px;
  }

  .ai-luxury-footer-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
  }

  .ai-luxury-footer-link-{{ ai_gen_id }} {
    font-family: {{ block.settings.link_font.family }}, {{ block.settings.link_font.fallback_families }};
    font-weight: {{ block.settings.link_font.weight }};
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: opacity 0.3s ease;
    line-height: 1.6;
  }

  .ai-luxury-footer-link-{{ ai_gen_id }}:hover {
    opacity: {{ block.settings.link_hover_opacity | divided_by: 100.0 }};
    {% if block.settings.link_hover_underline %}
      text-decoration: underline;
    {% endif %}
  }

  /* Scoped overrides so a nested `social-links` theme block inherits the
     luxury-footer's social icon controls (color, size, spacing, hover). */
  .ai-luxury-footer-social-slot-{{ ai_gen_id }} {
    color: {{ block.settings.social_icon_color }};
  }

  .ai-luxury-footer-social-slot-{{ ai_gen_id }} .social-icons__wrapper {
    gap: {{ block.settings.social_icon_spacing }}px;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .ai-luxury-footer-social-slot-{{ ai_gen_id }} .social-icons__icon-wrapper {
    height: {{ block.settings.social_icon_size }}px;
    width: {{ block.settings.social_icon_size }}px;
    transition: opacity 0.3s ease;
  }

  .ai-luxury-footer-social-slot-{{ ai_gen_id }} .social-icons__icon-wrapper:hover {
    opacity: {{ block.settings.social_icon_hover_opacity | divided_by: 100.0 }};
  }

  .ai-luxury-footer-social-slot-{{ ai_gen_id }} .social-icons__icon {
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
    fill: currentColor;
  }

  @media screen and (max-width: 989px) {
    .ai-luxury-footer-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.mobile_column_gap }}px {{ block.settings.column_gap }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-footer-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px 0 {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-luxury-footer-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_horizontal_padding }}px;
    }

    .ai-luxury-footer-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_column_gap }}px;
    }

    .ai-luxury-footer-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-luxury-footer-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_link_size }}px;
    }
  }
{% endstyle %}

<luxury-footer-{{ ai_gen_id }} class="ai-luxury-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-footer-container-{{ ai_gen_id }}">
