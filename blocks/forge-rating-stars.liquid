{%- liquid
  if product == blank
    assign product = closest.product
  endif
  if product == blank and template.name == 'index'
    assign product = collections.all.products.first
  endif
  assign rating = product.metafields.forge_reviews.aggregate_rating.value | default: 0
  assign count = product.metafields.forge_reviews.review_count.value | default: 0
-%}
{%- capture api_base -%}{%- render 'forge-reviews-api-base' -%}{%- endcapture -%}
{%- assign show_sample = false -%}
{%- if block.settings.show_sample_data and request.design_mode -%}
  {%- assign show_sample = true -%}
{%- endif -%}

<forge-reviews
  data-mode="stars"
  data-api-base="{{ api_base }}"
  data-shop="{{ shop.permanent_domain }}"
  data-product="{{ product.id }}"
  data-rating="{{ rating }}"
  data-count="{{ count }}"
  data-stars-color="{{ block.settings.stars_color | default: '#f5a623' }}"
  {% if show_sample %}data-sample="1"{% endif %}
>
  {%- if block.settings.inline_text != blank -%}
    <template class="forge-reviews__stars-inline-text">{{ block.settings.inline_text }}</template>
  {%- endif -%}
</forge-reviews>

{% if rating > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AggregateRating",
  "itemReviewed": {
    "@type": "Product",
    "name": {{ product.title | json }},
    "sku": {{ product.selected_or_first_available_variant.sku | json }}
  },
  "ratingValue": "{{ rating }}",
  "reviewCount": "{{ count }}"
}
</script>
{% endif %}

<script src="{{ 'forge-reviews.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:blocks.forge_rating_stars.name",
  "settings": [
    { "type": "color", "id": "stars_color", "label": "Stars color", "default": "#f5a623" },
    {
      "type": "richtext",
      "id": "inline_text",
      "label": "Inline text",
      "info": "Optional text shown to the right of the rating (supports bold, italic, links)."
    },
    { "type": "header", "content": "Preview" },
    {
      "type": "checkbox",
      "id": "show_sample_data",
      "label": "Show sample data",
      "info": "Displays an example rating in the theme editor only. Real shoppers never see this.",
      "default": false
    }
  ]
}
{% endschema %}
