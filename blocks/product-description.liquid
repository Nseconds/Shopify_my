

{% liquid
  assign product = block.settings.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
    assign text = product.description
  endif
%}

{% comment %} Apply character limit if set {% endcomment %}
{% liquid
  assign char_limit = block.settings.character_limit
  assign text_content = block.settings.text
  
  if char_limit > 0 and text_content != blank
    assign text_plain = text_content | strip_html | strip
    if text_plain.size > char_limit
      assign text_content = text_plain | truncate: char_limit, ''
    endif
  endif
%}

{% comment %} Override block.settings.text temporarily for rendering {% endcomment %}
{% if char_limit > 0 and text_content != block.settings.text %}
  {% liquid
    assign type = 'body'
    if block.settings.font_size contains 'heading-lg' or block.settings.font_size contains 'heading-xl'
      assign type = 'display'
    elsif block.settings.font_size contains 'heading'
      assign type = 'heading'
    endif
    
    assign text_classes = 'text-block text-block--' | append: block.id | append: ' ' | append: block.settings.type_preset | append: ' spacing-style'
    
    if block.settings.width == '100%'
      assign text_classes = text_classes | append: ' text-block--align-' | append: block.settings.alignment
      if block.settings.max_width == 'none'
        assign text_classes = text_classes | append: ' text-block--full-width'
      endif
    endif
    
    if block.settings.type_preset == 'custom'
      assign text_classes = text_classes | append: ' custom-typography'
      if block.settings.font_size != ''
        assign text_classes = text_classes | append: ' custom-font-size'
      endif
      if block.settings.color != ''
        assign text_classes = text_classes | append: ' custom-color'
      endif
    endif
    
    if block.settings.background
      assign text_classes = text_classes | append: ' text-block--background'
    endif
  %}
  
  <div 
    class="{{ text_classes }}"
    style="
      {% render 'spacing-padding', settings: block.settings %}
      {% render 'typography-style', settings: block.settings %}
      --width: {{ block.settings.width }};
      --max-width: var(--max-width--{{ type }}-{{ block.settings.max_width }});
      {% if block.settings.width == '100%' %}
        --text-align: {{ block.settings.alignment }};
      {% endif %}
      {% if block.settings.background %}
        --text-background-color: {{ block.settings.background_color | default: 'rgb(255 255 255 / 1.0)' }};
        --text-corner-radius: {{ block.settings.corner_radius }}px;
        --text-padding: max(var(--padding-2xs), calc((var(--text-corner-radius) + var(--padding-xs)) * (1 - cos(45deg))));
      {% endif %}
    "
    {{ block.shopify_attributes }}
  >
    {{ text_content }}
  </div>
{% else %}
  {% render 'text', fallback_text: text, block: block %}
{% endif %}

