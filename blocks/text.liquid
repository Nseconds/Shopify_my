
{% liquid
  assign char_limit = block.settings.character_limit
  assign text_content = block.settings.text
  
  if char_limit > 0 and text_content != blank
    assign text_plain = text_content | strip_html | strip
    if text_plain.size > char_limit
      assign text_content = text_plain | truncate: char_limit, ''
    endif
  endif
%}

{% if char_limit > 0 and text_content != block.settings.text %}
  {% render 'text', block: block, text_override: text_content %}
{% else %}
  {% render 'text', block: block %}
{% endif %}

{% schema %}
{
  "name": "t:names.text",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "t:settings.text"
    },
    {
      "type": "range",
      "id": "character_limit",
      "label": "Character limit",
      "info": "Limit description length (0 = no limit)",
      "min": 0,
      "max": 1000,
      "step": 10,
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width",
