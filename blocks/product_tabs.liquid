{% assign ai_gen_id = block.id | replace: '_', '-' | downcase %}
{% assign ai_gen_id_js = block.id | replace: '_', '' | replace: '-', '' | downcase %}

{% style %}
  .ai-tabs-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background: {{ block.settings.background_color }};
    position: relative;
    overflow: hidden;
  }

  .ai-tabs-section-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    background: linear-gradient(135deg, {{ block.settings.accent_color }} 0%, transparent 70%);
    opacity: 0.15;
    pointer-events: none;
    z-index: 0;
  }

  .ai-tabs-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
  }

  .ai-tabs-nav-{{ ai_gen_id }} {
    display: flex;
    gap: 40px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    margin-bottom: 32px;
  }

  .ai-tab-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 16px 0;
    font-size: {{ block.settings.tab_font_size }}px;
    font-weight: 400;
    color: {{ block.settings.tab_inactive_color }};
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-tab-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_active_color }};
  }

  .ai-tab-button-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
    font-weight: 600;
  }

  .ai-tab-button-{{ ai_gen_id }}.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background-color: {{ block.settings.tab_underline_color }};
  }

  .ai-tabs-content-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-tab-panel-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .ai-tab-panel-{{ ai_gen_id }}.active {
    display: block;
    animation: ai-fade-in-{{ ai_gen_id }} 0.4s ease forwards;
  }

  @keyframes ai-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-content-card-{{ ai_gen_id }} {
    background: {% if block.settings.card_background != blank %}{{ block.settings.card_background }}{% else %}var(--color-background-secondary){% endif %};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: var(--style-border-radius-cards);
    padding: {{ block.settings.card_padding }}px;
    position: relative;
    min-height: 200px;
  }

  .ai-badge-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: -12px;
    left: 24px;
    background: {% if block.settings.badge_background != blank %}{{ block.settings.badge_background }}{% else %}var(--color-primary){% endif %};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 16px;
    border-radius: var(--style-border-radius-global);
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-badge-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .ai-content-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_font_size }}px;
    line-height: 1.8;
    color: {{ block.settings.content_text_color }};
    margin: 0;
  }

  .ai-content-text-{{ ai_gen_id }} p {
    margin-bottom: 16px;
  }

  .ai-content-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-tabs-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-tabs-nav-{{ ai_gen_id }} {
      gap: 24px;
    }

    .ai-tab-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
      padding: 12px 0;
    }

    .ai-content-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }

    .ai-badge-overlay-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size | times: 0.85 }}px;
      padding: 6px 12px;
      left: 16px;
    }

    .ai-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<product-tabs-{{ ai_gen_id }} class="ai-tabs-section-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
  <div class="ai-tabs-container-{{ ai_gen_id }}">
    <div class="ai-tabs-nav-{{ ai_gen_id }}" role="tablist">
      <button
        class="ai-tab-button-{{ ai_gen_id }} active"
        role="tab"
        aria-selected="true"
        aria-controls="ai-tab-benefits-{{ ai_gen_id }}"
        data-tab="benefits"
      >
        {{ block.settings.tab_1_label }}
      </button>
      <button
        class="ai-tab-button-{{ ai_gen_id }}"
        role="tab"
        aria-selected="false"
        aria-controls="ai-tab-ingredients-{{ ai_gen_id }}"
        data-tab="ingredients"
      >
        {{ block.settings.tab_2_label }}
      </button>
    </div>

    <div class="ai-tabs-content-{{ ai_gen_id }}">
      <div
        id="ai-tab-benefits-{{ ai_gen_id }}"
        class="ai-tab-panel-{{ ai_gen_id }} active"
        role="tabpanel"
        data-panel="benefits"
      >
        <div class="ai-content-card-{{ ai_gen_id }}">
          <div class="ai-badge-overlay-{{ ai_gen_id }}">
            <span class="ai-badge-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
            <span>{{ block.settings.tab_1_badge }}</span>
          </div>
          <div class="ai-content-text-{{ ai_gen_id }}">
            {{ block.settings.tab_1_content }}
          </div>
        </div>
      </div>

      <div
        id="ai-tab-ingredients-{{ ai_gen_id }}"
        class="ai-tab-panel-{{ ai_gen_id }}"
        role="tabpanel"
        data-panel="ingredients"
      >
        <div class="ai-content-card-{{ ai_gen_id }}">
          <div class="ai-badge-overlay-{{ ai_gen_id }}">
            <span class="ai-badge-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
            <span>{{ block.settings.tab_2_badge }}</span>
          </div>
          <div class="ai-content-text-{{ ai_gen_id }}">
            {{ block.settings.tab_2_content }}
          </div>
        </div>
      </div>
    </div>
  </div>
</product-tabs-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductTabs{{ ai_gen_id_js }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabButtons = this.querySelectorAll('.ai-tab-button-{{ ai_gen_id }}');
        this.tabPanels = this.querySelectorAll('.ai-tab-panel-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const targetTab = button.getAttribute('data-tab');
            this.switchTab(targetTab);
          });
        });
      }

      switchTab(targetTab) {
        this.tabButtons.forEach((btn) => {
          const isActive = btn.getAttribute('data-tab') === targetTab;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-selected', isActive);
        });

        this.tabPanels.forEach((panel) => {
          const isActive = panel.getAttribute('data-panel') === targetTab;
          if (isActive) {
            panel.classList.add('active');
          } else {
            panel.classList.remove('active');
          }
        });
      }
    }

    customElements.define('product-tabs-{{ ai_gen_id }}', ProductTabs{{ ai_gen_id_js }});
  })();
</script>

