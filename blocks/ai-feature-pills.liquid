{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign use_custom = block.settings.use_custom_colors %}

{% style %}
  .ai-feature-pills-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-feature-pills__container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.gap }}px;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-feature-pill-{{ ai_gen_id }} {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    border-radius: var(--style-border-radius-buttons-primary);
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    {% if use_custom %}
      background: {{ block.settings.pill_background }};
      color: {{ block.settings.pill_text_color }};
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
      box-shadow: 0 0 {{ block.settings.glow_blur }}px {{ block.settings.glow_spread }}px {{ block.settings.glow_color }};
    {% elsif settings.style_mode == 'gradient' %}
      background: var(--color-primary-button-background);
      color: var(--color-primary-button-text);
      border: {{ block.settings.border_width }}px solid transparent;
      box-shadow: none;
    {% else %}
      background: var(--color-primary);
      color: var(--color-primary-button-text);
      border: {{ block.settings.border_width }}px solid transparent;
      box-shadow: none;
    {% endif %}
  }

  .ai-feature-pill__content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
  }

  .ai-feature-pill__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-pill__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-feature-pill__text-{{ ai_gen_id }} {
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-feature-pills__container-{{ ai_gen_id }} {
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }

    .ai-feature-pill-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-feature-pill__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-feature-pills-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-pills__container-{{ ai_gen_id }}">
    {% if block.settings.feature_1_enabled %}
      <div class="ai-feature-pill-{{ ai_gen_id }}">
        <div class="ai-feature-pill__content-{{ ai_gen_id }}">
          {% if block.settings.feature_1_icon != blank %}
            <div class="ai-feature-pill__icon-{{ ai_gen_id }}">
              {{ block.settings.feature_1_icon }}
            </div>
          {% endif %}
          {% if block.settings.feature_1_text != blank %}
            <span class="ai-feature-pill__text-{{ ai_gen_id }}">
              {{ block.settings.feature_1_text }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.feature_2_enabled %}
      <div class="ai-feature-pill-{{ ai_gen_id }}">
        <div class="ai-feature-pill__content-{{ ai_gen_id }}">
          {% if block.settings.feature_2_icon != blank %}
            <div class="ai-feature-pill__icon-{{ ai_gen_id }}">
              {{ block.settings.feature_2_icon }}
            </div>
          {% endif %}
          {% if block.settings.feature_2_text != blank %}
            <span class="ai-feature-pill__text-{{ ai_gen_id }}">
              {{ block.settings.feature_2_text }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.feature_3_enabled %}
      <div class="ai-feature-pill-{{ ai_gen_id }}">
        <div class="ai-feature-pill__content-{{ ai_gen_id }}">
          {% if block.settings.feature_3_icon != blank %}
            <div class="ai-feature-pill__icon-{{ ai_gen_id }}">
              {{ block.settings.feature_3_icon }}
            </div>
          {% endif %}
          {% if block.settings.feature_3_text != blank %}
            <span class="ai-feature-pill__text-{{ ai_gen_id }}">
              {{ block.settings.feature_3_text }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.feature_4_enabled %}
      <div class="ai-feature-pill-{{ ai_gen_id }}">
        <div class="ai-feature-pill__content-{{ ai_gen_id }}">
          {% if block.settings.feature_4_icon != blank %}
            <div class="ai-feature-pill__icon-{{ ai_gen_id }}">
              {{ block.settings.feature_4_icon }}
            </div>
          {% endif %}
          {% if block.settings.feature_4_text != blank %}
            <span class="ai-feature-pill__text-{{ ai_gen_id }}">
              {{ block.settings.feature_4_text }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.feature_5_enabled %}
      <div class="ai-feature-pill-{{ ai_gen_id }}">
        <div class="ai-feature-pill__content-{{ ai_gen_id }}">
          {% if block.settings.feature_5_icon != blank %}
            <div class="ai-feature-pill__icon-{{ ai_gen_id }}">
              {{ block.settings.feature_5_icon }}
            </div>
          {% endif %}
          {% if block.settings.feature_5_text != blank %}
            <span class="ai-feature-pill__text-{{ ai_gen_id }}">
              {{ block.settings.feature_5_text }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.feature_6_enabled %}
      <div class="ai-feature-pill-{{ ai_gen_id }}">
        <div class="ai-feature-pill__content-{{ ai_gen_id }}">
          {% if block.settings.feature_6_icon != blank %}
            <div class="ai-feature-pill__icon-{{ ai_gen_id }}">
              {{ block.settings.feature_6_icon }}
            </div>
          {% endif %}
          {% if block.settings.feature_6_text != blank %}
            <span class="ai-feature-pill__text-{{ ai_gen_id }}">
              {{ block.settings.feature_6_text }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "AI Feature pills",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between pills",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Pill style"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 8,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false,
      "info": "When disabled, colors are inherited from the color scheme"
    },
    {
      "type": "color",
      "id": "pill_background",
      "label": "Background",
      "default": "#0A0A0A",
      "visible_if": "{{ block.settings.use_custom_colors }}"
    },
    {
      "type": "color",
      "id": "pill_text_color",
      "label": "Text color",
      "default": "#FFFFFF",
      "visible_if": "{{ block.settings.use_custom_colors }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#E0E0E0",
      "visible_if": "{{ block.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Glow effect",
      "visible_if": "{{ block.settings.use_custom_colors }}"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#FFD700",
      "visible_if": "{{ block.settings.use_custom_colors }}"
    },
    {
      "type": "range",
      "id": "glow_blur",
      "label": "Glow blur",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20,
      "visible_if": "{{ block.settings.use_custom_colors }}"
    },
    {
      "type": "range",
      "id": "glow_spread",
      "label": "Glow spread",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 2,
      "visible_if": "{{ block.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
