      "label": "Icon color",
      "default": "#8B0000"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "connector_color",
      "label": "Timeline connector color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Delivery Info",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}

