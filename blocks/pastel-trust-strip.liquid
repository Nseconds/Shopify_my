<div class="pastel-trust-strip spacing-style" {{ block.shopify_attributes }}>
  <div class="pastel-trust-strip__grid">
    {% for i in (1..3) %}
      {% assign key = 'item_' | append: i %}
      {% assign text = block.settings[key] %}
      {% if text != blank %}
        <div class="pastel-trust-strip__item">
          <span class="pastel-trust-strip__icon" aria-hidden="true">●</span>
          <span class="pastel-trust-strip__text">{{ text }}</span>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .pastel-trust-strip {
    padding-block: 10px 8px;
  }

  .pastel-trust-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .pastel-trust-strip__item {
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 48px;
    padding: 10px 12px;
    background: color-mix(in srgb, var(--color-foreground) 8%, var(--color-background));
    border-radius: 14px;
  }

  .pastel-trust-strip__icon {
    color: var(--color-foreground);
    font-size: 10px;
    line-height: 1;
  }

  .pastel-trust-strip__text {
    font-family: var(--font-body--family);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-foreground);
  }

  @media screen and (max-width: 749px) {
    .pastel-trust-strip__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust strip",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "item_1",
      "label": "Item 1",
      "default": "Fast shipping"
    },
    {
      "type": "text",
      "id": "item_2",
      "label": "Item 2",
      "default": "30-day returns"
    },
    {
      "type": "text",
      "id": "item_3",
      "label": "Item 3",
      "default": "Support when you need it"
    }
  ],
  "presets": [
    {
      "name": "Trust strip"
    }
  ]
}
{% endschema %}
