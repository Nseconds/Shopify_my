
{%- doc -%}
  Minimalistic shipping message block
  Displays a simple truck icon with customizable shipping message
{%- enddoc -%}

{%- liquid
  assign block_settings = block.settings
  assign threshold = block_settings.threshold | default: 50
  
  if block_settings.message != blank
    assign message = block_settings.message
  else
    assign message = 'Free Shipping on $' | append: threshold | append: '+'
  endif
-%}

<div
  class="shipping-message spacing-style"
  style="
    {% render 'spacing-padding', settings: block_settings %}
    --shipping-icon-size: {{ block_settings.icon_size }}px;
    --shipping-icon-color: {{ block_settings.icon_color }};
    --shipping-text-color: {{ block_settings.text_color }};
    --shipping-text-size: {{ block_settings.text_size }}px;
    --shipping-gap: {{ block_settings.gap }}px;
  "
  {{ block.shopify_attributes }}
>
  <div class="shipping-message__icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/>
      <path d="M5 16a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM19 16a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
    </svg>
  </div>
  <div class="shipping-message__text">
    {{ message }}
  </div>
</div>

{% stylesheet %}
  .shipping-message {
    display: flex;
    align-items: center;
    gap: var(--shipping-gap, 8px);
  }

  .shipping-message__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--shipping-icon-size, 20px);
    height: var(--shipping-icon-size, 20px);
    color: var(--shipping-icon-color, currentColor);
  }

  .shipping-message__icon svg {
    width: 100%;
    height: 100%;
  }

  .shipping-message__text {
    color: var(--shipping-text-color, currentColor);
    font-size: var(--shipping-text-size, 14px);
    line-height: 1.4;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Shipping Message",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Free Shipping on $50+",
      "info": "Leave empty to use default message with threshold"
    },
    {
      "type": "range",
      "id": "threshold",
      "label": "Threshold amount",
      "min": 0,
      "max": 500,
      "step": 5,
      "default": 50,
      "info": "Used in default message if custom message is empty"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between icon and text",
      "min": 4,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Shipping Message",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
