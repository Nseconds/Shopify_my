{% doc %}
  Grid of up to four highlight rows with optional icons (check, truck, tag, clock), configurable
  columns on desktop and mobile, and item styling.
{% enddoc %}

{% liquid
  assign ai_gen_id = block.id | replace: '_', '-' | downcase
%}

{% style %}
  .ai-highlight-points-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-highlight-points__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-highlight-points__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    padding: {{ block.settings.item_padding }}px;
    background: {{ block.settings.item_background }};
    border-radius: {{ block.settings.border_radius }}px;
    {% if block.settings.show_border %}
      border: 1px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-highlight-points__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.icon_background }};
    border-radius: 50%;
  }

  .ai-highlight-points__icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.icon_size }}px * 0.55);
    height: calc({{ block.settings.icon_size }}px * 0.55);
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-highlight-points__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.3;
    margin: 0;
    flex: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-highlight-points__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-highlight-points__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-highlight-points__icon-wrapper-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.85);
      height: calc({{ block.settings.icon_size }}px * 0.85);
    }
  }
{% endstyle %}

<div class="ai-highlight-points-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-highlight-points__grid-{{ ai_gen_id }}">
    {% if block.settings.show_point_1 and block.settings.point_1_text != blank %}
      <div class="ai-highlight-points__item-{{ ai_gen_id }}">
        <div class="ai-highlight-points__icon-wrapper-{{ ai_gen_id }}">
          {% if block.settings.point_1_icon == 'check' %}
            <svg class="ai-highlight-points__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {% elsif block.settings.point_1_icon == 'truck' %}
            <svg class="ai-highlight-points__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <rect x="1" y="3" width="15" height="13"></rect>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
              <circle cx="5.5" cy="18.5" r="2.5"></circle>
              <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
          {% elsif block.settings.point_1_icon == 'tag' %}
            <svg class="ai-highlight-points__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
              <line x1="7" y1="7" x2="7.01" y2="7"></line>
            </svg>
          {% elsif block.settings.point_1_icon == 'clock' %}
            <svg class="ai-highlight-points__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          {% endif %}
        </div>
        <p class="ai-highlight-points__text-{{ ai_gen_id }}">{{ block.settings.point_1_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.show_point_2 and block.settings.point_2_text != blank %}
