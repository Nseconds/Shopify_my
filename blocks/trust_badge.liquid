{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badge-{{ ai_gen_id }} {
    display: flex;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.margin_top }}px;
    padding-bottom: {{ block.settings.margin_bottom }}px;
  }

  .ai-trust-badge-container-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: var(--color-background, {{ block.settings.background_color }});
    border-radius: var(--style-border-radius-cards);
    box-shadow: 0 0 {{ block.settings.glow_size }}px {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }};
    margin: 0 auto;
  }

  .ai-trust-badge-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-trust-badge-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-trust-badge-text-{{ ai_gen_id }} {
    color: var(--color-foreground, {{ block.settings.text_color }});
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badge-{{ ai_gen_id }} {
      padding-top: {{ block.settings.margin_top_mobile }}px;
      padding-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }

    .ai-trust-badge-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-trust-badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-trust-badge-star-{{ ai_gen_id }} {
      width: {{ block.settings.star_size | times: 0.9 }}px;
      height: {{ block.settings.star_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-badge-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badge-container-{{ ai_gen_id }}">
    {% if block.settings.show_stars %}
      <div class="ai-trust-badge-stars-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          <svg class="ai-trust-badge-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        {% endfor %}
      </div>
    {% endif %}
    <span class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
  </div>
</div>

{% schema %}
{
  "name": "Trust badge",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Trusted by 10,000 buyers"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show stars",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top spacing (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom spacing (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Top spacing (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Bottom spacing (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFF4E6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#FF8C42"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star",
      "default": "#FFB366"
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "range",
      "id": "glow_size",
      "label": "Glow size",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Glow spread",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#FFD4A3"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    }
  ],
  "presets": [
    {
      "name": "Trust badge"
    }
  ]
}
{% endschema %}
