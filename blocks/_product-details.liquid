

{%- assign block_settings = block.settings -%}

<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
  {% capture children %}
    {% if product.handle == 'adjustable-pet-cat-dog-car-seat-belt-pet-seat-vehicle-dog-harness-lead-clip-safety-lever-traction-dog-collars-dogs-accessoires-pets-products' %}
      {% render 'pawsafe-custom-product-details', product: product, section: section, block: block %}
    {% else %}
      <div class="view-product-title">
        <a
          href="{{ product.selected_or_first_available_variant.url }}"
          class="link"
        >
          {{- product.title }}
        </a>
      </div>
      {% content_for 'blocks' %}
    {% endif %}
  {% endcapture %}

  {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
</div>

{% style %}
  #ProductInformation-{{ section.id }} {
    --product-details-border-radius: {{ block_settings.block_border_radius }}px;
  }
  
  {% if block_settings.override_child_border_radius %}
    /* Override border-radius CSS variable for all blocks - this overrides inline styles */
    #ProductInformation-{{ section.id }} [style*="--border-radius"],
    #ProductInformation-{{ section.id }} .border-style {
      --border-radius: {{ block_settings.block_border_radius }}px !important;
    }
    
    /* Override computed border-radius for elements using the variable */
    #ProductInformation-{{ section.id }} .border-style {
      border-radius: {{ block_settings.block_border_radius }}px !important;
    }
    
    /* Override border-radius for group blocks */
    #ProductInformation-{{ section.id }} .group-block {
      border-radius: {{ block_settings.block_border_radius }}px !important;
    }
    
    /* Override border-radius for accordion blocks */
    #ProductInformation-{{ section.id }} .accordion {
      border-radius: {{ block_settings.block_border_radius }}px !important;
    }
    
    /* Override border-radius for buttons - use global button shape var */
    #ProductInformation-{{ section.id }} .button,
    #ProductInformation-{{ section.id }} .button-secondary,
    #ProductInformation-{{ section.id }} a.button,
    #ProductInformation-{{ section.id }} a.button-secondary,
    #ProductInformation-{{ section.id }} [style*="border-radius"].button,
    #ProductInformation-{{ section.id }} [style*="border-radius"].button-secondary {
      border-radius: var(--style-border-radius-buttons-primary) !important;
    }
    
    /* Override border-radius for image blocks */
    #ProductInformation-{{ section.id }} image-block {
      --border-radius: {{ block_settings.block_border_radius }}px !important;
    }
    
    #ProductInformation-{{ section.id }} image-block img {
      border-radius: {{ block_settings.block_border_radius }}px !important;
    }
    
    /* Override border-radius for feature-pills container - override inline CSS variable */
    #ProductInformation-{{ section.id }} .feature-pills-container {
      --feature-pill-border-radius: {{ block_settings.block_border_radius }}px;
    }
    
    /* Override border-radius for feature-pill elements - override inline styles */
    #ProductInformation-{{ section.id }} .feature-pill {
      border-radius: {{ block_settings.block_border_radius }}px;
    }
    
    /* Override border-radius for buy-buttons - use global button shape var */
    #ProductInformation-{{ section.id }} .buy-buttons-block .button,
    #ProductInformation-{{ section.id }} .buy-buttons-block .button-secondary,
    #ProductInformation-{{ section.id }} .buy-buttons-block .add-to-cart-button,
    #ProductInformation-{{ section.id }} .buy-buttons-block .product-form-buttons button {
      border-radius: var(--style-border-radius-buttons-primary) !important;
    }

    /* Override border-radius for add-to-cart-with-price buttons - use global button shape var */
    #ProductInformation-{{ section.id }} .add-to-cart-with-price__button,
    #ProductInformation-{{ section.id }} [data-block-id] .add-to-cart-with-price__button {
      border-radius: var(--style-border-radius-buttons-primary) !important;
    }

    /* Override border-radius for buy-now-with-price buttons - use global button shape var */
    #ProductInformation-{{ section.id }} .buy-now-with-price__button,
    #ProductInformation-{{ section.id }} [data-block-id] .buy-now-with-price__button {
      border-radius: var(--style-border-radius-buttons-primary) !important;
    }
    
    /* Override border-radius for variant-picker options and swatches - use global shape var */
    #ProductInformation-{{ section.id }} .variant-picker__option,
    #ProductInformation-{{ section.id }} .variant-picker__swatch {
      border-radius: var(--style-border-radius-global) !important;
    }
  {% endif %}
{% endstyle %}

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 0;
    }
  }

  .view-product-title {
    display: none;
  }

  /* Container styles */
  .product-details {
    display: flex;
    align-self: start;
    justify-content: center;
    max-width: 100%;
  }

  .product-details > * {
    min-width: 0;
    max-width: 100%;
  }

  .product-details:has(.pastel-review-pill) > .group-block {
    gap: 10px;
  }

  .product-details:has(.pastel-review-pill) > .group-block > .text-block h1 {
    margin: 0;
    font-family: "Nunito", "Quicksand", -apple-system, sans-serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: 0.01em;
    text-wrap: balance;
  }

  .product-details:has(.pastel-review-pill) > .group-block > product-price .price {
    font-size: clamp(1.75rem, 3vw, 2.35rem);
    color: var(--color-primary);
  }

  .product-details:has(.pastel-review-pill) > .group-block > product-price .compare-at-price {
    font-size: 1.125rem;
  }

  @media screen and (min-width: 750px) {
    .product-details > .group-block {
      height: min-content;
    }

    .full-height--desktop {
      height: 100%;
      max-height: calc(100vh - var(--header-group-height, 0));
      min-height: fit-content;
    }

    .full-height--desktop .group-block {
      align-self: var(--details-position, 'flex-start');
    }
  }
{% endstylesheet %}

