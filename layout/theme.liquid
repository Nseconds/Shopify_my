<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% # theme-check-disable RemoteAsset %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >
    {% # theme-check-enable RemoteAsset %}

    {%- render 'meta-tags' -%}
    {%- render 'json-ld-organization' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}
    <style>
      .pawsafe-product-conversion .pawsafe-product-conversion__header,
      .pawsafe-product-conversion .pawsafe-product-conversion__trust,
      .pawsafe-product-conversion .pawsafe-product-conversion__grid {
        box-sizing: border-box;
        width: min(100%, 1100px);
        margin-right: auto;
        margin-left: auto;
        padding-right: 28px;
        padding-left: 28px;
      }

      .pawsafe-product-conversion .pawsafe-product-conversion__header {
        max-width: none;
      }

      .pawsafe-product-conversion .pawsafe-product-conversion__header h2,
      .pawsafe-product-conversion .pawsafe-product-conversion__header p {
        max-width: 760px;
      }

      .pawsafe-product-conversion .pawsafe-product-conversion__faq,
      .pawsafe-product-conversion .pawsafe-product-conversion__reviews {
        box-sizing: border-box;
        width: min(100%, 980px);
        margin-right: auto;
        margin-left: auto;
      }

      .pawsafe-product-conversion .pawsafe-product-conversion__faq {
        padding: 18px 28px 8px;
      }

      .pawsafe-product-conversion .pawsafe-product-conversion__reviews {
        margin-top: 34px;
      }

      @media screen and (max-width: 749px) {
        .pawsafe-product-conversion .pawsafe-product-conversion__header,
        .pawsafe-product-conversion .pawsafe-product-conversion__trust,
        .pawsafe-product-conversion .pawsafe-product-conversion__grid {
          padding-right: 16px;
          padding-left: 16px;
        }

        .pawsafe-product-conversion .pawsafe-product-conversion__faq {
          padding-right: 16px;
          padding-left: 16px;
        }
      }
    </style>

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% section 'custom-announcement-bar' %}
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    {% section 'pawsafe-header' %}
    {% render 'pawsafe-discount-popup' %}

    {% if request.page_type == 'index' %}
      <main
        id="MainContent"
        class="content-for-layout"
        role="main"
        data-page-transition-enabled="false"
        data-product-transition="false"
        data-template="index"
      >
        {{ content_for_layout }}
      </main>
    {% else %}
      <script
        src="{{ 'critical.js' | asset_url }}"
        type="module"
        async
        blocking="render"
      ></script>

      {% render 'cart-drawer-mini-2' %}
      {% render 'forge-pv-beacon' %}

      <main
        id="MainContent"
        class="content-for-layout"
        role="main"
        data-page-transition-enabled="{{ settings.page_transition_enabled }}"
        data-product-transition="{{ settings.transition_to_main_product }}"
        data-template="{{ template.name }}"
      >
        {{ content_for_layout }}
      </main>

      {% sections 'footer-group' %}

      {% render 'search-modal' %}

      {% if settings.quick_add or settings.mobile_quick_add %}
        {% render 'quick-add-modal' %}
      {% endif %}
    {% endif %}
  </body>
</html>
