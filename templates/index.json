    "editorial-accordion_olxrsq": {
      "type": "editorial-accordion",
      "blocks": {
        "item_0": {
          "type": "accordion_item",
          "settings": {
            "heading": "<p>Why is a vehicle restraint necessary?</p>",
            "content": "<p>Unrestrained pets can become projectiles in a collision. Our harnesses keep them secure in their seat, reducing injury risk to both pet and passengers during sudden stops.</p>"
          }
        },
        "item_1": {
          "type": "accordion_item",
          "settings": {
            "heading": "<p>How does it fit my car?</p>",
            "content": "<p>The universal clip design fits standard seatbelt receptacles in 99% of vehicles with zero modifications required for installation.</p>"
          }
        },
        "item_2": {
          "type": "accordion_item",
          "settings": {
            "heading": "<p>Is it weight-rated?</p>",
            "content": "<p>Yes. Our systems are load-tested to withstand over 200 lbs of impact force, suitable for pets ranging from 5 to 85 lbs.</p>"
          }
        },
        "item_3": {
          "type": "accordion_item",
          "settings": {
            "heading": "<p>Zinc Alloy vs. Plastic components?</p>",
            "content": "<p>We use heavy-duty zinc alloy and reinforced nylon because plastic buckles often shatter under the high-G forces of a sudden stop or impact.</p>"
          }
        },
        "item_4": {
          "type": "accordion_item",
          "settings": {
            "heading": "<p>Fit &amp; Sizing Guide</p>",
            "content": "<p>Adjustable straps ensure a snug fit for any breed. Simply adjust the lead length to give your pet comfortable movement without excessive slack.</p>"
          }
        }
      },
      "block_order": [
        "item_0",
        "item_1",
