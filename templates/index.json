        },
        "item_1": {
          "type": "review",
          "settings": {
            "stars": 5,
            "title": "<p>Peace of Mind</p>",
            "quote": "<p>The quality of the zinc hardware is obvious. This is a must-have for long road trips. It is noticeably better than cheap store brands.</p>",
