        },
        "item_3": {
          "type": "review",
          "settings": {
            "stars": 5,
            "title": "<p>Easy Install</p>",
            "quote": "<p>Took less than a minute to set up. Now I don't worry about my cat jumping in my lap while I am driving on the highway.</p>",
            "author": "Elena R.",
