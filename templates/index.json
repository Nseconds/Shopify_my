          "type": "review",
          "settings": {
            "stars": 5,
            "title": "<p>Perfect Fit</p>",
            "quote": "<p>Finally, a seatbelt that feels solid. My lab doesn't shift during turns anymore and I can drive with complete peace of mind.</p>",
