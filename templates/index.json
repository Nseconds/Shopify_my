          }
        },
        "item_2": {
          "type": "review",
          "settings": {
            "stars": 5,
            "title": "<p>Vet Approved</p>",
            "quote": "<p>As a veterinarian, I only trust load-tested restraints. This is the gold standard for my dogs and I recommend it to all my clients.</p>",
            "author": "Dr. James K.",
            "product_info": ""
