        },
        "item_4": {
          "type": "review",
          "settings": {
            "stars": 5,
            "title": "<p>Heavy Duty</p>",
            "quote": "<p>Stronger than anything I found at the pet store. The nylon webbing is incredibly thick and the metal clip is very secure.</p>",
