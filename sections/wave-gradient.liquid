
{%- liquid
    assign s = section.settings
  -%}

  {%- if settings.style_mode == 'flat' -%}
    {%- assign grad_1 = s.color_scheme.settings.background -%}
    {%- assign grad_2 = s.color_scheme.settings.background -%}
    {%- assign grad_3 = s.color_scheme.settings.background -%}
    {%- assign grad_text = s.color_scheme.settings.foreground -%}
  {%- elsif s.use_custom_colors -%}
    {%- assign grad_1 = s.bg_color_1 -%}
    {%- assign grad_2 = s.bg_color_2 -%}
    {%- assign grad_3 = s.bg_color_3 -%}
    {%- assign grad_text = s.text_color -%}
  {%- else -%}
    {%- assign grad_1 = s.color_scheme.settings.gradient_1 -%}
    {%- assign grad_2 = s.color_scheme.settings.gradient_2 -%}
    {%- assign grad_3 = s.color_scheme.settings.gradient_3 -%}
    {%- assign grad_text = s.color_scheme.settings.gradient_text_color -%}
  {%- endif -%}

  <section
    id="wave-hero-{{ section.id }}"
    class="wave-hero"
    style="
      --bg1: {{ grad_1 }};
      --bg2: {{ grad_2 }};
      --bg3: {{ grad_3 }};
      --wave1: {{ grad_1 }};
      --wave2: {{ grad_3 }};
      --text: {{ grad_text }};
      --btn_bg: {{ s.button_bg }};
      --btn_text: {{ s.button_text }};
      --card_bg: {{ s.card_bg }};
      --card_border: {{ s.card_border }};
    "
  >
    <div class="wave-hero__wave" aria-hidden="true">
      <!-- SVG wave with gradient you can control -->
      <svg viewBox="0 0 1440 180" preserveAspectRatio="none" role="presentation">
        <defs>
          <linearGradient id="waveGrad-{{ section.id }}" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%" stop-color="var(--wave1)"></stop>
            <stop offset="100%" stop-color="var(--wave2)"></stop>
          </linearGradient>
        </defs>
  
        <!-- Desktop wave layers -->
        <path
          class="wave-layer wave-desktop"
          d="M0,64 C120,96 240,32 360,48 C480,64 600,128 720,112 C840,96 960,32 1080,40 C1200,48 1320,96 1440,72 L1440,0 L0,0 Z"
          fill="url(#waveGrad-{{ section.id }})"
          opacity="0.9"
        ></path>
  
        <path
          class="wave-layer wave-desktop"
          d="M0,84 C140,120 260,64 380,72 C520,80 620,132 760,120 C900,108 1000,48 1120,56 C1260,64 1340,112 1440,92 L1440,0 L0,0 Z"
          fill="url(#waveGrad-{{ section.id }})"
          opacity="0.55"
        ></path>
  
        <!-- Mobile wave (simple + smooth like pink example) -->
        <path
          class="wave-layer wave-mobile"
          d="M0,92 C360,28 720,136 1080,84 C1260,60 1380,84 1440,76 L1440,0 L0,0 Z"
          fill="url(#waveGrad-{{ section.id }})"
          opacity="0.9"
        ></path>
  
        <path
          class="wave-layer wave-mobile"
          d="M0,120 C360,60 720,160 1080,112 C1260,88 1380,108 1440,100 L1440,0 L0,0 Z"
          fill="url(#waveGrad-{{ section.id }})"
          opacity="0.55"
        ></path>
      </svg>
    </div>
  
    <div class="wave-hero__inner page-width">
      {% if s.heading != blank %}
        <h2 class="wave-hero__heading">{{ s.heading }}</h2>
      {% endif %}
  
      {% if s.subheading != blank %}
        <div class="wave-hero__subheading rte">{{ s.subheading }}</div>
      {% endif %}
  
      {% if s.button_label != blank and s.button_link != blank %}
        <a class="wave-hero__button" href="{{ s.button_link }}">
          {{ s.button_label }}
        </a>
      {% endif %}
  
      {% if section.blocks.size > 0 %}
        <div class="wave-hero__cards">
          {% for block in section.blocks %}
            <div class="wave-hero__card" {{ block.shopify_attributes }}>
              {% if block.settings.text != blank %}
                <p class="wave-hero__card-text">{{ block.settings.text }}</p>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </section>
  
  {% style %}
    #wave-hero-{{ section.id }}.wave-hero{
      position: relative;
      overflow: hidden;
      color: var(--text);
      padding: clamp(48px, 6vw, 88px) 0 clamp(56px, 6vw, 90px);
      background: linear-gradient(180deg, var(--bg1), var(--bg2), var(--bg3));
    }
  
    #wave-hero-{{ section.id }} .wave-hero__wave{
      position:absolute;
      top:0;
      left:0;
      right:0;
      height:140px;
      transform: translateY(-1px);
      pointer-events: none;
    }
  
    #wave-hero-{{ section.id }} .wave-hero__wave svg{
      width:100%;
      height:100%;
      display:block;
    }
  
    #wave-hero-{{ section.id }} .wave-hero__inner{
      position:relative;
      text-align:center;
    }
  
    #wave-hero-{{ section.id }} .wave-hero__heading{
      margin: 0 auto 10px;
      max-width: 900px;
      font-weight: 800;
      letter-spacing: -0.02em;
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1.1;
    }
  
    #wave-hero-{{ section.id }} .wave-hero__subheading{
      margin: 0 auto 22px;
      max-width: 760px;
      opacity: 0.95;
      font-size: clamp(14px, 1.3vw, 18px);
    }
  
    #wave-hero-{{ section.id }} .wave-hero__button{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding: 14px 22px;
      min-width: 220px;
      border-radius: var(--style-border-radius-buttons-primary);
      background: var(--btn_bg);
      color: var(--btn_text);
      text-decoration:none;
      font-weight: 700;
      box-shadow: 0 10px 24px rgba(0,0,0,0.18);
      transition: transform .15s ease, box-shadow .15s ease;
      margin-bottom: 18px;
    }
  
    #wave-hero-{{ section.id }} .wave-hero__button:hover{
      transform: translateY(-1px);
      box-shadow: 0 14px 28px rgba(0,0,0,0.22);
    }
  
    /* FORCE spacing between cards + add left/right padding on desktop */
    #wave-hero-{{ section.id }} .wave-hero__cards{
      margin-top: 34px !important;
      margin-bottom: 34px !important;
      padding: 0 24px 12px !important;      /* ✅ left/right spacing + bottom spacing */
      display: grid !important;
      grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
      gap: 18px !important;
      max-width: 1200px;                    /* ✅ prevents edge-to-edge stretching */
      margin-left: auto !important;
      margin-right: auto !important;
    }
  
    #wave-hero-{{ section.id }} .wave-hero__card{
      background: var(--card_bg);
      border: 1px solid var(--card_border);
      border-radius: var(--style-border-radius-cards);
      padding: 18px 16px;
      backdrop-filter: blur(2px);
      margin: 0 !important;
    }
  
    #wave-hero-{{ section.id }} .wave-hero__card-text{
      margin:0;
      font-size: 14px;
      line-height: 1.35;
      font-weight: 600;
    }
  
    /* Hide mobile wave by default */
    #wave-hero-{{ section.id }} .wave-mobile { display: none; }
  
    @media (max-width: 990px){
      #wave-hero-{{ section.id }} .wave-hero__cards{
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
        padding-left: 18px !important;
        padding-right: 18px !important;
      }
    }
  
    @media (max-width: 749px){
      /* Mobile wave: prevent cutoff */
      #wave-hero-{{ section.id }} .wave-desktop { display: none; }
      #wave-hero-{{ section.id }} .wave-mobile { display: block; }
  
      #wave-hero-{{ section.id }} .wave-hero__wave{
        height: 220px;  /* ✅ taller */
        top: -28px;     /* ✅ lift wave up so it doesn’t get chopped */
      }
  
      #wave-hero-{{ section.id }} .wave-hero__wave svg{
    width: 100%;
    left: 0;
    position: relative;
  }
  /* Ensure no tiny subpixel gap shows at edges */
  #wave-hero-{{ section.id }} .wave-hero__wave{
    left: -1px;
    right: -1px;
  }
  
      /* Mobile cards spacing + inset like pink example */
      #wave-hero-{{ section.id }} .wave-hero__cards{
        grid-template-columns: 1fr !important;
        gap: 16px !important;
        margin-bottom: 38px !important;
        padding-left: 16px !important;
        padding-right: 16px !important;
        max-width: 560px;
      }
    }
  {% endstyle %}
  
  {% schema %}
  {
    "name": "Wave Hero (Gradient)",
    "settings": [
      { "type": "text", "id": "heading", "label": "Heading", "default": "Transform Your Skincare Routine" },
      { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>Experience the power of facial massage with the Facecube Face Massager - your path to glowing, relaxed skin!</p>" },
  
      { "type": "text", "id": "button_label", "label": "Button label", "default": "Add to Bag" },
      { "type": "url", "id": "button_link", "label": "Button link" },
  
      { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

      { "type": "header", "content": "Colors" },
      { "type": "checkbox", "id": "use_custom_colors", "label": "Override theme gradient colors", "info": "When off, uses the theme's global gradient colors", "default": false },

      { "type": "header", "content": "Background gradient" },
      { "type": "color", "id": "bg_color_1", "label": "Gradient color 1 (top)", "default": "#0EA5E9", "visible_if": "{{ section.settings.use_custom_colors }}" },
      { "type": "color", "id": "bg_color_2", "label": "Gradient color 2 (middle)", "default": "#2563EB", "visible_if": "{{ section.settings.use_custom_colors }}" },
      { "type": "color", "id": "bg_color_3", "label": "Gradient color 3 (bottom)", "default": "#1E3A8A", "visible_if": "{{ section.settings.use_custom_colors }}" },

      { "type": "header", "content": "Wave colors" },
      { "type": "color", "id": "wave_color_1", "label": "Wave gradient color 1", "default": "#38BDF8", "visible_if": "{{ section.settings.use_custom_colors }}" },
      { "type": "color", "id": "wave_color_2", "label": "Wave gradient color 2", "default": "#1D4ED8", "visible_if": "{{ section.settings.use_custom_colors }}" },

      { "type": "header", "content": "Text & UI" },
      { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF", "visible_if": "{{ section.settings.use_custom_colors }}" },
      { "type": "color", "id": "button_bg", "label": "Button background", "default": "#0B1020" ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
      { "type": "color", "id": "button_text", "label": "Button text", "default": "#FFFFFF" ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
  
      { "type": "color", "id": "card_bg", "label": "Card background", "default": "rgba(255,255,255,0.12)" ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
      { "type": "color", "id": "card_border", "label": "Card border", "default": "rgba(255,255,255,0.35)" ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    }
    ],
    "blocks": [
      {
        "type": "feature",
        "name": "Feature card",
        "settings": [
          { "type": "text", "id": "text", "label": "Text", "default": "Lightweight and Discreet" }
        ]
      }
    ],
    "max_blocks": 4,
    "presets": [
      {
        "name": "Wave Hero (Gradient)",
        "blocks": [
          { "type": "feature" },
          { "type": "feature", "settings": { "text": "Multiple Intensity Levels" } },
          { "type": "feature", "settings": { "text": "Waterproof & Easy to Clean" } },
          { "type": "feature", "settings": { "text": "Ergonomic Cube Design" } }
        ]
      }
    ]
  }
  {% endschema %}
  