{% comment %}
  Full-width trust bar with top/bottom rules and inset vertical dividers between columns (desktop).
{% endcomment %}

{%- liquid
  assign icon_shield = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#2da15f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 11 11 13 15 9"/></svg>'
  assign icon_delivery = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#2da15f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>'
  assign icon_returns = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#2da15f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>'
  assign icon_star = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#2da15f" stroke="#2da15f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  assign default_icons = icon_shield | append: '||' | append: icon_delivery | append: '||' | append: icon_returns | append: '||' | append: icon_star
  assign default_icons_arr = default_icons | split: '||'

  if section.settings.border_color != blank
    assign rule = section.settings.border_color
  else
    assign rule = '#333333'
  endif

  if section.settings.divider_vertical_inset == blank
    assign divider_inset = 6
  else
    assign divider_inset = section.settings.divider_vertical_inset
  endif
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --etb-rule-color: {{ rule }};
    --etb-divider-inset: {{ divider_inset }}px;
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="editorial-trust-bar section spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="editorial-trust-bar__strip">
    <div class="editorial-trust-bar__inner">
      <div class="editorial-trust-bar__grid">
        {% for block in section.blocks %}
          {% if block.type == 'trust_item' %}
            {%- assign fallback_icon = default_icons_arr[forloop.index0] -%}
            <div class="etb-item" {{ block.shopify_attributes }}>
              <div class="etb-item__icon">
                {%- if block.settings.icon != blank -%}
                  {{ block.settings.icon }}
                {%- elsif fallback_icon != blank -%}
                  {{ fallback_icon }}
                {%- endif -%}
              </div>
              <div class="etb-item__text">
                {% if block.settings.heading != blank %}
                  <p class="etb-item__heading">{{ block.settings.heading }}</p>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="etb-item__description">{{ block.settings.description }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% else %}
          <div class="etb-item">
            <div class="etb-item__icon">{{ icon_shield }}</div>
            <div class="etb-item__text">
              <p class="etb-item__heading">Crash tested</p>
            </div>
          </div>
          <div class="etb-item">
            <div class="etb-item__icon">{{ icon_delivery }}</div>
            <div class="etb-item__text">
              <p class="etb-item__heading">Free shipping</p>
            </div>
          </div>
          <div class="etb-item">
            <div class="etb-item__icon">{{ icon_returns }}</div>
            <div class="etb-item__text">
              <p class="etb-item__heading">30-day returns</p>
            </div>
          </div>
          <div class="etb-item">
            <div class="etb-item__icon">{{ icon_star }}</div>
            <div class="etb-item__text">
              <p class="etb-item__heading">4.92 rating</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .editorial-trust-bar {
    width: 100%;
    background: #222222 !important;
  }

  /* Full viewport width bar with horizontal rules */
  .editorial-trust-bar__strip {
    width: 100vw;
    max-width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    box-sizing: border-box;
    border-top: 1px solid var(--etb-rule-color, #333333);
    border-bottom: 1px solid var(--etb-rule-color, #333333);
    background: #222222 !important;
  }

  .editorial-trust-bar__inner {
    margin: 0 auto;
    padding: 16px var(--page-margin, 24px);
    max-width: 1200px;
  }

  .editorial-trust-bar__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    align-items: center;
  }

  .etb-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 8px 16px;
    box-sizing: border-box;
    text-align: center;
  }

  /* Inset vertical divider between columns on desktop */
  @media screen and (min-width: 750px) {
    .etb-item:not(:nth-child(4n + 1))::before {
      content: '';
      position: absolute;
      left: 0;
      top: var(--etb-divider-inset, 6px);
      bottom: var(--etb-divider-inset, 6px);
      width: 1px;
      background: var(--etb-rule-color, #333333) !important;
    }
  }

  .etb-item__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: #2da15f !important;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .etb-item__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .etb-item__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .etb-item__heading {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #ffffff !important;
    line-height: 1.2;
    text-transform: none;
  }

  .etb-item__description {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .editorial-trust-bar__inner {
      padding: 12px 16px;
    }

    .editorial-trust-bar__grid {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 12px;
    }

    .etb-item {
      padding: 6px 8px;
    }

    /* Vertical divider between left and right column on mobile */
    .etb-item:nth-child(2n)::before {
      content: '';
      position: absolute;
      left: 0;
      top: var(--etb-divider-inset, 6px);
      bottom: var(--etb-divider-inset, 6px);
      width: 1px;
      background: var(--etb-rule-color, #333333) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial Trust Bar",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "info": "Background and text use the scheme; borders use the color below."
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Rule & divider color",
      "default": "#d4d4d4"
    },
    {
      "type": "range",
      "id": "divider_vertical_inset",
      "label": "Divider inset (desktop)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 14,
      "info": "Shortens vertical column lines so they do not touch the top and bottom borders."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "limit": 6,
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Fast Delivery"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Free delivery worldwide"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Trust Bar",
      "settings": {
        "border_color": "#d4d4d4",
        "divider_vertical_inset": 14
      },
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "heading": "Fast Delivery Worldwide",
            "description": "Free delivery from €125"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "heading": "Buy Now Pay Later",
            "description": "Pay within 30 days at home"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "heading": "14 Day Returns",
            "description": "Simple, straightforward returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}
