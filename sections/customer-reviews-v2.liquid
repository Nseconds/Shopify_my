{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}
{% assign ai_gen_id_js = section.id | replace: '_', '' | replace: '-', '' | downcase %}
{%- liquid
  if section.settings.use_custom_colors
    assign sc_bg        = section.settings.section_background
    assign sc_accent    = section.settings.star_color
    assign sc_avatar_bg = section.settings.avatar_placeholder_bg
    assign sc_avatar    = section.settings.avatar_placeholder_color
    assign sc_card      = section.settings.card_background
    assign sc_text      = 'var(--color-foreground)'
  elsif settings.style_mode == 'gradient'
    assign sc_bg        = section.settings.color_scheme.settings.background
    assign sc_card      = 'var(--color-card-gradient)'
    assign sc_accent    = 'var(--color-gradient-1)'
    assign sc_avatar_bg = 'var(--color-gradient-1)'
    assign sc_avatar    = 'var(--color-gradient-text)'
    assign sc_text      = 'var(--color-gradient-text)'
  else
    assign sc_bg        = section.settings.color_scheme.settings.background
    assign sc_accent    = section.settings.color_scheme.settings.primary
    assign sc_avatar_bg = section.settings.color_scheme.settings.primary
    assign sc_avatar    = section.settings.color_scheme.settings.background
    assign sc_card      = 'var(--color-card-background)'
    assign sc_text      = 'var(--color-foreground)'
  endif
-%}
{% if settings.style_mode == 'gradient' %}
  {% style %}
    /* Force all text inside gradient cards to gradient-text color */
    #shopify-section-{{ section.id }} .ai-reviews-card-{{ ai_gen_id }},
    #shopify-section-{{ section.id }} .ai-reviews-card-{{ ai_gen_id }} * {
      color: var(--color-gradient-text) !important;
    }
  {% endstyle %}
{% endif %}
{% style %}
  .ai-reviews-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
    background: {{ sc_bg }};
    overflow: hidden;
  }

  .ai-reviews-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ section.settings.header_spacing }}px;
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ section.settings.title_size }}px;
    color: var(--color-foreground-heading, {{ section.settings.title_color }});
    margin: 0 0 12px;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .ai-reviews-subtitle-{{ ai_gen_id }} {
    font-size: {{ section.settings.subtitle_size }}px;
    color: var(--color-foreground, {{ section.settings.subtitle_color }});
    margin: 0;
    font-weight: 300;
    opacity: 0.8;
  }

  .ai-reviews-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin: 0 -20px;
    padding: 0 20px;
  }

  .ai-reviews-carousel-{{ ai_gen_id }} {
    display: flex;
    gap: var(--style-gap-cards);
    padding: 8px 0 24px;
    width: max-content;
    will-change: transform;
    user-select: none;
    cursor: grab;
  }

  .ai-reviews-card-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ section.settings.card_width }}px;
    background: {{ sc_card }};
    color: {{ sc_text }};
    border-radius: var(--style-border-radius-cards);
    padding: {{ section.settings.card_padding }}px;
    box-shadow: var(--style-shadow-card);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-reviews-card-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .ai-reviews-avatar-{{ ai_gen_id }} {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    background: {{ sc_avatar_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-reviews-avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-reviews-avatar-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.avatar_size | divided_by: 2 }}px;
    color: {{ sc_avatar }};
    font-weight: 500;
  }

  .ai-reviews-customer-info-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-reviews-customer-name-{{ ai_gen_id }} {
    font-size: {{ section.settings.name_size }}px;
    color: var(--color-foreground-heading, {{ section.settings.name_color }});
    margin: 0 0 4px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .ai-reviews-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-reviews-star-{{ ai_gen_id }} {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    color: {{ sc_accent }};
  }

  .ai-reviews-testimonial-{{ ai_gen_id }} {
    font-size: {{ section.settings.testimonial_size }}px;
    line-height: 1.6;
    color: var(--color-foreground, {{ section.settings.testimonial_color }});
    margin: 0;
    font-weight: 300;
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-card-{{ ai_gen_id }} {
      width: {{ section.settings.card_width_mobile }}px;
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: {{ section.settings.title_size | times: 0.8 }}px;
    }

    .ai-reviews-subtitle-{{ ai_gen_id }} {
      font-size: {{ section.settings.subtitle_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<premium-reviews-{{ ai_gen_id }} class="ai-reviews-{{ ai_gen_id }}">
  <div class="ai-reviews-container-{{ ai_gen_id }}">
    {% if section.settings.section_title != blank or section.settings.section_subtitle != blank %}
      <div class="ai-reviews-header-{{ ai_gen_id }}">
        {% if section.settings.section_title != blank %}
          <h2 class="ai-reviews-title-{{ ai_gen_id }}">{{ section.settings.section_title }}</h2>
        {% endif %}
        {% if section.settings.section_subtitle != blank %}
          <p class="ai-reviews-subtitle-{{ ai_gen_id }}">{{ section.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-reviews-carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-reviews-carousel-{{ ai_gen_id }}" data-carousel>
        {% for i in (1..6) %}
          {% liquid
            assign review_enabled_key = 'review_' | append: i | append: '_enabled'
            assign customer_name_key = 'review_' | append: i | append: '_customer_name'
            assign testimonial_key = 'review_' | append: i | append: '_testimonial'
            assign avatar_key = 'review_' | append: i | append: '_avatar'

            assign review_enabled = section.settings[review_enabled_key]
            assign customer_name = section.settings[customer_name_key]
            assign testimonial = section.settings[testimonial_key]
            assign avatar = section.settings[avatar_key]
          %}

          {% if review_enabled %}
            <div class="ai-reviews-card-{{ ai_gen_id }}" data-forge-slot-id="{{ i }}"{% if avatar == blank %} data-forge-slot-blank="true"{% endif %}>
              <div class="ai-reviews-card-header-{{ ai_gen_id }}">
                <div class="ai-reviews-avatar-{{ ai_gen_id }}">
                  {% if avatar != blank %}
                    <img
                      src="{{ avatar | image_url: width: 100 }}"
                      alt="{{ customer_name | escape }}"
                      loading="lazy"
                      width="100"
                      height="100"
                    >
                  {% else %}
                    <div class="ai-reviews-avatar-placeholder-{{ ai_gen_id }}">
                      {% if customer_name != blank %}
                        {{ customer_name | slice: 0 | upcase }}
                      {% else %}
                        ?
                      {% endif %}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-reviews-customer-info-{{ ai_gen_id }}">
                  {% if customer_name != blank %}
                    <h3 class="ai-reviews-customer-name-{{ ai_gen_id }}">{{ customer_name }}</h3>
                  {% endif %}
                  <div class="ai-reviews-stars-{{ ai_gen_id }}">
                    {% for star in (1..5) %}
                      <svg class="ai-reviews-star-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                      </svg>
                    {% endfor %}
                  </div>
                </div>
              </div>

              {% if testimonial != blank %}
                <p class="ai-reviews-testimonial-{{ ai_gen_id }}">{{ testimonial }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</premium-reviews-{{ ai_gen_id }}>

<script>
  (function() {
    class PremiumReviews{{ ai_gen_id_js }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.position = 0;
        this.speed = 50 / {{ section.settings.scroll_speed }};
        this.isPaused = false;
        this.isDragging = false;
        this.rafId = null;
        this.dragStartX = 0;
        this.dragStartPos = 0;
        this._cleanupDrag = null;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-carousel]');
        if (!this.track) return;

        {% if section.settings.enable_auto_scroll %}
          this.duplicateForInfiniteScroll();
        {% endif %}

        this.setupDrag();

        {% if section.settings.enable_auto_scroll %}
          this.startAnimation();
          this.setupPauseOnHover();
        {% endif %}
      }

      duplicateForInfiniteScroll() {
        const cards = Array.from(this.track.children);
        if (cards.length === 0) return;
        cards.forEach((card) => {
          this.track.appendChild(card.cloneNode(true));
        });
      }

      startAnimation() {
        const animate = () => {
          if (!this.isPaused && !this.isDragging) {
            this.position += this.speed;
            const halfWidth = this.track.scrollWidth / 2;
            if (halfWidth > 0 && this.position >= halfWidth) {
              this.position -= halfWidth;
            }
            this.track.style.transform = `translateX(-${this.position}px)`;
          }
          this.rafId = requestAnimationFrame(animate);
        };
        this.rafId = requestAnimationFrame(animate);
      }

      setupDrag() {
        const onMouseDown = (e) => {
          this.isDragging = true;
          this.isPaused = true;
          this.dragStartX = e.clientX;
          this.dragStartPos = this.position;
          this.track.style.cursor = 'grabbing';
        };

        const onMouseMove = (e) => {
          if (!this.isDragging) return;
          const dx = e.clientX - this.dragStartX;
          const halfWidth = this.track.scrollWidth / 2;
          if (halfWidth > 0) {
            this.position = ((this.dragStartPos - dx) % halfWidth + halfWidth) % halfWidth;
          }
          this.track.style.transform = `translateX(-${this.position}px)`;
        };

        const onMouseUp = () => {
          if (!this.isDragging) return;
          this.isDragging = false;
          this.track.style.cursor = 'grab';
          setTimeout(() => { this.isPaused = false; }, 800);
        };

        const onTouchStart = (e) => {
          this.isDragging = true;
          this.isPaused = true;
          this.dragStartX = e.touches[0].clientX;
          this.dragStartPos = this.position;
        };

        const onTouchMove = (e) => {
          if (!this.isDragging) return;
          const dx = e.touches[0].clientX - this.dragStartX;
          const halfWidth = this.track.scrollWidth / 2;
          if (halfWidth > 0) {
            this.position = ((this.dragStartPos - dx) % halfWidth + halfWidth) % halfWidth;
          }
          this.track.style.transform = `translateX(-${this.position}px)`;
        };

        const onTouchEnd = () => {
          this.isDragging = false;
          setTimeout(() => { this.isPaused = false; }, 800);
        };

        this.track.addEventListener('mousedown', onMouseDown);
        document.addEventListener('mousemove', onMouseMove);
        document.addEventListener('mouseup', onMouseUp);
        this.track.addEventListener('touchstart', onTouchStart, { passive: true });
        document.addEventListener('touchmove', onTouchMove, { passive: true });
        document.addEventListener('touchend', onTouchEnd);

        this._cleanupDrag = () => {
          document.removeEventListener('mousemove', onMouseMove);
          document.removeEventListener('mouseup', onMouseUp);
          document.removeEventListener('touchmove', onTouchMove);
          document.removeEventListener('touchend', onTouchEnd);
        };
      }

      setupPauseOnHover() {
        this.addEventListener('mouseenter', () => { this.isPaused = true; });
        this.addEventListener('mouseleave', () => {
          if (!this.isDragging) this.isPaused = false;
        });
      }

      disconnectedCallback() {
        if (this.rafId) cancelAnimationFrame(this.rafId);
        if (this._cleanupDrag) this._cleanupDrag();
      }
    }

    customElements.define('premium-reviews-{{ ai_gen_id }}', PremiumReviews{{ ai_gen_id_js }});
  })();
</script>

