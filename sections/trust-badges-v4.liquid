{%- liquid
  if section.settings.use_custom_colors
    assign sc_bg     = section.settings.background_color
    assign sc_text   = section.settings.text_color
    assign sc_title  = section.settings.title_color
    assign sc_accent = section.settings.icon_color
  elsif settings.style_mode == 'gradient'
    assign sc_bg     = 'var(--color-background)'
    assign sc_text   = 'var(--color-foreground)'
    assign sc_title  = 'var(--color-foreground)'
    assign sc_accent = 'var(--color-gradient-1)'
  else
    assign sc_bg     = section.settings.color_scheme.settings.background
    assign sc_text   = section.settings.color_scheme.settings.foreground
    assign sc_title  = section.settings.color_scheme.settings.foreground
    assign sc_accent = section.settings.color_scheme.settings.primary
  endif
-%}
{% style %}
  .trust-badges-v4-{{ section.id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
    background: {{ sc_bg }};
    border-radius: var(--style-border-radius-cards);
  }

  .trust-badges-v4-container-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }

  .trust-badges-v4-badge-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ section.settings.icon_text_gap }}px;
  }

  .trust-badges-v4-badge-icon-{{ section.id }} {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trust-badges-v4-badge-icon-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .trust-badges-v4-badge-icon-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    color: {{ sc_accent }};
  }

  {% if settings.style_mode == 'gradient' and section.settings.use_custom_colors == false %}
  .trust-badges-v4-badge-icon-{{ section.id }} svg {
    stroke: url(#tbv4-icon-grad-{{ section.id | replace: '_', '' | downcase }});
  }
  {% endif %}

  .trust-badges-v4-badge-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .trust-badges-v4-badge-title-{{ section.id }} {
    font-size: {{ section.settings.title_size }}px;
    font-weight: 600;
    color: {{ sc_title }};
    margin: 0;
  }

  .trust-badges-v4-badge-text-{{ section.id }} {
    font-size: {{ section.settings.text_size }}px;
    color: {{ sc_text }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .trust-badges-v4-container-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }

    .trust-badges-v4-badge-icon-{{ section.id }} {
      width: {{ section.settings.icon_size | times: 0.8 }}px;
      height: {{ section.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

{% if settings.style_mode == 'gradient' and section.settings.use_custom_colors == false %}
  {%- assign tbv4_g1 = section.settings.color_scheme.settings.gradient_1 -%}
  {%- assign tbv4_g2 = section.settings.color_scheme.settings.gradient_2 -%}
  {%- assign tbv4_g3 = section.settings.color_scheme.settings.gradient_3 -%}
  <svg width="0" height="0" style="position:absolute;overflow:hidden" aria-hidden="true">
    <defs>
      <linearGradient id="tbv4-icon-grad-{{ section.id | replace: '_', '' | downcase }}" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="{{ tbv4_g1 }}"/>
        <stop offset="50%" stop-color="{{ tbv4_g2 }}"/>
        <stop offset="100%" stop-color="{{ tbv4_g3 }}"/>
      </linearGradient>
    </defs>
  </svg>
{% endif %}

<trust-badges-v4-{{ section.id | downcase | replace: '_', '-' }} class="trust-badges-v4-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="trust-badges-v4-container-{{ section.id }}">
    {% for i in (1..6) %}
      {% liquid
        assign enabled_key = 'badge_' | append: i | append: '_enabled'
        assign icon_key = 'badge_' | append: i | append: '_icon'
        assign custom_icon_key = 'badge_' | append: i | append: '_custom_icon'
        assign title_key = 'badge_' | append: i | append: '_title'
        assign text_key = 'badge_' | append: i | append: '_text'

        assign enabled = section.settings[enabled_key]
        assign icon = section.settings[icon_key]
        assign custom_icon = section.settings[custom_icon_key]
        assign title = section.settings[title_key]
        assign text = section.settings[text_key]
      %}

      {% if enabled %}
        <div class="trust-badges-v4-badge-{{ section.id }}">
          <div class="trust-badges-v4-badge-icon-{{ section.id }}">
            {% if custom_icon != blank %}
              <img src="{{ custom_icon | image_url: width: 200 }}" alt="{{ title | escape }}" loading="lazy" width="200" height="200">
            {% else %}
              {% case icon %}
                {% when 'leaf' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                    <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
                  </svg>
                {% when 'shield' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    <path d="m9 12 2 2 4-4"></path>
                  </svg>
                {% when 'droplet' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
                  </svg>
                {% when 'heart' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0-7.78 0z"></path>
                  </svg>
                {% when 'star' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {% when 'check' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
              {% endcase %}
            {% endif %}
          </div>
          <div class="trust-badges-v4-badge-content-{{ section.id }}">
            {% if title != blank %}
              <h3 class="trust-badges-v4-badge-title-{{ section.id }}">{{ title }}</h3>
            {% endif %}
            {% if text != blank %}
              <p class="trust-badges-v4-badge-text-{{ section.id }}">{{ text }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</trust-badges-v4-{{ section.id | downcase | replace: '_', '-' }}>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const tagName = 'trust-badges-v4-' + sectionId.toLowerCase().replace(/_/g, '-');
    
    class TrustBadgesV4 extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        // Component is ready
      }
    }

    customElements.define(tagName, TrustBadgesV4);
  })();
</script>

