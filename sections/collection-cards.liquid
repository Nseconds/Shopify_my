{% liquid
  assign columns = section.settings.columns | default: 3
  assign max_collections = section.settings.max_collections | default: 4
  
  if section.settings.collection_list != blank
    assign section_collections = section.settings.collection_list
  endif
%}

{% style %}
  #shopify-section-{{ section.id }} {
    --cc-columns: {{ columns }};
    --cc-gap: {{ section.settings.gap }}px;
    --cc-row-gap: {{ section.settings.row_gap }}px;
    --cc-border-radius: var(--style-border-radius-cards);
  }
  
  #shopify-section-{{ section.id }} .collection-cards__grid {
    display: grid;
    grid-template-columns: repeat(var(--cc-columns), 1fr);
    gap: var(--cc-row-gap) var(--cc-gap);
  }
  
  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} {
      --cc-columns: 2;
    }
  }
  
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --cc-columns: {{ section.settings.mobile_columns }};
    }
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    collection-cards
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.show_heading and section.settings.heading != blank %}
    <div class="collection-cards__header">
      <h2 class="collection-cards__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="collection-cards__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="collection-cards__grid">
    {% if section_collections != blank %}
      {% for collection in section_collections limit: max_collections %}
        <a href="{{ collection.url }}" class="collection-card">
          <div class="collection-card__image-wrapper">
            {% if collection.image %}
              {{ collection.image | image_url: width: 600 | image_tag: 
                class: 'collection-card__image',
                loading: 'lazy',
                widths: '300, 400, 600'
              }}
            {% elsif collection.products.first.featured_image %}
              {{ collection.products.first.featured_image | image_url: width: 600 | image_tag: 
                class: 'collection-card__image',
                loading: 'lazy',
                widths: '300, 400, 600'
              }}
            {% else %}
              {% assign inline_placeholder_variant = forloop.index | modulo: 4 | plus: 1 %}
              {% assign inline_placeholder_name = 'collection-apparel-' | append: inline_placeholder_variant %}
              <div class="collection-card__placeholder">
                {{ inline_placeholder_name | placeholder_svg_tag: 'collection-card__placeholder-svg' }}
              </div>
            {% endif %}
            {% if section.settings.show_overlay %}
              <div class="collection-card__overlay"></div>
            {% endif %}
          </div>
          <div class="collection-card__content">
            <h3 class="collection-card__name">{{ collection.title }}</h3>
            {% if section.settings.show_product_count %}
              <span class="collection-card__count">{{ collection.products_count }} {{ 'products.product.products' | t }}</span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    {% else %}
      {% for i in (1..max_collections) %}
        {% assign placeholder_variant = i | modulo: 4 | plus: 1 %}
        {% assign placeholder_name = 'collection-apparel-' | append: placeholder_variant %}
        <div class="collection-card collection-card--placeholder">
          <div class="collection-card__image-wrapper">
            <div class="collection-card__placeholder">
              {{ placeholder_name | placeholder_svg_tag: 'collection-card__placeholder-svg' }}
            </div>
          </div>
          <div class="collection-card__content">
            <h3 class="collection-card__name">Collection</h3>
            {% if section.settings.show_product_count %}
              <span class="collection-card__count">0 products</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  {% if section.settings.show_view_all and section.settings.view_all_link != blank %}
    <div class="collection-cards__footer">
      <a href="{{ section.settings.view_all_link }}" class="button {{ section.settings.button_style }}">
        {{ section.settings.view_all_text | default: 'View All Collections' }}
      </a>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .collection-cards {
    width: 100%;
  }

  .collection-cards__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .collection-cards__title {
    margin: 0 0 8px 0;
  }

  .collection-cards__subtitle {
    margin: 0;
    opacity: 0.7;
  }

  .collection-card {
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    border-radius: var(--cc-border-radius);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .collection-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .collection-card__image-wrapper {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-background);
  }

  .collection-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collection-card:hover .collection-card__image {
    transform: scale(1.05);
  }

  .collection-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-background);
  }

  .collection-card__placeholder-svg {
    width: 50%;
    height: auto;
    opacity: 0.3;
  }

  .collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
    pointer-events: none;
  }

  .collection-card__content {
    padding: 16px;
    background: var(--color-background);
  }

  .collection-card__name {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .collection-card__count {
    font-size: 0.85rem;
    opacity: 0.6;
    margin-top: 4px;
    display: block;
  }

  .collection-cards__footer {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  @media screen and (max-width: 749px) {
    .collection-cards__header {
      margin-bottom: 24px;
    }

    .collection-card__content {
      padding: 12px;
    }

    .collection-card__name {
      font-size: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Cards",
  "class": "ui-test-collection-cards",
  "blocks": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse our curated collections"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "max_collections",
      "label": "Max collections",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Horizontal gap",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Vertical gap",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show image overlay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "header",
      "content": "View All Button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All button",
      "default": false
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All link"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button text",
      "default": "View All Collections"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "button-primary", "label": "Primary" },
        { "value": "button-secondary", "label": "Secondary" },
        { "value": "link", "label": "Link" }
      ],
      "default": "button-secondary"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Collection Cards",
      "category": "Collections",
      "settings": {
        "show_heading": true,
        "heading": "Shop by Category",
        "subheading": "Browse our curated collections",
        "max_collections": 4,
        "columns": 4,
        "mobile_columns": "2",
        "gap": 24,
        "row_gap": 24,
        "card_radius": 8,
        "show_overlay": false,
        "show_product_count": true,
        "show_view_all": false,
        "button_style": "button-secondary",
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    }
  ]
}
{% endschema %}
