{% comment %}
  Editorial UGC photo strip: configurable slide size, aspect ratio, gap, optional full-bleed track, heading alignment.
{% endcomment %}

{% liquid
  assign slide_w_desktop = section.settings.slide_width_desktop | default: 360
  assign slide_w_mobile = section.settings.slide_width_mobile | default: 280
  assign gap = section.settings.gap | default: 6
  assign aspect = section.settings.aspect_ratio | default: '1 / 1'
  assign heading_align = section.settings.heading_alignment | default: 'center'
  assign heading_mb = section.settings.heading_margin_bottom | default: 24

  assign full_bleed = true
  if section.settings.full_width_strip == false
    assign full_bleed = false
  endif

  assign scroll_snap = true
  if section.settings.scroll_snap == false
    assign scroll_snap = false
  endif

  assign hover_zoom = true
  if section.settings.enable_hover_zoom == false
    assign hover_zoom = false
  endif
%}

{% style %}
  #shopify-section-{{ section.id }} {
    --eug-slide-desktop: {{ slide_w_desktop }}px;
    --eug-slide-mobile: {{ slide_w_mobile }}px;
    --eug-gap: {{ gap }}px;
    --eug-aspect: {{ aspect }};
    --eug-heading-mb: {{ heading_mb }}px;
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="editorial-ugc-strip section spacing-style color-{{ section.settings.color_scheme }} editorial-ugc-strip--heading-{{ heading_align }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <h2 class="editorial-ugc-strip__heading" id="eug-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
  {% endif %}

  <div
    class="editorial-ugc-strip__track-bleed{% if full_bleed %} editorial-ugc-strip__track-bleed--full{% endif %}"
  >
    <div
      class="editorial-ugc-strip__track{% if scroll_snap %} editorial-ugc-strip__track--snap{% endif %}{% unless hover_zoom %} editorial-ugc-strip__track--no-hover-zoom{% endunless %}"
      {% if scroll_snap %}
        tabindex="0"
        role="region"
        {% if section.settings.heading != blank %}
          aria-labelledby="eug-heading-{{ section.id }}"
        {% else %}
          aria-label="Photo gallery"
        {% endif %}
      {% endif %}
    >
      {% for block in section.blocks %}
        {% if block.type == 'photo' %}
          <div class="eug-item" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              {%- capture sizes -%}
                (min-width: 750px) {{ slide_w_desktop }}px, {{ slide_w_mobile }}px
              {%- endcapture -%}
              {{
                block.settings.image
                | image_url: width: 1600
                | image_tag:
                  class: 'eug-item__img',
                  loading: 'lazy',
                  widths: '400, 600, 800, 1000, 1200, 1600',
                  sizes: sizes
              }}
            {% else %}
              <div class="eug-item__placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'eug-item__placeholder-svg' }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% else %}
        {% for i in (1..6) %}
          <div class="eug-item">
            <div class="eug-item__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'eug-item__placeholder-svg' }}
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .editorial-ugc-strip {
    width: 100%;
  }

  .editorial-ugc-strip__heading {
    font-family: var(--font-heading--family, inherit);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
    margin: 0 0 var(--eug-heading-mb, 24px) 0;
    padding: 0 var(--page-margin, 24px);
  }

  .editorial-ugc-strip--heading-center .editorial-ugc-strip__heading {
    text-align: center;
  }

  .editorial-ugc-strip--heading-left .editorial-ugc-strip__heading {
    text-align: left;
  }

  .editorial-ugc-strip--heading-right .editorial-ugc-strip__heading {
    text-align: right;
  }

  .editorial-ugc-strip__track-bleed {
    width: 100%;
  }

  .editorial-ugc-strip__track-bleed--full {
    width: 100vw;
    max-width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  .editorial-ugc-strip__track {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: var(--eug-gap, 4px);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 var(--page-margin, 24px) 4px;
    -webkit-overflow-scrolling: touch;
  }

  .editorial-ugc-strip__track-bleed--full .editorial-ugc-strip__track {
    padding-inline: 0;
    padding-bottom: 4px;
  }

  .editorial-ugc-strip__track--snap {
    scroll-snap-type: x mandatory;
    scroll-padding-inline: var(--page-margin, 24px);
  }

  .editorial-ugc-strip__track-bleed--full .editorial-ugc-strip__track.editorial-ugc-strip__track--snap {
    scroll-padding-inline: 0;
  }

  .editorial-ugc-strip__track::-webkit-scrollbar {
    display: none;
  }

  .editorial-ugc-strip__track--snap:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .eug-item {
    flex: 0 0 var(--eug-slide-desktop, 360px);
    width: var(--eug-slide-desktop, 360px);
    max-width: var(--eug-slide-desktop, 360px);
    aspect-ratio: var(--eug-aspect, 1 / 1);
    overflow: hidden;
    border-radius: var(--style-border-radius-cards, 0px);
    scroll-snap-align: start;
  }

  .editorial-ugc-strip__track:not(.editorial-ugc-strip__track--snap) .eug-item {
    scroll-snap-align: unset;
  }

  .eug-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .editorial-ugc-strip__track--no-hover-zoom .eug-item__img {
    transition: none;
  }

  .eug-item:hover .eug-item__img {
    transform: scale(1.04);
  }

  .editorial-ugc-strip__track--no-hover-zoom .eug-item:hover .eug-item__img {
    transform: none;
  }

  .eug-item__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-card-background, #e8e2da);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .eug-item__placeholder-svg {
    width: 35%;
    height: auto;
    opacity: 0.15;
  }

  @media screen and (max-width: 749px) {
    .eug-item {
      flex: 0 0 var(--eug-slide-mobile, 260px);
      width: var(--eug-slide-mobile, 260px);
      max-width: var(--eug-slide-mobile, 260px);
    }

    .editorial-ugc-strip__heading {
      padding: 0 16px;
    }

    .editorial-ugc-strip__track {
      padding: 0 16px 4px;
    }

    .editorial-ugc-strip__track--snap {
      scroll-padding-inline: 16px;
    }

    .editorial-ugc-strip__track-bleed--full .editorial-ugc-strip__track.editorial-ugc-strip__track--snap {
      scroll-padding-inline: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .editorial-ugc-strip__track--snap {
      scroll-snap-type: none;
    }

    .eug-item__img {
      transition: none;
    }

    .eug-item:hover .eug-item__img {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial UGC Strip",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow Us @Brand"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Space below heading",
      "min": 8,
      "max": 56,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Photos"
    },
    {
      "type": "range",
      "id": "slide_width_desktop",
      "label": "Slide width (desktop)",
      "min": 220,
      "max": 520,
      "step": 10,
      "unit": "px",
      "default": 360,
      "info": "Each photo tile width on large screens."
    },
    {
      "type": "range",
      "id": "slide_width_mobile",
      "label": "Slide width (mobile)",
      "min": 160,
      "max": 360,
      "step": 10,
      "unit": "px",
      "default": 280
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Photo shape",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" }
      ],
      "default": "1 / 1"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between photos",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "full_width_strip",
      "label": "Full-width strip",
      "default": true,
      "info": "Photos span the full viewport width (heading stays padded)."
    },
    {
      "type": "checkbox",
      "id": "scroll_snap",
      "label": "Scroll snap (carousel feel)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_hover_zoom",
      "label": "Zoom image slightly on hover",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial UGC Strip",
      "settings": {
        "heading": "Follow Us @Brand",
        "heading_alignment": "center",
        "heading_margin_bottom": 24,
        "slide_width_desktop": 360,
        "slide_width_mobile": 280,
        "aspect_ratio": "1 / 1",
        "gap": 6,
        "full_width_strip": true,
        "scroll_snap": true,
        "enable_hover_zoom": true
      },
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
