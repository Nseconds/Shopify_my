{%- liquid
  assign section_id_variable = section.id
  if section.settings.enable_background_color_override and section.settings.background_color != blank
    assign hst_bg   = section.settings.background_color
    assign hst_text = section.settings.text_color | default: section.settings.color_scheme.settings.primary_button_text
  elsif settings.style_mode == 'gradient'
    assign hst_bg   = 'var(--color-card-gradient)'
    assign hst_text = 'var(--color-gradient-text)'
  else
    assign hst_bg   = section.settings.color_scheme.settings.primary
    assign hst_text = section.settings.color_scheme.settings.primary_button_text
  endif
  if section.settings.enable_text_color_override and section.settings.text_color != blank
    assign hst_text = section.settings.text_color
  endif
  if section.settings.enable_highlighted_text_color_override and section.settings.highlighted_text_color != blank
    assign hst_hl = section.settings.highlighted_text_color
  else
    assign hst_hl = hst_text
  endif
-%}
{% if request.visual_preview_mode %}
  {% comment %} For rendering in the theme editor visual preview. {% endcomment %}
  {% assign section_id_variable = "id" %}
{% endif %}

{%- style -%}
  .horizontal-scrolling-text-{{ section_id_variable }} {
    overflow: hidden;
    white-space: nowrap;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    position: relative;
    background: {{ hst_bg }} !important;
  }
  .horizontal-scrolling-text__wrapper-{{ section_id_variable }} {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    width: 100%;
  }
  .horizontal-scrolling-text__container-{{ section_id_variable }} {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: scroll-left linear infinite;
    animation-duration: {{ 60 | divided_by: section.settings.speed }}s;
  }
  @keyframes scroll-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .horizontal-scrolling-text__item-{{ section_id_variable }} {
    display: inline-block;
    padding: 0 {{ section.settings.text_spacing }}rem;
    font-size: {{ section.settings.text_size }}px;
    color: {{ hst_text }} !important;
  }
  .horizontal-scrolling-text__item-{{ section_id_variable }} strong,
  .horizontal-scrolling-text__item-{{ section_id_variable }} b {
    color: {{ hst_hl }} !important;
  }
  .horizontal-scrolling-text__loop_container-{{ section_id_variable }} {
    width: fit-content;
  }
{%- endstyle -%}

{%- capture loop_content -%}
  {%- for block in section.blocks -%}
    <div class="horizontal-scrolling-text__item-{{ section_id_variable }} block-{{ block.id }}">
      {{- block.settings.title -}}
    </div>
  {%- endfor -%}
{%- endcapture -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="horizontal-scrolling-text horizontal-scrolling-text-{{ section_id_variable }} section color-{{ section.settings.color_scheme }}">
  <div class="horizontal-scrolling-text__wrapper-{{ section_id_variable }}">
    <div class="horizontal-scrolling-text__container-{{ section_id_variable }}">
      {%- for i in (1..6) -%}
        <div class="horizontal-scrolling-text__loop_container-{{ section_id_variable }}">
          {{- loop_content -}}
        </div>
      {%- endfor -%}
    </div>
  </div>
  <div class="fade-in__left_container"></div>
  <div class="fade-in__right_container"></div>
</div>

{%- schema -%}
{
  "name": "Horizontal sliding text",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Text spacing",
      "min": 1,
      "max": 5,
      "default": 3,
      "step": 0.5
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 0.5,
      "max": 10,
      "default": 1,
      "step": 0.5
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "checkbox",
      "id": "enable_text_color_override",
      "label": "Enable text color override",
      "default": false
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color override",
      "visible_if": "{{ section.settings.enable_text_color_override }}"
    },
    {
      "type": "checkbox",
      "id": "enable_highlighted_text_color_override",
      "label": "Enable bolded text color override",
      "default": false
    },
    {
      "type": "color",
      "id": "highlighted_text_color",
      "label": "Bolded text color override",
      "visible_if": "{{ section.settings.enable_highlighted_text_color_override }}"
    },
    {
      "type": "checkbox",
      "id": "enable_background_color_override",
      "label": "Enable background color override",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color override",
      "visible_if": "{{ section.settings.enable_background_color_override }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:settings.top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:settings.bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "title",
          "default": "FORGE",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Horizontal sliding text",
      "blocks": [
        { "type": "text" },
        { "type": "text" },
        { "type": "text" }
      ]
    }
  ]
}
{%- endschema -%}
