{%- liquid
  assign eub_accent = section.settings.color_scheme.settings.primary_button_background
  assign eub_btn_text = section.settings.color_scheme.settings.primary_button_text
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --eub-accent: {{ eub_accent }};
    --eub-btn-text: {{ eub_btn_text }};
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="editorial-used-by section spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <h2 class="editorial-used-by__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="editorial-used-by__track">
    <div class="editorial-used-by__inner">
      {% for i in (1..2) %}
        {% for block in section.blocks %}
          {% if block.type == 'influencer' %}
            <div class="eub-item" {{ block.shopify_attributes }}>
              <div class="eub-item__avatar-wrap">
                {% if block.settings.avatar %}
                  {{
                    block.settings.avatar
                    | image_url: width: 160
                    | image_tag:
                      class: 'eub-item__avatar',
                      loading: 'lazy',
                      widths: '80, 120, 160'
                  }}
                {% else %}
                  <div class="eub-item__avatar-placeholder">
                    <span class="eub-item__avatar-initial">{{ block.settings.name | slice: 0 | upcase }}</span>
                  </div>
                {% endif %}
              </div>
              <div class="eub-item__meta">
                <span class="eub-item__name">
                  {{ block.settings.name }}
                  {% if block.settings.verified %}
                    <svg class="eub-item__verified" viewBox="0 0 20 20" fill="none" aria-label="Verified">
                      <circle cx="10" cy="10" r="10" fill="#1d9bf0"/>
                      <path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {% endif %}
                </span>
                {% if block.settings.handle != blank %}
                  <span class="eub-item__handle">{{ block.settings.handle }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .editorial-used-by__heading {
    font-family: var(--font-heading--family, inherit);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
    margin: 0 0 20px 0;
    padding: 0 var(--page-margin, 24px);
  }

  .editorial-used-by__track {
    display: flex;
    gap: 32px;
    overflow: hidden;
    padding: 0 var(--page-margin, 24px) 4px;
    align-items: center;
  }

  .editorial-used-by__inner {
    display: flex;
    gap: 32px;
    animation: eubScroll 60s linear infinite;
    flex-shrink: 0;
  }

  .eub-item {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  @keyframes eubScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .editorial-used-by__track:hover .editorial-used-by__inner {
    animation-play-state: paused;
  }

  .eub-item__avatar-wrap {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-card-background, #f0f0f0);
  }

  .eub-item__avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .eub-item__avatar-placeholder {
    width: 100%;
    height: 100%;
    background: var(--eub-accent, #141414);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .eub-item__avatar-initial {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1;
    color: var(--eub-btn-text, #ffffff);
    font-family: var(--font-heading--family, inherit);
    text-transform: uppercase;
  }

  .eub-item__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .eub-item__name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-foreground-heading);
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  .eub-item__verified {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .eub-item__handle {
    font-size: 0.72rem;
    color: var(--color-foreground);
    opacity: 0.55;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .editorial-used-by__heading {
      padding: 0 16px;
    }
    .editorial-used-by__track {
      padding: 0 16px 4px;
      gap: 18px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial Used By",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Used By"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "influencer",
      "name": "Person",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Name Surname"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Social handle",
          "default": "@handle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Used By",
      "settings": { "heading": "Used By" },
      "blocks": [
        { "type": "influencer", "settings": { "name": "Alex Smith", "handle": "@alexsmith", "verified": true } },
        { "type": "influencer", "settings": { "name": "Jordan Lee", "handle": "@jordanlee", "verified": true } },
        { "type": "influencer", "settings": { "name": "Sam Taylor", "handle": "@samtaylor", "verified": true } },
        { "type": "influencer", "settings": { "name": "Chris Evans", "handle": "@chrisevans", "verified": true } },
        { "type": "influencer", "settings": { "name": "Morgan Fox", "handle": "@morganfox", "verified": false } }
      ]
    }
  ]
}
{% endschema %}
