
{% assign ai_gen_id = section.id | replace: '_', '-' | downcase %}
{% assign ai_gen_id_js = section.id | replace: '_', '' | replace: '-', '' | downcase %}
{%- liquid
  if section.settings.use_custom_colors
    assign sc_text   = section.settings.heading_color
    assign sc_label  = section.settings.label_color
  else
    assign sc_text   = section.settings.color_scheme.settings.foreground
    assign sc_label  = section.settings.color_scheme.settings.foreground
  endif
-%}

{% style %}
  .ai-trending-now-{{ ai_gen_id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
  }

  .ai-trending-now__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ section.settings.heading_spacing }}px;
    color: {{ sc_text }};
    font-size: {{ section.settings.heading_size }}px;
    text-transform: {{ section.settings.heading_text_transform }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
  }

  .ai-trending-now__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--style-gap-cards);
  }

  .ai-trending-now__tile-{{ ai_gen_id }} {
    position: relative;
    display: block;
    text-decoration: none;
    overflow: hidden;
  }

  .ai-trending-now__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ section.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: var(--color-border, #f4f4f4);
  }

  .ai-trending-now__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ai-trending-now__tile-{{ ai_gen_id }}:hover .ai-trending-now__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-trending-now__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-border, #f4f4f4);
  }

  .ai-trending-now__image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-trending-now__label-{{ ai_gen_id }} {
    text-align: center;
    margin-top: {{ section.settings.label_spacing }}px;
    color: {{ sc_label }};
    font-size: {{ section.settings.label_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ section.settings.label_letter_spacing }}px;
    font-weight: {{ section.settings.label_font_weight }};
  }

  @media screen and (max-width: 989px) {
    .ai-trending-now__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-trending-now__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-trending-now__heading-{{ ai_gen_id }} {
      font-size: calc({{ section.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<trending-now-{{ ai_gen_id }} class="ai-trending-now-{{ ai_gen_id }}">
  {% if section.settings.heading != blank %}
    <h2 class="ai-trending-now__heading-{{ ai_gen_id }}">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="ai-trending-now__grid-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign product_key = 'product_' | append: i
        assign label_key = 'label_' | append: i
        assign product = section.settings[product_key]
        assign label = section.settings[label_key]
      %}

      <a
        href="{% if product != blank %}{{ product.url }}{% else %}#{% endif %}"
        class="ai-trending-now__tile-{{ ai_gen_id }}"
        {% if product == blank %}aria-disabled="true"{% endif %}
      >
        <div class="ai-trending-now__image-wrapper-{{ ai_gen_id }}">
          {% if product != blank and product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              loading="lazy"
              width="800"
              height="{{ 800 | times: section.settings.image_aspect_ratio | divided_by: 100 }}"
              class="ai-trending-now__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-trending-now__image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        {% if label != blank %}
          <div class="ai-trending-now__label-{{ ai_gen_id }}">{{ label }}</div>
        {% elsif product != blank %}
          <div class="ai-trending-now__label-{{ ai_gen_id }}">{{ product.title }}</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</trending-now-{{ ai_gen_id }}>

<script>
  (function() {
    class TrendingNow{{ ai_gen_id_js }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tiles = this.querySelectorAll('.ai-trending-now__tile-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.tiles.forEach((tile) => {
          if (tile.getAttribute('aria-disabled') === 'true') {
            tile.addEventListener('click', (e) => {
              e.preventDefault();
            });
          }
        });
      }
    }

    customElements.define('trending-now-{{ ai_gen_id }}', TrendingNow{{ ai_gen_id_js }});
  })();
</script>

{% schema %}
{
  "name": "Trending products",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "use_custom_colors", "label": "Use custom colors", "default": false },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending Now"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#141414",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "select",
      "id": "heading_text_transform",
      "label": "Heading text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Spacing below heading",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 125
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#1A1A1A",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "range",
      "id": "label_letter_spacing",
      "label": "Label letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1.5
    },
    {
      "type": "select",
      "id": "label_font_weight",
      "label": "Label font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "label_spacing",
      "label": "Spacing above label",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Product 1"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "label_1",
      "label": "Label",
      "default": "New Arrivals"
    },
    {
      "type": "header",
      "content": "Product 2"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "label_2",
      "label": "Label",
      "default": "Best Sellers"
    },
    {
      "type": "header",
      "content": "Product 3"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "label_3",
      "label": "Label",
      "default": "Everyday Essentials"
    },
    {
      "type": "header",
      "content": "Product 4"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "label_4",
      "label": "Label",
      "default": "Statement Pieces"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Trending products"
    }
  ]
}
