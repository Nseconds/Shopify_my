{% liquid
  assign max_collections = section.settings.max_collections | default: 6
  assign card_width = section.settings.card_width | default: 200
  assign auto_scroll = section.settings.auto_scroll | default: true
  assign scroll_speed = section.settings.scroll_speed | default: 30
  assign show_border = section.settings.show_border | default: false
  assign border_width = section.settings.border_width | default: 1
  assign border_color = section.settings.border_color | default: '#e5e5e5'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
    collections-carousel-section
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <!-- Header -->
  {% if section.settings.heading != blank or section.settings.description != blank %}
    <div class="collections-carousel__header">
      {% if section.settings.heading != blank %}
        <h2 class="collections-carousel__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      
      {% if section.settings.description != blank %}
        <p class="collections-carousel__description">{{ section.settings.description }}</p>
      {% endif %}
    </div>
  {% endif %}

  <!-- Collections Marquee Carousel -->
  {% liquid
    assign section_collections = section.settings.collection_list
    assign use_all_collections = false
    if section_collections == blank or section_collections.size == 0
      assign use_all_collections = true
    endif
  %}

  {% liquid
    assign has_collections = false
    if use_all_collections
      for collection in collections limit: 1
        if collection.products_count > 0
          assign has_collections = true
        endif
      endfor
    else
      if section_collections.size > 0
        assign has_collections = true
      endif
    endif
  %}

  {% capture collection_cards %}
    {% if has_collections %}
      {% if use_all_collections %}
        {% for collection in collections limit: max_collections %}
          {% if collection.products_count > 0 %}
            <a href="{{ collection.url }}" class="collections-carousel__card">
              <div class="collections-carousel__image-wrapper">
                {% if collection.image %}
                  {{ collection.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'collections-carousel__image' }}
                {% elsif collection.products.first.featured_image %}
                  {{ collection.products.first.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'collections-carousel__image' }}
                {% else %}
                  <div class="collections-carousel__placeholder">
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {% endif %}
              </div>
              <div class="collections-carousel__info">
                <h3 class="collections-carousel__title">{{ collection.title | upcase }}</h3>
                <span class="collections-carousel__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</span>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      {% else %}
        {% for collection in section_collections limit: max_collections %}
          <a href="{{ collection.url }}" class="collections-carousel__card">
            <div class="collections-carousel__image-wrapper">
              {% if collection.image %}
                {{ collection.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'collections-carousel__image' }}
              {% elsif collection.products.first.featured_image %}
                {{ collection.products.first.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'collections-carousel__image' }}
              {% else %}
                <div class="collections-carousel__placeholder">
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
            </div>
            <div class="collections-carousel__info">
              <h3 class="collections-carousel__title">{{ collection.title | upcase }}</h3>
              <span class="collections-carousel__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</span>
            </div>
          </a>
        {% endfor %}
      {% endif %}
    {% else %}
      <!-- Placeholder collections when no real collections exist -->
      {% assign placeholder_names = 'New Arrivals,Best Sellers,Summer Collection,Accessories,Sale Items,Featured' | split: ',' %}
      {% for i in (1..6) %}
        {% assign placeholder_index = forloop.index | minus: 1 %}
        <div class="collections-carousel__card collections-carousel__card--placeholder">
          <div class="collections-carousel__image-wrapper">
            <div class="collections-carousel__placeholder">
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          </div>
          <div class="collections-carousel__info">
            <h3 class="collections-carousel__title">{{ placeholder_names[placeholder_index] | upcase }}</h3>
            <span class="collections-carousel__count">0 products</span>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  {% endcapture %}

  <div 
    class="collections-carousel__marquee-wrapper {% if auto_scroll %}collections-carousel__marquee-wrapper--animate{% endif %}"
    style="
      --carousel-card-width: {{ card_width }}px;
      --carousel-gap: var(--style-gap-cards);
      --carousel-speed: {{ scroll_speed }}s;
      --carousel-border-width: {% if show_border %}{{ border_width }}px{% else %}0{% endif %};
      --carousel-border-color: {{ border_color }};
      --carousel-border-radius: var(--style-border-radius-cards);
    "
  >
    <div class="collections-carousel__track">
      <div class="collections-carousel__items">
        {{ collection_cards }}
      </div>
      {% if auto_scroll %}
        <!-- Duplicate for seamless loop -->
        <div class="collections-carousel__items" aria-hidden="true">
          {{ collection_cards }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .collections-carousel-section {
    overflow: hidden;
  }

  .collections-carousel__header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .collections-carousel__heading {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  .collections-carousel__description {
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    color: var(--color-foreground);
    opacity: 0.7;
  }

  /* Marquee wrapper */
  .collections-carousel__marquee-wrapper {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 5%,
      black 95%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 5%,
      black 95%,
      transparent
    );
  }

  .collections-carousel__track {
    display: flex;
    width: fit-content;
    gap: var(--carousel-gap, 16px);
  }

  .collections-carousel__marquee-wrapper--animate .collections-carousel__track {
    animation: collections-scroll var(--carousel-speed, 30s) linear infinite;
  }

  .collections-carousel__marquee-wrapper:hover .collections-carousel__track {
    animation-play-state: paused;
  }

  @keyframes collections-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - var(--carousel-gap, 16px) / 2));
    }
  }

  .collections-carousel__items {
    display: flex;
    gap: var(--carousel-gap, 16px);
    flex-shrink: 0;
  }

  .collections-carousel__card {
    display: block;
    text-decoration: none;
    color: inherit;
    width: var(--carousel-card-width, 200px);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .collections-carousel__card:hover {
    transform: translateY(-4px);
  }

  .collections-carousel__image-wrapper {
    width: var(--carousel-card-width, 200px);
    height: var(--carousel-card-width, 200px);
    overflow: hidden;
    border-radius: var(--carousel-border-radius, 8px);
    background: var(--color-background-secondary, #f5f5f5);
    border: var(--carousel-border-width, 0) solid var(--carousel-border-color, #e5e5e5);
  }

  .collections-carousel__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .collections-carousel__card:hover .collections-carousel__image {
    transform: scale(1.05);
  }

  .collections-carousel__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-background-secondary, #f5f5f5);
  }

  .collections-carousel__placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .collections-carousel__info {
    padding: 0.75rem 0;
    text-align: left;
  }

  .collections-carousel__title {
    font-size: 0.8125rem;
    font-weight: 600;
    margin: 0 0 0.125rem 0;
    color: var(--color-foreground);
    letter-spacing: 0.02em;
  }

  .collections-carousel__count {
    font-size: 0.75rem;
    color: var(--color-foreground);
    opacity: 0.5;
  }

  /* Placeholder cards styling */
  .collections-carousel__card--placeholder {
    cursor: default;
    opacity: 0.7;
  }

  .collections-carousel__card--placeholder:hover {
    transform: none;
  }

  .collections-carousel__card--placeholder .collections-carousel__image:hover {
    transform: none;
  }

  @media screen and (max-width: 749px) {
    .collections-carousel__heading {
      font-size: 1.375rem;
    }

    .collections-carousel__marquee-wrapper {
      --carousel-card-width: 150px !important;
    }
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .collections-carousel__marquee-wrapper--animate .collections-carousel__track {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collections Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections",
      "info": "Select collections to display. If none selected, shows all collections with products."
    },
    {
      "type": "range",
      "id": "max_collections",
      "label": "Maximum collections",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card width",
      "min": 120,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 200,
      "info": "Width of each collection card"
    },
    {
      "type": "header",
      "content": "Card Border"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show border",
      "default": true
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "auto_scroll",
      "label": "Auto scroll",
      "default": true,
      "info": "Continuously scroll the carousel"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30,
      "unit": "s",
      "info": "Lower = faster"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Collections Carousel",
      "settings": {
        "heading": "Shop by collection",
        "max_collections": 8,
        "card_width": 200,
        "auto_scroll": true,
        "scroll_speed": 30
      }
    }
  ]
}
{% endschema %}
