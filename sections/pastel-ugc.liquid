{% liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign ugc_blocks = section.blocks | where: 'type', 'ugc_item'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="pastel-ugc section color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="pastel-ugc__inner">
    {% if heading != blank %}
      <h2 class="pastel-ugc__heading">{{ heading }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="pastel-ugc__subheading">{{ subheading }}</p>
    {% endif %}

    {% if ugc_blocks.size > 0 %}
      <div class="pastel-ugc__strip">
        {% for block in ugc_blocks %}
          <div class="pastel-ugc__item" {{ block.shopify_attributes }}>
            <div class="pastel-ugc__image-wrap">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 400 }}"
                  alt="{{ block.settings.caption | default: 'Customer photo' }}"
                  width="200"
                  height="200"
                  loading="lazy"
                  class="pastel-ugc__image"
                >
              {% elsif block.settings.image_url != blank %}
                {% # theme-check-disable RemoteAsset %}
                <img
                  src="{{ block.settings.image_url }}"
                  alt="{{ block.settings.caption | default: 'Customer photo' }}"
                  width="200"
                  height="200"
                  loading="lazy"
                  class="pastel-ugc__image"
                >
                {% # theme-check-enable RemoteAsset %}
              {% else %}
                <div class="pastel-ugc__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
              {% endif %}
            </div>
            {% if block.settings.caption != blank or block.settings.username != blank %}
              <div class="pastel-ugc__meta">
                {% if block.settings.username != blank %}
                  <span class="pastel-ugc__username">{{ block.settings.username }}</span>
                {% endif %}
                {% if block.settings.caption != blank %}
                  <p class="pastel-ugc__caption">{{ block.settings.caption }}</p>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .pastel-ugc {
    padding: 48px 24px;
    background: var(--color-background);
  }

  .pastel-ugc__inner {
    max-width: 100%;
    overflow: hidden;
  }

  .pastel-ugc__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-foreground-heading);
    margin: 0 0 12px;
    text-align: center;
  }

  .pastel-ugc__subheading {
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground-muted);
    margin: 0 0 24px;
    text-align: center;
  }

  .pastel-ugc__strip {
    display: flex;
    gap: var(--style-gap-cards, 12px);
    overflow-x: auto;
    padding-bottom: 8px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .pastel-ugc__strip::-webkit-scrollbar {
    height: 6px;
  }

  .pastel-ugc__strip::-webkit-scrollbar-track {
    background: var(--color-background-secondary);
    border-radius: 999px;
  }

  .pastel-ugc__strip::-webkit-scrollbar-thumb {
    background: var(--color-primary);
    border-radius: 999px;
  }

  .pastel-ugc__item {
    flex: 0 0 200px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pastel-ugc__image-wrap {
    position: relative;
    padding-bottom: 100%;
    overflow: hidden;
    background: var(--color-background-secondary);
    border-radius: var(--style-border-radius-images, 12px);
  }

  .pastel-ugc__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pastel-ugc__placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pastel-ugc__placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .pastel-ugc__meta {
    padding: 0 4px;
  }

  .pastel-ugc__username {
    font-family: var(--font-body--family);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary);
    display: block;
    margin-bottom: 2px;
  }

  .pastel-ugc__caption {
    font-family: var(--font-body--family);
    font-size: 12px;
    color: var(--color-foreground-muted);
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media screen and (max-width: 749px) {
    .pastel-ugc {
      padding: 32px 16px;
    }

    .pastel-ugc__item {
      flex: 0 0 160px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Feed Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Peep the feed"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real customers, real results"
    }
  ],
  "blocks": [
    {
      "type": "ugc_item",
      "name": "UGC item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback for AI-generated)"
        },
        {
          "type": "text",
          "id": "username",
          "label": "Username",
          "default": "@restednights"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feed Strip",
      "blocks": [
        { "type": "ugc_item", "settings": { "username": "@restednights", "caption": "Best sleep ever!" } },
        { "type": "ugc_item", "settings": { "username": "@sleepwell", "caption": "Game changer" } },
        { "type": "ugc_item", "settings": { "username": "@zzzqueen", "caption": "Finally resting" } },
        { "type": "ugc_item", "settings": { "username": "@calmdreamer", "caption": "Sweet dreams" } },
        { "type": "ugc_item", "settings": { "username": "@nightowlnomore", "caption": "Out like a light" } },
        { "type": "ugc_item", "settings": { "username": "@dreamteam", "caption": "Couldn't live without it" } },
        { "type": "ugc_item", "settings": { "username": "@sleepysmiles", "caption": "Wake up refreshed" } }
      ]
    }
  ]
}
{% endschema %}
