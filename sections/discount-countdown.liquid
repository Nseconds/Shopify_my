{% assign ai_gen_id = section.id | replace: '_', '-' | downcase %}
{% assign ai_gen_id_js = section.id | replace: '_', '' | replace: '-', '' | downcase %}
{% assign background_gradient = section.settings.background_gradient %}
{% assign background_color = section.settings.background_color %}
{% assign overlay_color = section.settings.overlay_color %}
{% assign overlay_opacity_raw = section.settings.overlay_opacity %}
{% assign blur_color_1 = section.settings.blur_color_1 %}
{% assign blur_color_2 = section.settings.blur_color_2 %}
{% assign eyebrow_color = section.settings.eyebrow_color %}
{% assign eyebrow_bg_color = section.settings.eyebrow_bg_color %}
{% assign heading_color = section.settings.heading_color %}
{% assign subheading_color = section.settings.subheading_color %}
{% assign countdown_color = section.settings.countdown_color %}
{% assign countdown_label_color = section.settings.countdown_label_color %}
{% assign countdown_bg_color = section.settings.countdown_bg_color %}
{% assign button_bg_color = section.settings.button_bg_color %}
{% assign button_text_color = section.settings.button_text_color %}
{% assign button_hover_bg = section.settings.button_hover_bg %}
{% assign button_hover_text = section.settings.button_hover_text %}

{% assign overlay_opacity = overlay_opacity_raw | divided_by: 100.0 %}

{% if settings.style_mode == 'gradient' %}
  {%- liquid
    assign background_gradient = 'var(--color-card-gradient)'
    assign background_color = 'var(--color-card-background)'
    assign heading_color = 'var(--color-gradient-text)'
    assign subheading_color = 'var(--color-gradient-text)'
    assign countdown_color = 'var(--color-gradient-text)'
    assign countdown_label_color = 'var(--color-gradient-text)'
  -%}
{% else %}
  {%- liquid
    assign background_gradient = 'var(--color-primary)'
    assign background_color = 'var(--color-primary)'
    assign heading_color = 'var(--color-primary-button-text)'
    assign subheading_color = 'var(--color-primary-button-text)'
    assign countdown_color = 'var(--color-primary)'
    assign countdown_label_color = 'var(--color-primary)'
    assign eyebrow_color = 'var(--color-primary)'
    assign eyebrow_bg_color = 'var(--color-background)'
    assign countdown_bg_color = 'var(--color-background)'
    assign button_bg_color = 'var(--color-background)'
    assign button_text_color = 'var(--color-primary)'
    assign button_hover_bg = 'var(--color-background)'
    assign button_hover_text = 'var(--color-primary)'
    assign blur_color_1 = 'transparent'
    assign blur_color_2 = 'transparent'
    assign overlay_color = 'transparent'
  -%}
{% endif %}

{% style %}
  .ai-black-friday-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background: {{ background_gradient | default: background_color }};
    background-color: {{ background_color }};
    padding: {{ section.settings.padding_desktop }}px 40px;
    text-align: {{ section.settings.text_alignment }};
    overflow: hidden;
  }

  .ai-black-friday-banner--full-width-{{ ai_gen_id }} {
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    width: 100vw;
  }

  @media screen and (max-width: 749px) {
    .ai-black-friday-banner-{{ ai_gen_id }} {
      padding: {{ section.settings.padding_mobile }}px 20px;
    }
  }

  .ai-black-friday-banner__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-black-friday-banner__eyebrow-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: {{ section.settings.eyebrow_size }}px;
    color: {{ eyebrow_color }};
    background: {{ eyebrow_bg_color }};
    padding: 6px 14px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    font-weight: 600;
    backdrop-filter: blur(20px) saturate(180%);
    border: 0.5px solid {% if settings.style_mode == 'gradient' %}rgba(255, 255, 255, 0.18){% else %}var(--color-border){% endif %};
  }

  @media screen and (max-width: 749px) {
    .ai-black-friday-banner__eyebrow-{{ ai_gen_id }} {
      font-size: {{ section.settings.eyebrow_size | times: 0.9 }}px;
      padding: 5px 12px;
    }
  }

  .ai-black-friday-banner__heading-{{ ai_gen_id }} {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ heading_color }};
    margin: 0 0 8px;
    font-weight: 700;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -0.5px;
  }

  @media screen and (max-width: 749px) {
    .ai-black-friday-banner__heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_size | times: 0.6 }}px;
    }
  }

  .ai-black-friday-banner__subheading-{{ ai_gen_id }} {
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ subheading_color }};
    margin: 0 0 20px;
    line-height: 1.4;
    font-weight: 500;
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    .ai-black-friday-banner__subheading-{{ ai_gen_id }} {
      font-size: {{ section.settings.subheading_size | times: 0.9 }}px;
      margin-bottom: 16px;
    }
  }

  .ai-black-friday-banner__countdown-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ section.settings.text_alignment }};
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .ai-black-friday-banner__countdown-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 64px;
    background: {{ countdown_bg_color }};
    border-radius: var(--style-border-radius-cards);
    padding: 12px 10px;
    backdrop-filter: blur(20px) saturate(180%);
    border: 0.5px solid {% if settings.style_mode == 'gradient' %}rgba(255, 255, 255, 0.18){% else %}var(--color-border){% endif %};
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  @media screen and (max-width: 749px) {
    .ai-black-friday-banner__countdown-item-{{ ai_gen_id }} {
      min-width: 56px;
      padding: 10px 8px;
    }
  }

  .ai-black-friday-banner__countdown-number-{{ ai_gen_id }} {
    font-size: {{ section.settings.countdown_size }}px;
    color: {{ countdown_color }};
    font-weight: 600;
    line-height: 1;
    margin-bottom: 4px;
    font-variant-numeric: tabular-nums;
  }

  @media screen and (max-width: 749px) {
    .ai-black-friday-banner__countdown-number-{{ ai_gen_id }} {
      font-size: {{ section.settings.countdown_size | times: 0.75 }}px;
    }
  }

  .ai-black-friday-banner__countdown-label-{{ ai_gen_id }} {
    font-size: 10px;
    color: {{ countdown_label_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 500;
    opacity: 0.7;
  }

  .ai-black-friday-banner__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 32px;
    background: {{ button_bg_color }};
    color: {{ button_text_color }};
    text-decoration: none;
    font-size: {{ section.settings.button_size }}px;
    font-weight: 600;
    letter-spacing: -0.2px;
    border-radius: 100px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(20px) saturate(180%);
  }

  .ai-black-friday-banner__button-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 100%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .ai-black-friday-banner__button-{{ ai_gen_id }}:hover::before {
    opacity: 1;
  }

  .ai-black-friday-banner__button-{{ ai_gen_id }}:hover {
    background: {{ button_hover_bg }};
    color: {{ button_hover_text }};
    transform: scale(1.02);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18);
  }

  .ai-black-friday-banner__button-{{ ai_gen_id }}:active {
    transform: scale(0.98);
  }

  @media screen and (max-width: 749px) {
    .ai-black-friday-banner__button-{{ ai_gen_id }} {
      padding: 12px 28px;
      font-size: {{ section.settings.button_size | times: 0.95 }}px;
    }
  }

  .ai-black-friday-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ overlay_color }};
    opacity: {{ overlay_opacity }};
    z-index: 1;
  }

  .ai-black-friday-banner__blur-circle-{{ ai_gen_id }} {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
    z-index: 0;
  }

  .ai-black-friday-banner__blur-circle-1-{{ ai_gen_id }} {
    width: 300px;
    height: 300px;
    background: {{ blur_color_1 }};
    top: -100px;
    right: 10%;
  }

  .ai-black-friday-banner__blur-circle-2-{{ ai_gen_id }} {
    width: 250px;
    height: 250px;
    background: {{ blur_color_2 }};
    bottom: -80px;
    left: 15%;
  }

  @media screen and (max-width: 749px) {
    .ai-black-friday-banner__blur-circle-1-{{ ai_gen_id }} {
      width: 200px;
      height: 200px;
      top: -60px;
    }

    .ai-black-friday-banner__blur-circle-2-{{ ai_gen_id }} {
      width: 180px;
      height: 180px;
      bottom: -50px;
    }
  }
{% endstyle %}

<div class="ai-black-friday-banner-{{ ai_gen_id }} ai-black-friday-banner--full-width-{{ ai_gen_id }} color-{{ section.settings.color_scheme }}">
  {% if section.settings.show_blur_effects %}
    <div class="ai-black-friday-banner__blur-circle-{{ ai_gen_id }} ai-black-friday-banner__blur-circle-1-{{ ai_gen_id }}"></div>
    <div class="ai-black-friday-banner__blur-circle-{{ ai_gen_id }} ai-black-friday-banner__blur-circle-2-{{ ai_gen_id }}"></div>
  {% endif %}

  {% if section.settings.show_overlay %}
    <div class="ai-black-friday-banner__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-black-friday-banner__content-{{ ai_gen_id }}">
    {% if section.settings.eyebrow_text != blank %}
      <div class="ai-black-friday-banner__eyebrow-{{ ai_gen_id }}">
        <span>{{ section.settings.eyebrow_text }}</span>
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="ai-black-friday-banner__heading-{{ ai_gen_id }}">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <div class="ai-black-friday-banner__subheading-{{ ai_gen_id }}">
        {{ section.settings.subheading }}
      </div>
    {% endif %}

    {% if section.settings.show_countdown %}
      <div class="ai-black-friday-banner__countdown-{{ ai_gen_id }}" id="ai-countdown-{{ ai_gen_id }}">
        <div class="ai-black-friday-banner__countdown-item-{{ ai_gen_id }}">
          <div class="ai-black-friday-banner__countdown-number-{{ ai_gen_id }}" data-hours>00</div>
          <div class="ai-black-friday-banner__countdown-label-{{ ai_gen_id }}">Hours</div>
        </div>
        <div class="ai-black-friday-banner__countdown-item-{{ ai_gen_id }}">
          <div class="ai-black-friday-banner__countdown-number-{{ ai_gen_id }}" data-minutes>00</div>
          <div class="ai-black-friday-banner__countdown-label-{{ ai_gen_id }}">Mins</div>
        </div>
        <div class="ai-black-friday-banner__countdown-item-{{ ai_gen_id }}">
          <div class="ai-black-friday-banner__countdown-number-{{ ai_gen_id }}" data-seconds>00</div>
          <div class="ai-black-friday-banner__countdown-label-{{ ai_gen_id }}">Secs</div>
        </div>
      </div>
    {% endif %}

    {% if section.settings.button_text != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="ai-black-friday-banner__button-{{ ai_gen_id }}">
        <span>{{ section.settings.button_text }}</span>
      </a>
    {% endif %}
  </div>
</div>

{% if section.settings.show_countdown %}
  <script>
    (function() {
      var tagName = 'black-friday-countdown-{{ ai_gen_id }}';

      class BlackFridayCountdown{{ ai_gen_id_js }} extends HTMLElement {
        constructor() {
          super();
          this.countdownElement = document.getElementById('ai-countdown-{{ ai_gen_id }}');
        }

        connectedCallback() {
          if (this.countdownElement) {
            this.updateCountdown();
            this.interval = setInterval(() => this.updateCountdown(), 1000);
          }
        }

        disconnectedCallback() {
          if (this.interval) {
            clearInterval(this.interval);
          }
        }

        getNextTarget() {
          var now = new Date();
          var target = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 18, 0, 0, 0);

          /* If 6 PM today has already passed, target tomorrow's 6 PM */
          if (now.getTime() >= target.getTime()) {
            target.setDate(target.getDate() + 1);
          }

          return target.getTime();
        }

        updateCountdown() {
          var now = new Date().getTime();
          var distance = this.getNextTarget() - now;

          if (distance < 0) {
            distance = 0;
          }

          var hours = Math.floor(distance / (1000 * 60 * 60));
          var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          var seconds = Math.floor((distance % (1000 * 60)) / 1000);

          this.countdownElement.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
          this.countdownElement.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
          this.countdownElement.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');
        }
      }

      if (!customElements.get(tagName)) {
        customElements.define(tagName, BlackFridayCountdown{{ ai_gen_id_js }});
      }

      var banner = document.querySelector('.ai-black-friday-banner-{{ ai_gen_id }}');
      if (banner) {
        var wrapper = document.createElement(tagName);
        banner.parentNode.insertBefore(wrapper, banner);
        wrapper.appendChild(banner);
      }
    })();
  </script>
{% endif %}

