{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}
{%- liquid
  assign product_count = 0
  for i in (1..4)
    assign product_key = 'product_' | append: i
    if section.settings[product_key] != blank
      assign product_count = product_count | plus: 1
    endif
  endfor
  assign render_placeholders = false
  if product_count == 0
    assign render_placeholders = true
    assign visible_count = 4
  else
    assign visible_count = product_count
  endif
-%}
{%- liquid
  if section.settings.use_custom_colors
    assign sc_bg          = section.settings.background_color
    assign sc_text        = section.settings.headline_color
    assign sc_accent      = section.settings.accent_color
    assign sc_card        = section.settings.card_background
    assign sc_cta         = section.settings.cta_color
    assign sc_placeholder = section.settings.placeholder_bg
    assign sc_gradient    = section.settings.gradient_color
  elsif settings.style_mode == 'gradient'
    assign sc_bg          = 'var(--color-background)'
    assign sc_text        = 'var(--color-foreground)'
    assign sc_accent      = 'var(--color-gradient-1)'
    assign sc_card        = 'var(--color-card-gradient)'
    assign sc_cta         = 'var(--color-card-gradient)'
    assign sc_placeholder = 'var(--color-card-background)'
    assign sc_gradient    = 'rgba(0, 0, 0, 0.5)'
  else
    assign sc_bg          = section.settings.color_scheme.settings.background
    assign sc_text        = section.settings.color_scheme.settings.foreground
    assign sc_accent      = section.settings.color_scheme.settings.primary
    assign sc_card        = section.settings.color_scheme.settings.background
    assign sc_cta         = section.settings.color_scheme.settings.background
    assign sc_placeholder = section.settings.color_scheme.settings.background
    assign sc_gradient    = 'rgba(0, 0, 0, 0.5)'
  endif
-%}

{% style %}
  .ai-luxury-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ section.settings.section_padding_top }}px 20px {{ section.settings.section_padding_bottom }}px;
    background: {{ sc_bg }};
  }

  .ai-luxury-showcase__container-{{ ai_gen_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-luxury-showcase__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ section.settings.header_spacing }}px;
  }

  .ai-luxury-showcase__headline-{{ ai_gen_id }} {
    font-family: var(--font-heading--family);
    font-size: {{ section.settings.headline_size }}px;
    line-height: 1.2;
    color: {{ sc_text }};
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ai-luxury-showcase__headline-accent-{{ ai_gen_id }} {
    color: {{ sc_accent }};
    font-style: {{ section.settings.accent_style }};
  }

  {% if settings.style_mode == 'gradient' %}
  .ai-luxury-showcase__headline-accent-{{ ai_gen_id }} {
    background: var(--color-card-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  {% endif %}

  .ai-luxury-showcase__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ visible_count }}, 1fr);
    gap: var(--style-gap-cards);
    max-width: calc({{ section.settings.max_width }}px * {{ visible_count }} / 4);
    margin: 0 auto;
  }

  .ai-luxury-showcase__card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: var(--style-border-radius-cards);
    background-color: {{ sc_card }};
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-luxury-showcase__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ section.settings.hover_lift }}px);
    box-shadow: 0 {{ section.settings.hover_lift | times: 2 }}px {{ section.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, {{ section.settings.hover_shadow_opacity }});
  }

  .ai-luxury-showcase__card-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  .ai-luxury-showcase__card-link-{{ ai_gen_id }}:focus-visible {
    outline: 2px solid {{ sc_accent }};
    outline-offset: 3px;
    border-radius: var(--style-border-radius-cards);
  }

  .ai-luxury-showcase__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-luxury-showcase__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  .ai-luxury-showcase__card-{{ ai_gen_id }}:hover .ai-luxury-showcase__image-{{ ai_gen_id }} {
    opacity: {{ section.settings.hover_image_opacity }};
  }

  .ai-luxury-showcase__gradient-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: {{ section.settings.gradient_height }}%;
    background: linear-gradient(to top, {{ sc_gradient }}, transparent);
    pointer-events: none;
  }

  .ai-luxury-showcase__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ sc_placeholder }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-luxury-showcase__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-luxury-showcase__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: {{ sc_text }};
    opacity: 0.6;
    text-align: center;
    padding: 0 12px;
  }

  .ai-luxury-showcase__cta-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ section.settings.cta_bottom_spacing }}px;
    left: {{ section.settings.cta_side_spacing }}px;
    right: {{ section.settings.cta_side_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-body--family);
    font-size: {{ section.settings.cta_size }}px;
    color: {{ sc_cta }};
    letter-spacing: 0.05em;
    pointer-events: none;
    transition: transform 0.3s ease;
  }

  .ai-luxury-showcase__card-{{ ai_gen_id }}:hover .ai-luxury-showcase__cta-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-luxury-showcase__cta-text-{{ ai_gen_id }} {
    text-transform: {{ section.settings.cta_text_transform }};
  }

  .ai-luxury-showcase__cta-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2;
    transition: transform 0.3s ease;
  }

  .ai-luxury-showcase__card-{{ ai_gen_id }}:hover .ai-luxury-showcase__cta-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  @media screen and (max-width: 989px) {
    .ai-luxury-showcase__grid-{{ ai_gen_id }} {
      {% if visible_count == 4 %}
      grid-template-columns: repeat(2, 1fr);
      {% endif %}
      gap: var(--style-gap-cards);
    }

    .ai-luxury-showcase__headline-{{ ai_gen_id }} {
      font-size: {{ section.settings.headline_size | times: 0.7 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-showcase-{{ ai_gen_id }} {
      padding: {{ section.settings.section_padding_top | times: 0.6 }}px 16px {{ section.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-luxury-showcase__header-{{ ai_gen_id }} {
      margin-bottom: {{ section.settings.header_spacing | times: 0.7 }}px;
    }

    .ai-luxury-showcase__headline-{{ ai_gen_id }} {
      font-size: {{ section.settings.headline_size | times: 0.5 }}px;
    }

    .ai-luxury-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: var(--style-gap-cards);
      max-width: 100%;
    }

    .ai-luxury-showcase__cta-{{ ai_gen_id }} {
      font-size: {{ section.settings.cta_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div
  id="shopify-section-{{ section.id }}"
  class="ai-luxury-showcase-{{ ai_gen_id }} color-{{ section.settings.color_scheme }}"
  {{ section.shopify_attributes }}
>
  <div class="ai-luxury-showcase__container-{{ ai_gen_id }}">
    {% if section.settings.headline != blank %}
      <div class="ai-luxury-showcase__header-{{ ai_gen_id }}">
        <h2 class="ai-luxury-showcase__headline-{{ ai_gen_id }}">
          {% assign words = section.settings.headline | split: ' ' %}
          {% assign accent_word_index = section.settings.accent_word_position | minus: 1 %}
          {% for word in words %}
            {% if forloop.index0 == accent_word_index %}
              <span class="ai-luxury-showcase__headline-accent-{{ ai_gen_id }}">{{ word }}</span>
            {% else %}
              {{ word }}
            {% endif %}
            {% unless forloop.last %} {% endunless %}
          {% endfor %}
        </h2>
      </div>
    {% endif %}

    <div class="ai-luxury-showcase__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign product = section.settings[product_key]
        %}

        {% if product != blank %}
          <div class="ai-luxury-showcase__card-{{ ai_gen_id }}">
            <a
              href="{{ product.url }}"
              class="ai-luxury-showcase__card-link-{{ ai_gen_id }}"
            >
              <div class="ai-luxury-showcase__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    width="800"
                    height="{{ 800 | divided_by: section.settings.image_aspect_ratio }}"
                    loading="lazy"
                    class="ai-luxury-showcase__image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-luxury-showcase__placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
                <div class="ai-luxury-showcase__gradient-overlay-{{ ai_gen_id }}"></div>
              </div>
              <div class="ai-luxury-showcase__cta-{{ ai_gen_id }}">
                <span class="ai-luxury-showcase__cta-text-{{ ai_gen_id }}">
                  {{ section.settings.cta_prefix }} {{ product.title }}
                </span>
                <svg
                  class="ai-luxury-showcase__cta-arrow-{{ ai_gen_id }}"
                  aria-hidden="true"
                  focusable="false"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </a>
          </div>
        {% elsif render_placeholders %}
          <div class="ai-luxury-showcase__card-{{ ai_gen_id }}">
            <div class="ai-luxury-showcase__image-wrapper-{{ ai_gen_id }}">
              <div class="ai-luxury-showcase__placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
                <div class="ai-luxury-showcase__empty-state-{{ ai_gen_id }}">
                  Add product {{ i }}
                </div>
              </div>
              <div class="ai-luxury-showcase__gradient-overlay-{{ ai_gen_id }}"></div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const sectionElement = document.querySelector(`#shopify-section-${sectionId}`);
    if (sectionElement) {
      const cards = sectionElement.querySelectorAll('.ai-luxury-showcase__card-{{ ai_gen_id }}');
      cards.forEach((card) => {
        const link = card.querySelector('.ai-luxury-showcase__card-link-{{ ai_gen_id }}');
        if (link) {
          const label = link.textContent.replace(/\s+/g, ' ').trim();
          if (label) link.setAttribute('aria-label', label);
        }
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Luxury product showcase",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline text",
      "default": "Discover Our Signature Collection"
    },
    {
      "type": "range",
      "id": "accent_word_position",
      "label": "Accent word position",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3,
      "info": "Which word in the headline to emphasize"
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Headline size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline color",
      "default": "#2c2c2c",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent word color",
      "default": "#9b7e6b",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "select",
      "id": "accent_style",
      "label": "Accent word style",
      "options": [
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "italic",
          "label": "Italic"
        }
      ],
      "default": "italic"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Header spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Product 4"
    },
    {
      "type": "header",
      "content": "Product cards"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "0.75",
          "label": "Portrait (3:4)"
        },
        {
          "value": "0.8",
          "label": "Portrait (4:5)"
        },
        {
          "value": "1",
          "label": "Square (1:1)"
        }
      ],
      "default": "0.75"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Gradient overlay"
    },
    {
      "type": "range",
      "id": "gradient_height",
      "label": "Gradient height",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "color",
      "id": "gradient_color",
      "label": "Gradient color",
      "default": "rgba(0, 0, 0, 0.5)",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_prefix",
      "label": "CTA prefix",
      "default": "Shop"
    },
    {
      "type": "range",
      "id": "cta_size",
      "label": "CTA size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "CTA color",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "select",
      "id": "cta_text_transform",
      "label": "CTA text style",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "cta_bottom_spacing",
      "label": "CTA bottom spacing",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "cta_side_spacing",
      "label": "CTA side spacing",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Hover effects"
    },
    {
      "type": "range",
      "id": "hover_lift",
      "label": "Lift amount",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "hover_shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "default": 0.2
    },
    {
      "type": "range",
      "id": "hover_image_opacity",
      "label": "Image opacity on hover",
      "min": 0.5,
      "max": 1,
      "step": 0.1,
      "default": 0.9
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top padding",
      "min": 20,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom padding",
      "min": 20,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#faf8f6",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "color",
      "id": "placeholder_bg",
      "label": "Placeholder background",
      "default": "#f0ebe6",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Luxury product showcase"
    }
  ]
}
{% endschema %}
