            </div>
          {% endif %}

          {% if section.settings.benefit_3 != blank %}
            <div class="comparison-v2__benefit-item-{{ section.id }}">
              <div class="comparison-v2__x-icon-{{ section.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </div>
              <p class="comparison-v2__benefit-text-{{ section.id }} comparison-v2__others-label-{{ section.id }}">
                {{ section.settings.others_benefit_3 }}
              </p>
            </div>
          {% endif %}

          {% if section.settings.benefit_4 != blank %}
            <div class="comparison-v2__benefit-item-{{ section.id }}">
              <div class="comparison-v2__x-icon-{{ section.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </div>
              <p class="comparison-v2__benefit-text-{{ section.id }} comparison-v2__others-label-{{ section.id }}">
                {{ section.settings.others_benefit_4 }}
              </p>
            </div>
          {% endif %}

          {% if section.settings.benefit_5 != blank %}
            <div class="comparison-v2__benefit-item-{{ section.id }}">
              <div class="comparison-v2__x-icon-{{ section.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </div>
              <p class="comparison-v2__benefit-text-{{ section.id }} comparison-v2__others-label-{{ section.id }}">
