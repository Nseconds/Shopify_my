            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</comparison-v2-{{ section.id | downcase | replace: '_', '-' }}>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const tagName = 'comparison-v2-' + sectionId.toLowerCase().replace(/_/g, '-');
    
    class ComparisonV2 extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const headlines = this.querySelectorAll('.comparison-v2__headline-' + sectionId);
        headlines.forEach((headline, index) => {
          if (index > 0) {
            headline.setAttribute('aria-hidden', 'true');
          }
        });
      }
    }

    customElements.define(tagName, ComparisonV2);
  })();
</script>

{% schema %}
{
  "name": "Brand comparison v2",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "section_padding_desktop",
      "label": "Desktop padding",
      "min": 20,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_mobile",
      "label": "Mobile padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_row_gap",
      "label": "Mobile row gap",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Left column"
    },
    {
      "type": "text",
