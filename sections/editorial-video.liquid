{% liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign btn_label = section.settings.button_label
  assign btn_link = section.settings.button_link
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0

  if section.settings.use_custom_colors
    assign ev_text_color = section.settings.text_color
    assign ev_btn_bg = section.settings.button_bg
    assign ev_btn_text = section.settings.button_text_color
  else
    assign ev_text_color = section.settings.color_scheme.settings.foreground
    assign ev_btn_bg = section.settings.color_scheme.settings.primary_button_background
    assign ev_btn_text = section.settings.color_scheme.settings.primary_button_text
  endif
%}

{% style %}
  #shopify-section-{{ section.id }} {
    --ev-overlay-opacity: {{ overlay_opacity }};
    --ev-min-height: {{ section.settings.min_height }}px;
    --ev-text-color: {{ ev_text_color }};
    --ev-btn-bg: {{ ev_btn_bg }};
    --ev-btn-text: {{ ev_btn_text }};
  }
{% endstyle %}

<div class="editorial-video spacing-style color-{{ section.settings.color_scheme }}" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="editorial-video__media" data-forge-slot-id="fallback_image"{% if section.settings.fallback_image == blank %} data-forge-slot-blank="true"{% endif %}>
    {% if section.settings.video %}
      {{ section.settings.video | video_tag: class: 'editorial-video__vid', autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
    {% elsif section.settings.fallback_image %}
      {{
        section.settings.fallback_image
        | image_url: width: 2000
        | image_tag:
          class: 'editorial-video__img',
          loading: 'eager',
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw'
      }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial-video__img editorial-video__img--placeholder' }}
    {% endif %}
    <div class="editorial-video__overlay"></div>
  </div>

  <div class="editorial-video__content">
    {% if subheading != blank %}
      <p class="editorial-video__subheading">{{ subheading }}</p>
    {% endif %}
    {% if heading != blank %}
      <h2 class="editorial-video__heading">{{ heading }}</h2>
    {% endif %}
    {% if btn_label != blank %}
      <a href="{{ btn_link | default: '/collections/all' }}" class="editorial-video__btn">
        {{ btn_label }}
      </a>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .editorial-video {
    position: relative;
    min-height: var(--ev-min-height, 600px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .editorial-video__media {
    position: absolute;
    inset: 0;
  }

  .editorial-video__vid,
  .editorial-video__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .editorial-video__img--placeholder {
    background: #d8d0c8;
  }

  .editorial-video__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--ev-overlay-opacity, 0.4));
  }

  .editorial-video__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 24px;
    max-width: 800px;
  }

  .editorial-video__subheading {
    margin: 0 0 16px 0;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ev-text-color, #ffffff);
    opacity: 0.9;
  }

  .editorial-video__heading {
    margin: 0 0 32px 0;
    font-family: var(--font-heading--family, inherit);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ev-text-color, #ffffff);
    text-transform: uppercase;
  }

  .editorial-video__btn {
    display: inline-block;
    padding: 12px 28px;
    background: var(--ev-btn-bg, #ffffff);
    color: var(--ev-btn-text, #000000);
    border: none;
    border-radius: var(--style-border-radius-buttons-primary, 0px);
    font-family: var(--button-font-family, var(--font-body--family, inherit));
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: var(--button-text-case, uppercase);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .editorial-video__btn:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 989px) {
    .editorial-video {
      min-height: calc(var(--ev-min-height, 600px) * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .editorial-video {
      min-height: calc(var(--ev-min-height, 600px) * 0.65);
    }
    .editorial-video__content {
      padding: 0 16px;
    }
    .editorial-video__heading {
      margin-bottom: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial Video Hero",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Autoplays, muted, and loops."
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback image",
      "info": "Displays while video loads or on unsupported devices."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Available Now"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the Look"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "info": "Override the color scheme for this section.",
      "default": false
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min height (desktop)",
      "min": 400,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "default": 800
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Editorial Video Hero",
      "settings": {
        "heading": "New Collection",
        "subheading": "Available Now",
        "button_label": "Shop the Look",
        "overlay_opacity": 40,
        "min_height": 800
      }
    }
  ]
}
{% endschema %}
