{%- liquid
  assign title = section.settings.title
  if section.settings.use_custom_colors
    assign ben_icon    = section.settings.icon_color
    assign ben_card_bg = section.settings.card_bg_color
    assign ben_accent  = section.settings.accent_color
    assign ben_hl_bg   = section.settings.highlight_bg_color
    assign ben_text    = 'var(--color-foreground)'
  elsif settings.style_mode == 'gradient'
    assign ben_card_bg = 'var(--color-card-gradient)'
    assign ben_icon    = 'var(--color-gradient-text)'
    assign ben_accent  = 'var(--color-gradient-1)'
    assign ben_hl_bg   = 'var(--color-card-gradient)'
    assign ben_text    = 'var(--color-gradient-text)'
  else
    assign ben_icon    = section.settings.color_scheme.settings.primary
    assign ben_card_bg = 'var(--color-card-background)'
    assign ben_accent  = section.settings.color_scheme.settings.primary
    assign ben_hl_bg   = 'var(--color-card-background)'
    assign ben_text    = 'var(--color-foreground)'
  endif
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --benefits-icon-color: {{ ben_icon }};
    --benefits-card-bg: {{ ben_card_bg }};
    --benefits-card-text: {{ ben_text }};
    --benefits-border-radius: var(--style-border-radius-cards);
    --benefits-accent-color: {{ ben_accent }};
    --benefits-highlight-bg: {{ ben_hl_bg }};
  }
  #shopify-section-{{ section.id }} .benefits__card-inner {
    color: var(--benefits-card-text);
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="benefits section color-{{ section.settings.color_scheme }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="benefits__container container" style="{% unless section.settings.full_width %}max-width: {{ section.settings.section_width }}px;{% endunless %}">

    {%- if title != blank -%}
      <div class="benefits__title rte">{{ title }}</div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="benefits__grid">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'benefit' -%}
              <div class="benefits__card" {{ block.shopify_attributes }}>
                <div class="benefits__card-inner">
                  {%- if block.settings.icon != blank -%}
                    <div class="benefits__icon">
                      {{ block.settings.icon }}
                    </div>
                  {%- endif -%}

                  <div class="benefits__content">
                    {%- if block.settings.title != blank -%}
                      <h3 class="benefits__card-title">{{ block.settings.title }}</h3>
                    {%- endif -%}

                    {%- if block.settings.description != blank -%}
                      <div class="benefits__description rte">{{ block.settings.description }}</div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  .benefits {
    width: 100%;
    overflow: hidden;
  }

  .benefits__container {
    margin: 0 auto;
    padding: 0 20px;
  }

  .benefits__title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin: 0 0 48px 0;
    line-height: 1.2;
  }

  .benefits__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .benefits__card {
    position: relative;
  }

  .benefits__card-inner {
    height: 100%;
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: flex-start;
    padding: 32px;
    background: var(--benefits-card-bg);
    border-radius: var(--benefits-border-radius);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .benefits__card:hover .benefits__card-inner {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .benefits__icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .benefits__icon svg {
    width: 100%;
    height: 100%;
    stroke: var(--benefits-icon-color);
    fill: none;
    stroke-width: 2;
  }

  .benefits__content {
    flex: 1;
    min-width: 0;
  }

  .benefits__card-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 8px 0;
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .benefits__description {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.8;
    margin: 0;
  }

  .benefits__description p {
    margin: 0;
  }

  @media (max-width: 989px) {
    .benefits__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (min-width: 990px) and (max-width: 1199px) {
    .benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 749px) {
    .benefits__title {
      font-size: 2rem;
      margin-bottom: 32px;
    }

    .benefits__card-inner {
      padding: 24px;
      gap: 16px;
    }

    .benefits__icon {
      width: 56px;
      height: 56px;
    }

    .benefits__card-title {
      font-size: 1.125rem;
    }

    .benefits__description {
      font-size: 0.875rem;
    }
  }
{% endstylesheet %}

{% schema %}
