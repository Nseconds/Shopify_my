      "type": "inline_richtext",
      "id": "block_3_title",
      "label": "Block 3 title",
      "default": "Skin Compatibility"
    },
    {
      "type": "richtext",
      "id": "block_3_text",
      "label": "Block 3 text",
      "default": "<p>Dermatologically tested for sensitive skin. Non-comedogenic and fragrance-free.</p>"
    },
    {
      "type": "range",
      "id": "block_title_size",
      "label": "Block title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "block_title_spacing",
      "label": "Block title spacing",
      "min": 5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 10
