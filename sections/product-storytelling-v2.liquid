      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f6",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2c2c2c",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    }
  ],
  "presets": [
    {
      "name": "Product storytelling"
    }
  ]
}
{% endschema %}
