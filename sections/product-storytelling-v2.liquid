    {
      "type": "range",
      "id": "divider_width",
      "label": "Divider width",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#e0e0e0"
    ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Closing statement"
    },
    {
      "type": "inline_richtext",
      "id": "closing_text",
      "label": "Closing text",
      "default": "Precision formulated. Thoughtfully designed."
    },
    {
      "type": "range",
      "id": "closing_size",
      "label": "Closing size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
