{% render 'pastel-scalloped' %}
{% liquid
  assign heading = section.settings.heading
  assign primary_button = section.settings.primary_button
  assign primary_link = section.settings.primary_link
  assign secondary_button = section.settings.secondary_button
  assign secondary_link = section.settings.secondary_link
  assign hero_image = section.settings.hero_image
  assign hero_image_url = section.settings.hero_image_url
  assign benefit_blocks = section.blocks | where: 'type', 'benefit'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="pastel-hero-2 section section--full-width color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="pastel-hero-2__media" aria-hidden="true">
    {% if hero_image != blank %}
      <img
        src="{{ hero_image | image_url: width: 2400 }}"
        alt=""
        width="2400"
        height="1350"
        loading="eager"
        class="pastel-hero-2__bg"
      >
    {% elsif hero_image_url != blank %}
      {% # theme-check-disable RemoteAsset %}
      <img
        src="{{ hero_image_url }}"
        alt=""
        width="2400"
        height="1350"
        loading="eager"
        class="pastel-hero-2__bg"
      >
      {% # theme-check-enable RemoteAsset %}
    {% endif %}
    <div class="pastel-hero-2__overlay"></div>
  </div>

  <div class="pastel-hero-2__inner">
    <div class="pastel-hero-2__content">
      {% if heading != blank %}
        <h1 class="pastel-hero-2__heading">{{ heading }}</h1>
      {% endif %}

      {% if benefit_blocks.size > 0 %}
        <ul class="pastel-hero-2__pills">
          {% for block in benefit_blocks limit: 2 %}
            <li class="pastel-hero-2__pill" {{ block.shopify_attributes }}>
              <span class="pastel-hero-2__pill-icon" aria-hidden="true">
                <svg viewBox="0 0 32 20" fill="currentColor" focusable="false">
                  <path d="M25.5 19.5H8.5C3.81 19.5 0 15.69 0 11s3.81-8.5 8.5-8.5c.41 0 .82.03 1.22.09C11.05 1.04 13.4 0 16 0c3.84 0 7.13 2.27 8.66 5.55.27-.03.55-.05.84-.05C29.2 5.5 32 8.3 32 11.75s-2.8 7.75-6.5 7.75z"/>
                </svg>
              </span>
              <span class="pastel-hero-2__pill-text{% if block.settings.bold %} pastel-hero-2__pill-text--bold{% endif %}">{{ block.settings.text }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      <div class="pastel-hero-2__buttons">
        {% if primary_button != blank %}
          <a href="{{ primary_link | default: '#' }}" class="pastel-hero-2__btn pastel-hero-2__btn--primary">
            {{ primary_button }}
          </a>
        {% endif %}
        {% if secondary_button != blank %}
          <a href="{{ secondary_link | default: '#' }}" class="pastel-hero-2__btn pastel-hero-2__btn--secondary">
            {{ secondary_button }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .pastel-hero-2 {
    grid-column: 1 / -1;
    position: relative;
    isolation: isolate;
    aspect-ratio: 16 / 9;
    min-height: 460px;
    max-height: min(80vh, 760px);
    overflow: hidden;
    background: var(--color-background);
  }

  .pastel-hero-2__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .pastel-hero-2__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .pastel-hero-2__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--color-background) 0%,
      color-mix(in srgb, var(--color-background) 55%, transparent) 35%,
      transparent 65%
    );
    opacity: 0.72;
  }

  .pastel-hero-2__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--page-width, 1440px);
    margin: 0 auto;
    padding-block: 64px;
    padding-inline: var(--page-margin, 24px);
    box-sizing: border-box;
  }

  .pastel-hero-2__content {
    max-width: 520px;
    text-align: left;
  }

  .pastel-hero-2__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 800;
    color: var(--color-foreground-heading);
    margin: 0 0 24px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .pastel-hero-2__pills {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .pastel-hero-2__pill {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body--family);
    font-size: 17px;
    color: var(--color-foreground);
    font-weight: 500;
  }

  .pastel-hero-2__pill-icon {
    flex-shrink: 0;
    width: 28px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }

  .pastel-hero-2__pill-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .pastel-hero-2__pill-text {
    line-height: 1.3;
  }

  .pastel-hero-2__pill-text--bold {
    font-weight: 700;
  }

  .pastel-hero-2__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .pastel-hero-2__btn {
    display: inline-block;
    padding: 16px 32px;
    border-radius: 9999px;
    font-family: var(--font-heading--family);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: opacity 0.2s, transform 0.2s, background 0.2s;
  }

  .pastel-hero-2__btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .pastel-hero-2__btn--primary {
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
    border: 2px solid transparent;
  }

  .pastel-hero-2__btn--primary:hover {
    background: var(--color-primary-button-hover-background);
  }

  .pastel-hero-2__btn--secondary {
    background: transparent;
    color: var(--color-primary-button-background);
    border: 2px solid var(--color-primary-button-background);
  }

  @media screen and (max-width: 989px) {
    .pastel-hero-2 {
      /* Tablet: keep the 16:9 ratio but allow a bit more room for the overlay copy */
      aspect-ratio: 16 / 10;
      min-height: 480px;
    }

    .pastel-hero-2__overlay {
      background: linear-gradient(
        to bottom,
        var(--color-background) 0%,
        color-mix(in srgb, var(--color-background) 45%, transparent) 50%,
        var(--color-background) 100%
      );
      opacity: 0.72;
    }

    .pastel-hero-2__content {
      max-width: 100%;
      text-align: center;
      margin: 0 auto;
    }

    .pastel-hero-2__pills {
      align-items: flex-start;
      max-width: 280px;
      margin-left: auto;
      margin-right: auto;
    }

    .pastel-hero-2__buttons {
      justify-content: center;
    }
  }

  @media screen and (max-width: 749px) {
    .pastel-hero-2 {
      /* Mobile: drop the strict aspect ratio so copy never gets squeezed */
      aspect-ratio: auto;
      min-height: max(640px, 80vh);
    }

    .pastel-hero-2__overlay {
      background: linear-gradient(
        to bottom,
        var(--color-background) 0%,
        var(--color-background) 18%,
        transparent 36%,
        transparent 60%,
        color-mix(in srgb, var(--color-background) 70%, transparent) 80%,
        var(--color-background) 100%
      );
      opacity: 0.85;
    }

    .pastel-hero-2__inner {
      padding-block: 32px;
      display: flex;
      min-height: inherit;
      box-sizing: border-box;
    }

    .pastel-hero-2__content {
      display: flex;
      flex-direction: column;
      flex: 1;
      width: 100%;
    }

    .pastel-hero-2__heading {
      font-size: clamp(2rem, 7vw, 2.75rem);
      margin-bottom: 0;
    }

    .pastel-hero-2__pills {
      margin-top: auto;
      margin-bottom: 20px;
    }

    .pastel-hero-2__buttons {
      flex-direction: column;
      width: 100%;
    }

    .pastel-hero-2__btn {
      width: 100%;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero (v2)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image",
      "info": "Landscape lifestyle/product image used as the full-bleed background. 16:9 recommended."
    },
    {
      "type": "text",
      "id": "hero_image_url",
      "label": "Hero background image URL (fallback)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THREE NEW MOODS. ONE GOOD DAY."
    },
    {
      "type": "text",
      "id": "primary_button",
      "label": "Primary button",
      "default": "SHOP THE NEW MOODS"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button",
      "label": "Secondary button",
      "default": "SHOP ALL"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "max_blocks": 2,
  "blocks": [
    {
      "type": "benefit",
      "name": "Copy point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Get 51% Off Subscriptions."
        },
        {
          "type": "checkbox",
          "id": "bold",
          "label": "Bold text",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero (v2)",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Get 51% Off Subscriptions." } },
        { "type": "benefit", "settings": { "text": "Get 30% Off Bundles." } }
      ]
    }
  ]
}
{% endschema %}
