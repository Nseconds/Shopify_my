{% liquid
  assign max_products = section.settings.max_products | default: 6
  assign collection = section.settings.collection
  
  if collection != blank
    assign products_to_show = collection.products
  else
    assign products_to_show = collections['all'].products
  endif
%}

{% style %}
  #shopify-section-{{ section.id }} {
    --br-card-width: {{ section.settings.card_width }}px;
    --br-gap: {{ section.settings.gap }}px;
    --section-border-radius: {{ section.settings.section_border_radius }}px;
  }

  /* Override card border-radius with section-level setting */
  #shopify-section-{{ section.id }} .bestseller-card {
    border-radius: {{ section.settings.section_border_radius }}px !important;
  }

  #shopify-section-{{ section.id }} .bestsellers-row__track {
    display: flex;
    gap: var(--br-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 8px 0;
  }

  #shopify-section-{{ section.id }} .bestsellers-row__track::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .bestseller-card {
    flex: 0 0 var(--br-card-width);
    scroll-snap-align: start;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --br-card-width: 200px;
    }
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    bestsellers-row
    {% if section.settings.show_card_shadow %}bestsellers-row--card-shadow{% endif %}
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.show_heading %}
    <div class="bestsellers-row__header">
      <div class="bestsellers-row__header-content" data-alignment="{{ section.settings.heading_alignment | default: 'center' }}">
        <h2 class="bestsellers-row__title">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="bestsellers-row__subtitle">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
      {% if section.settings.show_view_all %}
        <a href="{{ collection.url | default: '/collections/all' }}" class="bestsellers-row__view-all link">
          {{ section.settings.view_all_text | default: 'View All' }} →
        </a>
      {% endif %}
    </div>
  {% endif %}

  <div class="bestsellers-row__wrapper">
    <div class="bestsellers-row__track">
      {% if products_to_show.size > 0 %}
        {% for product in products_to_show limit: max_products %}
          <div class="bestseller-card">
            <a href="{{ product.url }}" class="bestseller-card__link">
              <div class="bestseller-card__image-wrapper">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 400 | image_tag: 
                    class: 'bestseller-card__image',
                    loading: 'lazy',
                    widths: '200, 300, 400'
                  }}
                {% else %}
                  <div class="bestseller-card__placeholder">
                    {{ 'product-1' | placeholder_svg_tag: 'bestseller-card__placeholder-svg' }}
                  </div>
                {% endif %}
                {% if section.settings.show_badge and forloop.index <= 3 %}
                  <span class="bestseller-card__badge">#{{ forloop.index }}</span>
                {% endif %}
              </div>
              <div class="bestseller-card__content">
                <h3 class="bestseller-card__name">{{ product.title }}</h3>
                <div class="bestseller-card__price">
                  {% if product.compare_at_price > product.price %}
                    <span class="bestseller-card__price-sale">{{ product.price | money }}</span>
                    <span class="bestseller-card__price-compare">{{ product.compare_at_price | money }}</span>
                  {% else %}
                    <span>{{ product.price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..max_products) %}
          {% assign placeholder_variant = i | modulo: 6 | plus: 1 %}
          {% assign placeholder_name = 'product-' | append: placeholder_variant %}
          <div class="bestseller-card bestseller-card--placeholder">
            <div class="bestseller-card__image-wrapper">
              <div class="bestseller-card__placeholder">
                {{ placeholder_name | placeholder_svg_tag: 'bestseller-card__placeholder-svg' }}
              </div>
              {% if section.settings.show_badge and i <= 3 %}
                <span class="bestseller-card__badge">#{{ i }}</span>
              {% endif %}
            </div>
            <div class="bestseller-card__content">
              <h3 class="bestseller-card__name">Product</h3>
              <div class="bestseller-card__price">
                <span>$29.99</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .bestsellers-row {
    width: 100%;
  }

  .bestsellers-row__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 24px;
    gap: 16px;
    position: relative;
  }

  .bestsellers-row__header-content[data-alignment="center"] {
    flex: 1;
    text-align: center;
  }

  .bestsellers-row__header-content[data-alignment="center"] ~ .bestsellers-row__view-all {
    position: absolute;
    right: 0;
  }

  .bestsellers-row__header-content {
    flex: 1;
    text-align: center;
  }

  .bestsellers-row__header-content[data-alignment="left"] {
    text-align: left;
  }

  .bestsellers-row__header-content[data-alignment="right"] {
    text-align: right;
  }

  .bestsellers-row__title {
    margin: 0;
  }

  .bestsellers-row__subtitle {
    margin: 8px 0 0 0;
    opacity: 0.7;
  }

  .bestsellers-row__view-all {
    white-space: nowrap;
    font-weight: 500;
  }

  .bestsellers-row__wrapper {
    position: relative;
  }

  .bestseller-card {
    background: var(--color-background);
    border-radius: var(--section-border-radius);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bestsellers-row--card-shadow .bestseller-card {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .bestseller-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .bestsellers-row--card-shadow .bestseller-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .bestseller-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .bestseller-card__image-wrapper {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-background);
  }

  .bestseller-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .bestseller-card:hover .bestseller-card__image {
    transform: scale(1.05);
  }

  .bestseller-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-background);
  }

  .bestseller-card__placeholder-svg {
    width: 50%;
    height: auto;
    opacity: 0.3;
  }

  .bestseller-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--color-accent);
    color: var(--color-accent-contrast, #fff);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: var(--style-border-radius-global);
  }

  .bestseller-card__content {
    padding: 16px;
  }

  .bestseller-card__name {
    margin: 0 0 8px 0;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bestseller-card__price {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .bestseller-card__price-sale {
    color: var(--color-accent);
    margin-right: 8px;
  }

  .bestseller-card__price-compare {
    text-decoration: line-through;
    opacity: 0.5;
  }

  @media screen and (max-width: 749px) {
    .bestsellers-row__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .bestsellers-row__header-content[data-alignment="center"] {
      align-self: center;
      text-align: center;
    }

    .bestsellers-row__header-content[data-alignment="right"] {
      align-self: flex-end;
    }

    .bestsellers-row__header-content[data-alignment="center"] ~ .bestsellers-row__view-all {
      position: static;
      align-self: center;
      margin-top: 8px;
    }

    .bestseller-card__content {
      padding: 12px;
    }

    .bestseller-card__name {
      font-size: 0.9rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bestsellers Row",
  "class": "ui-test-bestsellers-row",
  "blocks": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave empty to show all products"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our most popular products"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All text",
      "default": "View All"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show ranking badge",
      "default": true,
      "info": "Shows #1, #2, #3 badges on top products"
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card width",
      "min": 180,
      "max": 320,
      "step": 10,
      "unit": "px",
      "default": 240
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_card_shadow",
      "label": "Show card shadow",
      "default": false,
      "info": "Adds a subtle shadow to each card"
    },
    {
      "type": "header",
      "content": "Border Radius"
    },
    {
      "type": "select",
      "id": "section_border_radius",
      "label": "Corner style",
      "info": "Applies to all cards within this section",
      "options": [
        {
          "value": "0",
          "label": "Sharp"
        },
        {
          "value": "4",
          "label": "Slightly rounded"
        },
        {
          "value": "8",
          "label": "Rounded"
        },
        {
          "value": "12",
          "label": "Very rounded"
        },
        {
          "value": "16",
          "label": "Extra rounded"
        }
      ],
      "default": "8"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Bestsellers Row",
      "category": "Products",
      "settings": {
        "show_heading": true,
        "heading": "Bestsellers",
        "subheading": "Our most popular products",
        "heading_alignment": "center",
        "show_view_all": true,
        "view_all_text": "View All",
        "max_products": 6,
        "show_badge": true,
        "card_width": 240,
        "gap": 16,
        "section_border_radius": "8",
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    }
  ]
}
{% endschema %}
