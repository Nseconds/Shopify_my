{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}
{% assign ai_gen_id_js = section.id | replace: '_', '' | replace: '-', '' | downcase %}
{%- liquid
  if section.settings.use_custom_colors
    assign sc_bg     = section.settings.background_color
    assign sc_text   = section.settings.heading_color
    assign sc_body   = section.settings.question_color
    assign sc_accent = section.settings.icon_color
    assign sc_border = section.settings.divider_color
  elsif settings.style_mode == 'gradient'
    assign sc_bg     = 'var(--color-background)'
    assign sc_text   = 'var(--color-foreground)'
    assign sc_body   = 'var(--color-foreground)'
    assign sc_accent = 'var(--color-gradient-1)'
    assign sc_border = 'var(--color-border)'
  else
    assign sc_bg     = section.settings.color_scheme.settings.background
    assign sc_text   = section.settings.color_scheme.settings.foreground
    assign sc_body   = section.settings.color_scheme.settings.foreground
    assign sc_accent = section.settings.color_scheme.settings.primary
    assign sc_border = section.settings.color_scheme.settings.border
  endif
-%}
{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ section.settings.section_padding_top }}px {{ section.settings.section_padding_horizontal }}px {{ section.settings.section_padding_bottom }}px;
    background: {{ sc_bg }};
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ sc_text }};
    margin: 0 0 {{ section.settings.heading_spacing }}px;
    text-align: {{ section.settings.heading_alignment }};
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
  }

  .ai-faq-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border-bottom: {{ section.settings.divider_width }}px solid {{ sc_border }};
  }

  .ai-faq-item-{{ ai_gen_id }}:first-child {
    border-top: {{ section.settings.divider_width }}px solid {{ sc_border }};
  }

  .ai-faq-question-button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ section.settings.question_padding_vertical }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 24px;
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    font-size: {{ section.settings.question_size }}px;
    color: {{ sc_body }};
    font-weight: {{ section.settings.question_weight }};
    letter-spacing: {{ section.settings.question_letter_spacing }}px;
    line-height: 1.5;
    flex: 1;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    position: relative;
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }}::before,
  .ai-faq-icon-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    background-color: {{ sc_accent }};
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }}::before {
    width: 100%;
    height: {{ section.settings.icon_thickness }}px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .ai-faq-icon-{{ ai_gen_id }}::after {
    width: {{ section.settings.icon_thickness }}px;
    height: 100%;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }}::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding-top 0.4s ease;
    padding-top: 0;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    font-size: {{ section.settings.answer_size }}px;
    color: var(--color-foreground, {{ section.settings.answer_color }});
    line-height: 1.7;
    padding-bottom: {{ section.settings.answer_padding_bottom }}px;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 1000px;
    padding-top: {{ section.settings.answer_padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-section-{{ ai_gen_id }} {
      padding: {{ section.settings.section_padding_top | times: 0.6 }}px {{ section.settings.section_padding_horizontal | times: 0.6 }}px {{ section.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_size | times: 0.7 }}px;
      margin-bottom: {{ section.settings.heading_spacing | times: 0.7 }}px;
    }

    .ai-faq-question-text-{{ ai_gen_id }} {
      font-size: {{ section.settings.question_size | times: 0.9 }}px;
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: {{ section.settings.answer_size | times: 0.9 }}px;
    }

    .ai-faq-question-button-{{ ai_gen_id }} {
      gap: 16px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}">
  <div class="ai-faq-container-{{ ai_gen_id }}">
    {% if section.settings.heading != blank %}
      <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ section.settings.heading }}</h2>
    {% endif %}

    <ul class="ai-faq-list-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign question_key = 'question_' | append: i
          assign answer_key = 'answer_' | append: i
          assign question = section.settings[question_key]
          assign answer = section.settings[answer_key]
        %}

        {% if question != blank and answer != blank %}
          <li class="ai-faq-item-{{ ai_gen_id }}{% if forloop.index == 1 and section.settings.first_item_open %} active{% endif %}" data-faq-item>
            <button
              class="ai-faq-question-button-{{ ai_gen_id }}"
              aria-expanded="{% if forloop.index == 1 and section.settings.first_item_open %}true{% else %}false{% endif %}"
              data-faq-button
            >
              <span class="ai-faq-question-text-{{ ai_gen_id }}">{{ question }}</span>
              <span class="ai-faq-icon-{{ ai_gen_id }}" aria-hidden="true"></span>
            </button>
            <div class="ai-faq-answer-{{ ai_gen_id }}" data-faq-answer>
              <div class="ai-faq-answer-content-{{ ai_gen_id }}">{{ answer }}</div>
            </div>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    const allowMultipleOpen = {{ section.settings.allow_multiple_open | json }};
    const answerPaddingBottom = {{ section.settings.answer_padding_bottom }};

    class FaqAccordion{{ ai_gen_id_js }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('[data-faq-button]');
          const answer = item.querySelector('[data-faq-answer]');

          if (!button || !answer) return;

          // Set initial state for items that should be open
          if (item.classList.contains('active')) {
            answer.style.paddingTop = answerPaddingBottom + 'px';
            answer.style.maxHeight = answer.scrollHeight + 'px';
          }

          button.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            
            const isActive = item.classList.contains('active');

            if (isActive) {
              this.closeItem(item, button, answer);
            } else {
              if (!allowMultipleOpen) {
                this.items.forEach((otherItem) => {
                  if (otherItem !== item && otherItem.classList.contains('active')) {
                    const otherButton = otherItem.querySelector('[data-faq-button]');
                    const otherAnswer = otherItem.querySelector('[data-faq-answer]');
                    if (otherButton && otherAnswer) {
                      this.closeItem(otherItem, otherButton, otherAnswer);
                    }
                  }
                });
              }
              this.openItem(item, button, answer);
            }
          });
        });
      }

      openItem(item, button, answer) {
        item.classList.add('active');
        button.setAttribute('aria-expanded', 'true');
        answer.style.paddingTop = answerPaddingBottom + 'px';
        // Use a large value to ensure content is visible
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }

      closeItem(item, button, answer) {
        item.classList.remove('active');
        button.setAttribute('aria-expanded', 'false');
        answer.style.paddingTop = '0';
        answer.style.maxHeight = '0';
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id_js }});
  })();
</script>

{%- capture faq_ld -%}
{%- assign faq_first = true -%}
{%- for faq_i in (1..6) -%}
{%- assign faq_qk = 'question_' | append: faq_i -%}{%- assign faq_ak = 'answer_' | append: faq_i -%}
{%- assign faq_fq = section.settings[faq_qk] -%}{%- assign faq_fa = section.settings[faq_ak] -%}
{%- if faq_fq != blank and faq_fa != blank -%}
{%- unless faq_first -%},{%- endunless -%}
{"@type":"Question","name":{{ faq_fq | json }},"acceptedAnswer":{"@type":"Answer","text":{{ faq_fa | strip_html | json }}}}
{%- assign faq_first = false -%}
{%- endif -%}
{%- endfor -%}
{%- endcapture -%}
{%- assign faq_ld_s = faq_ld | strip -%}
{%- if faq_ld_s != '' -%}
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{{ faq_ld_s }}]}
</script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ accordion v2",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Frequently Asked Questions</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        }
      ],
      "default": "300"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Letter spacing",
      "min": -2,
      "max": 4,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#141414"
    ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Bottom spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Questions"
    },
    {
      "type": "inline_richtext",
      "id": "question_1",
      "label": "Question 1",
      "default": "What materials are your products made from?"
    },
    {
      "type": "richtext",
      "id": "answer_1",
      "label": "Answer 1",
      "default": "<p>Our activewear is crafted from premium, sustainable fabrics including organic cotton, recycled polyester, and innovative moisture-wicking blends designed for optimal performance and comfort.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "question_2",
      "label": "Question 2",
      "default": "How do I find my perfect size?"
    },
    {
      "type": "richtext",
      "id": "answer_2",
      "label": "Answer 2",
      "default": "<p>We recommend consulting our detailed size guide available on each product page. Our pieces are designed with a true-to-size fit, but if you're between sizes, we suggest sizing up for a more relaxed feel.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "question_3",
      "label": "Question 3",
      "default": "What is your return policy?"
    },
    {
      "type": "richtext",
      "id": "answer_3",
      "label": "Answer 3",
      "default": "<p>We offer a 30-day return window for unworn, unwashed items with original tags attached. Returns are free for domestic orders, and we'll provide a full refund or exchange.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "question_4",
      "label": "Question 4",
      "default": "How should I care for my activewear?"
    },
    {
      "type": "richtext",
      "id": "answer_4",
      "label": "Answer 4",
      "default": "<p>Machine wash cold with like colors, avoid fabric softeners, and hang dry or tumble dry on low. This helps maintain the integrity of the technical fabrics and extends the life of your pieces.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "question_5",
      "label": "Question 5",
      "default": "Do you offer international shipping?"
    },
    {
      "type": "richtext",
      "id": "answer_5",
      "label": "Answer 5",
      "default": "<p>Yes, we ship worldwide. International shipping times vary by destination, typically ranging from 7-14 business days. Customs fees may apply depending on your country.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "question_6",
      "label": "Question 6",
      "default": "Are your products sustainable?"
    },
    {
      "type": "richtext",
      "id": "answer_6",
      "label": "Answer 6",
      "default": "<p>Sustainability is at the core of our brand. We use eco-friendly materials, ethical manufacturing practices, and minimal packaging to reduce our environmental impact.</p>"
    },
    {
      "type": "header",
      "content": "Question style"
    },
    {
      "type": "range",
      "id": "question_size",
      "label": "Size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "question_weight",
      "label": "Weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "question_letter_spacing",
      "label": "Letter spacing",
      "min": -1,
      "max": 2,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Color",
      "default": "#141414"
    ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "range",
      "id": "question_padding_vertical",
      "label": "Vertical padding",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Answer style"
    },
    {
      "type": "range",
      "id": "answer_size",
      "label": "Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "answer_color",
      "label": "Color",
      "default": "#666666"
    ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "range",
      "id": "answer_padding_bottom",
      "label": "Bottom padding",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_thickness",
      "label": "Thickness",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "unit": "px",
      "default": 1.5
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color",
      "default": "#141414"
    ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Dividers"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Width",
      "min": 0,
      "max": 4,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Color",
      "default": "#E0E0E0"
    ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "first_item_open",
      "label": "Open first item by default",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "allow_multiple_open",
      "label": "Allow multiple items open",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    { "type": "checkbox", "id": "use_custom_colors", "label": "Use custom colors", "default": false },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF",
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion v2"
    }
  ]
}
{% endschema %}
