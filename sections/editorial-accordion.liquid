{% liquid
  if section.settings.use_custom_colors
    assign ea_text_color = section.settings.text_color
    assign ea_bg = section.settings.bg_color
    assign ea_border = section.settings.border_color
  else
    assign ea_text_color = section.settings.color_scheme.settings.foreground
    assign ea_bg = section.settings.color_scheme.settings.background
    assign ea_border = section.settings.color_scheme.settings.border
  endif
%}

{% style %}
  #shopify-section-{{ section.id }} {
    --ea-text-color: {{ ea_text_color }};
    --ea-bg: {{ ea_bg }};
    --ea-border: {{ ea_border }};
  }
{% endstyle %}

<div class="editorial-accordion spacing-style color-{{ section.settings.color_scheme }}" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="editorial-accordion__container">
    {% if section.settings.heading != blank %}
      <h2 class="editorial-accordion__main-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="editorial-accordion__list">
      {% for block in section.blocks %}
        {% if block.type == 'accordion_item' %}
          <details class="editorial-accordion__item" {{ block.shopify_attributes }}>
            <summary class="editorial-accordion__summary">
              <span class="editorial-accordion__heading">{{ block.settings.heading }}</span>
              <span class="editorial-accordion__icon">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7 1v12m-6-6h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
            </summary>
            <div class="editorial-accordion__content">
              <div class="editorial-accordion__content-inner">
                {{ block.settings.content }}
              </div>
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .editorial-accordion {
    width: 100vw;
    max-width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    box-sizing: border-box;
    background: var(--ea-bg);
    color: var(--ea-text-color);
  }

  .editorial-accordion__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--page-margin, 24px);
  }

  .editorial-accordion__main-heading {
    margin: 0 0 32px 0;
    font-family: var(--font-heading--family, inherit);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ea-text-color);
    text-align: center;
  }

  .editorial-accordion__list {
    border-top: 1px solid var(--ea-border);
  }

  .editorial-accordion__item {
    border-bottom: 1px solid var(--ea-border);
  }

  .editorial-accordion__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    transition: opacity 0.2s ease;
  }

  .editorial-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .editorial-accordion__summary:hover {
    opacity: 0.7;
  }

  .editorial-accordion__heading {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .editorial-accordion__icon {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  details[open] > .editorial-accordion__summary .editorial-accordion__icon {
    transform: rotate(45deg);
    color: #2da15f;
  }

  .editorial-accordion__content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease-out;
  }

  details[open] > .editorial-accordion__content {
    grid-template-rows: 1fr;
  }

  .editorial-accordion__content-inner {
    overflow: hidden;
    padding-bottom: 24px;
    font-size: 0.9rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  .editorial-accordion__content-inner p:first-child { margin-top: 0; }
  .editorial-accordion__content-inner p:last-child { margin-bottom: 0; }

  @media screen and (max-width: 749px) {
    .editorial-accordion__container {
      padding: 0 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial Accordion",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Details"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "info": "Override the color scheme for this section.",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top margin",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom margin",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "accordion_item",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Fit & Size"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Model is 6'1\" and wearing a size Medium. True to size fit.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Accordion",
      "blocks": [
        { "type": "accordion_item", "settings": { "heading": "Fit & Size" } },
        { "type": "accordion_item", "settings": { "heading": "Materials & Care" } },
        { "type": "accordion_item", "settings": { "heading": "Shipping & Returns" } }
      ]
    }
  ]
}
{% endschema %}
