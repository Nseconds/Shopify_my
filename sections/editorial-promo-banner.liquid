{% liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign btn_label = section.settings.button_label
  assign btn_link = section.settings.button_link
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0

  if section.settings.use_custom_colors
    assign epb_text_color = section.settings.text_color
    assign epb_btn_bg = section.settings.button_bg
    assign epb_btn_text = section.settings.button_text_color
  else
    assign epb_text_color = section.settings.color_scheme.settings.foreground
    assign epb_btn_bg = section.settings.color_scheme.settings.primary_button_background
    assign epb_btn_text = section.settings.color_scheme.settings.primary_button_text
  endif
%}

{% style %}
  #shopify-section-{{ section.id }} {
    --epb-min-height: {{ section.settings.min_height }}px;
    --epb-overlay-opacity: {{ overlay_opacity }};
    --epb-text-color: {{ epb_text_color }};
    --epb-btn-bg: {{ epb_btn_bg }};
    --epb-btn-text: {{ epb_btn_text }};
  }
{% endstyle %}

<div class="editorial-promo-banner spacing-style color-{{ section.settings.color_scheme }}" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="editorial-promo-banner__media" data-forge-slot-id="image"{% if section.settings.image == blank %} data-forge-slot-blank="true"{% endif %}>
    {% if section.settings.image %}
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          class: 'editorial-promo-banner__img',
          loading: 'lazy',
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw'
      }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'editorial-promo-banner__img editorial-promo-banner__img--placeholder' }}
    {% endif %}
    <div class="editorial-promo-banner__overlay"></div>
  </div>

  <div class="editorial-promo-banner__content">
    {% if heading != blank %}
      <p class="editorial-promo-banner__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="editorial-promo-banner__heading">{{ heading }}</h2>
    {% endif %}
    {% if subheading != blank %}
      <p class="editorial-promo-banner__subheading">{{ subheading }}</p>
    {% endif %}
    {% if btn_label != blank %}
      <a href="{{ btn_link | default: '/collections/all' }}" class="editorial-promo-banner__btn">
        {{ btn_label }}
      </a>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .editorial-promo-banner {
    position: relative;
    min-height: var(--epb-min-height, 400px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
  }

  .editorial-promo-banner__media {
    position: absolute;
    inset: 0;
  }

  .editorial-promo-banner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .editorial-promo-banner__img--placeholder {
    background: #d0c8be;
  }

  .editorial-promo-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--epb-overlay-opacity, 0.35));
  }

  .editorial-promo-banner__content {
    position: relative;
    z-index: 1;
    padding: 48px 24px;
    max-width: 640px;
    margin: 0 auto;
  }

  .editorial-promo-banner__eyebrow {
    margin: 0 0 8px 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--epb-text-color, #ffffff);
    opacity: 0.8;
  }

  .editorial-promo-banner__heading {
    margin: 0 0 16px 0;
    font-family: var(--font-heading--family, inherit);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: var(--epb-text-color, #ffffff);
    text-transform: uppercase;
  }

  .editorial-promo-banner__subheading {
    margin: 0 0 28px 0;
    font-size: 1rem;
    color: var(--epb-text-color, #ffffff);
    opacity: 0.85;
  }

  .editorial-promo-banner__btn {
    display: inline-block;
    padding: 12px 32px;
    background: var(--epb-btn-bg, #ffffff);
    color: var(--epb-btn-text, #000000);
    border-radius: var(--style-border-radius-buttons-primary, 0px);
    font-family: var(--button-font-family, var(--font-body--family, inherit));
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: var(--button-text-case, uppercase);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .editorial-promo-banner__btn:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .editorial-promo-banner {
      min-height: 300px;
    }
    .editorial-promo-banner__content {
      padding: 36px 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial Promo Banner",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Spring Sale"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Up to 50% Off"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "info": "Override the color scheme for this section.",
      "default": true
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min height",
      "min": 200,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Editorial Promo Banner",
      "settings": {
        "eyebrow": "Spring Sale",
        "heading": "Up to 50% Off",
        "button_label": "Shop Now",
        "use_custom_colors": true,
        "text_color": "#ffffff",
        "button_bg": "#ffffff",
        "button_text_color": "#000000",
        "overlay_opacity": 35,
        "min_height": 400
      }
    }
  ]
}
{% endschema %}
