{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}
{%- liquid
  if section.settings.use_custom_colors
    assign lt_bg     = section.settings.background_color
    assign lt_text   = section.settings.title_color
    assign lt_card   = section.settings.card_background
    assign lt_border = section.settings.card_border_color
    assign lt_quote  = section.settings.quote_color
    assign lt_name   = section.settings.name_color
    assign lt_star       = section.settings.star_color
    assign lt_avatar_bg  = section.settings.avatar_placeholder_bg
    assign lt_use_inset_card_ring = false
  elsif settings.style_mode == 'gradient'
    assign lt_bg         = section.settings.color_scheme.settings.background
    assign lt_text       = section.settings.color_scheme.settings.foreground
    assign lt_card       = 'var(--color-card-gradient)'
    assign lt_quote      = 'var(--color-gradient-text)'
    assign lt_name       = 'var(--color-gradient-text)'
    assign lt_star       = 'var(--color-gradient-text)'
    assign lt_avatar_bg  = 'var(--color-gradient-1)'
    assign lt_use_inset_card_ring = true
  else
    assign lt_bg         = section.settings.color_scheme.settings.background
    assign lt_text       = section.settings.color_scheme.settings.foreground
    assign lt_card       = 'var(--color-card-background)'
    assign lt_border     = section.settings.color_scheme.settings.border
    assign lt_use_inset_card_ring = false
    assign lt_quote      = section.settings.color_scheme.settings.foreground
    assign lt_name       = section.settings.color_scheme.settings.foreground
    assign lt_star       = section.settings.color_scheme.settings.primary
    assign lt_avatar_bg  = 'var(--color-card-background)'
  endif
-%}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ section.settings.section_padding }}px 0;
    background: {{ lt_bg }};
    overflow: hidden;
  }

  .ai-testimonials-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ section.settings.header_spacing }}px;
    padding: 0 20px;
  }

  .ai-testimonials-title-{{ ai_gen_id }} {
    font-family: var(--font-heading--family);
    font-size: {{ section.settings.title_size }}px;
    color: {{ lt_text }};
    margin: 0 0 12px;
    letter-spacing: 0.5px;
  }

  .ai-testimonials-subtitle-{{ ai_gen_id }} {
    font-family: var(--font-body--family);
    font-size: {{ section.settings.subtitle_size }}px;
    color: {{ lt_text }};
    margin: 0;
    opacity: 0.8;
  }

  .ai-testimonials-marquee-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-testimonials-marquee-row-{{ ai_gen_id }} {
    display: flex;
    gap: var(--style-gap-cards);
    animation: ai-testimonials-scroll-{{ ai_gen_id }} {{ section.settings.animation_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-testimonials-marquee-row-{{ ai_gen_id }}:not(:last-child) {
    margin-bottom: {{ section.settings.row_gap }}px;
  }

  @keyframes ai-testimonials-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-testimonials-card-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ section.settings.card_width }}px;
    padding: {{ section.settings.card_padding }}px;
    background: {{ lt_card }};
    border-radius: var(--style-border-radius-cards);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 16px;
    {% if lt_use_inset_card_ring and section.settings.card_border_width > 0 %}
    border: none;
    background-clip: padding-box;
    isolation: isolate;
    box-shadow:
      var(--style-shadow-card),
      inset 0 0 0 {{ section.settings.card_border_width }}px color-mix(in srgb, var(--color-gradient-text) 14%, transparent);
    {% else %}
    border: {{ section.settings.card_border_width }}px solid {{ lt_border }};
    box-shadow: var(--style-shadow-card);
    {% endif %}
  }

  .ai-testimonials-quote-{{ ai_gen_id }} {
    font-family: var(--font-body--family);
    font-size: {{ section.settings.quote_size }}px;
    line-height: 1.6;
    color: {{ lt_quote }};
    margin: 0;
  }

  .ai-testimonials-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-testimonials-avatar-{{ ai_gen_id }} {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: {{ lt_avatar_bg }};
  }

  .ai-testimonials-avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonials-avatar-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonials-avatar-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-testimonials-author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-testimonials-author-name-{{ ai_gen_id }} {
    font-family: var(--font-body--family);
    font-size: {{ section.settings.name_size }}px;
    color: {{ lt_name }};
    margin: 0;
    letter-spacing: 0.3px;
  }

  .ai-testimonials-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-testimonials-star-{{ ai_gen_id }} {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    color: {{ lt_star }};
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-{{ ai_gen_id }} {
      padding: {{ section.settings.section_padding | times: 0.6 }}px 0;
    }

    .ai-testimonials-title-{{ ai_gen_id }} {
      font-size: {{ section.settings.title_size | times: 0.7 }}px;
    }

    .ai-testimonials-subtitle-{{ ai_gen_id }} {
      font-size: {{ section.settings.subtitle_size | times: 0.85 }}px;
    }

    .ai-testimonials-card-{{ ai_gen_id }} {
      width: {{ section.settings.card_width | times: 0.85 }}px;
      padding: {{ section.settings.card_padding | times: 0.8 }}px;
    }

    .ai-testimonials-quote-{{ ai_gen_id }} {
      font-size: {{ section.settings.quote_size | times: 0.85 }}px;
    }

    .ai-testimonials-marquee-row-{{ ai_gen_id }}:not(:last-child) {
      margin-bottom: {{ section.settings.row_gap | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div
  id="shopify-section-{{ section.id }}"
  class="ai-testimonials-{{ ai_gen_id }} color-{{ section.settings.color_scheme }}"
  {{ section.shopify_attributes }}
>
  {% if section.settings.section_title != blank or section.settings.section_subtitle != blank %}
    <div class="ai-testimonials-header-{{ ai_gen_id }}">
      {% if section.settings.section_title != blank %}
        <h2 class="ai-testimonials-title-{{ ai_gen_id }}">{{ section.settings.section_title }}</h2>
      {% endif %}
      {% if section.settings.section_subtitle != blank %}
        <p class="ai-testimonials-subtitle-{{ ai_gen_id }}">{{ section.settings.section_subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-testimonials-marquee-wrapper-{{ ai_gen_id }}">
    {% for row in (1..2) %}
      {%- assign row_offset = row | minus: 1 | times: 6 -%}
      <div class="ai-testimonials-marquee-row-{{ ai_gen_id }}" data-row="{{ row }}">
        {% for duplicate in (1..2) %}
          {% assign is_first_dup = forloop.first %}
          {% for i in (1..6) %}
            {% assign inner_idx = forloop.index %}
            {% assign testimonial_index = row_offset | plus: inner_idx %}

            {% assign quote_key = 'testimonial_' | append: testimonial_index | append: '_quote' %}
            {% assign name_key = 'testimonial_' | append: testimonial_index | append: '_name' %}
            {% assign avatar_key = 'testimonial_' | append: testimonial_index | append: '_avatar' %}

            {% assign quote = section.settings[quote_key] %}
            {% assign name = section.settings[name_key] %}
            {% assign avatar = section.settings[avatar_key] %}

            {% assign show_slot = false %}
            {% if is_first_dup %}{% assign show_slot = true %}{% endif %}

            <div class="ai-testimonials-card-{{ ai_gen_id }}"{% if show_slot %} data-forge-slot-id="{{ avatar_key }}"{% if avatar == blank %} data-forge-slot-blank{% endif %}{% endif %}>
              <p class="ai-testimonials-quote-{{ ai_gen_id }}">"{{ quote }}"</p>
              <div class="ai-testimonials-author-{{ ai_gen_id }}">
                <div class="ai-testimonials-avatar-{{ ai_gen_id }}">
                  {% if avatar %}
                    <img src="{{ avatar | image_url: width: 100 }}" alt="{{ name }}" loading="lazy" width="100" height="100">
                  {% else %}
                    <div class="ai-testimonials-avatar-placeholder-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                      </svg>
                    </div>
                  {% endif %}
                </div>
                <div class="ai-testimonials-author-info-{{ ai_gen_id }}">
                  <p class="ai-testimonials-author-name-{{ ai_gen_id }}">{{ name }}</p>
                  <div class="ai-testimonials-stars-{{ ai_gen_id }}">
                    {% for star in (1..5) %}
                      <svg class="ai-testimonials-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const sectionElement = document.querySelector(`#shopify-section-${sectionId}`);
    if (sectionElement) {
      const rows = sectionElement.querySelectorAll('.ai-testimonials-marquee-row-{{ ai_gen_id }}');

      rows.forEach((row) => {
        row.addEventListener('mouseenter', () => {
          row.style.animationPlayState = 'paused';
        });

        row.addEventListener('mouseleave', () => {
          row.style.animationPlayState = 'running';
        });
      });
    }
  })();
</script>

