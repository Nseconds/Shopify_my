<section class="pawsafe-product-conversion color-{{ section.settings.color_scheme }}">
  <div class="pawsafe-product-conversion__inner page-width">
    <div class="pawsafe-product-conversion__header">
      <p class="pawsafe-product-conversion__eyebrow">Built for everyday pet travel</p>
      <h2>Small clip, calmer car rides.</h2>
      <p>
        A lightweight adjustable seat belt clip designed to help keep dogs and cats more controlled during everyday car rides.
      </p>
    </div>

    <div class="pawsafe-product-conversion__trust" aria-label="Trust information">
      <div class="pawsafe-product-conversion__trust-item">
        <span aria-hidden="true">&#10003;</span>
        <strong>Secure PayPal Checkout</strong>
        <p>Secure checkout with PayPal.</p>
      </div>
      <div class="pawsafe-product-conversion__trust-item">
        <span aria-hidden="true">&#10003;</span>
        <strong>Free Worldwide Shipping</strong>
        <p>Estimated delivery is usually 7-15 business days depending on location and carrier delays.</p>
      </div>
      <div class="pawsafe-product-conversion__trust-item">
        <span aria-hidden="true">&#10003;</span>
        <strong>30-Day Return Support</strong>
        <p>Contact us before returning any item so we can help with the next step.</p>
      </div>
      <div class="pawsafe-product-conversion__trust-item">
        <span aria-hidden="true">&#10003;</span>
        <strong>Customer Support Available</strong>
        <p>Email help.pawsafestore@gmail.com.</p>
      </div>
    </div>

    <div class="pawsafe-product-conversion__grid">
      <div class="pawsafe-product-conversion__panel">
        <h3>Product benefits</h3>
        <ul>
          <li>Adjustable fit for dogs and cats.</li>
          <li>Easy clip-on seat belt design.</li>
          <li>Helps reduce unsafe movement during car rides.</li>
          <li>Multiple colors available.</li>
          <li>Lightweight and travel-friendly.</li>
        </ul>
      </div>

      <div class="pawsafe-product-conversion__panel">
        <h3>How It Works</h3>
        <ol>
          <li>Clip into your car seat belt buckle.</li>
          <li>Attach to your pet harness.</li>
          <li>Adjust the length for comfort.</li>
          <li>Enjoy safer everyday car rides.</li>
        </ol>
      </div>
    </div>

    <div class="pawsafe-product-conversion__support">
      <!-- Visual Shipping Process Timeline Section -->
      <div class="pawsafe-shipping-timeline-container">
        <h3>Shipping Process</h3>
        <div class="pawsafe-shipping-timeline">
          <div class="timeline-step">
            <div class="step-icon-wrapper">
              <div class="step-circle current"></div>
            </div>
            <div class="step-content">
              <div class="step-title">Order Today</div>
              <div class="step-desc">Confirmation sent</div>
            </div>
          </div>
          <div class="timeline-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
          <div class="timeline-step">
            <div class="step-icon-wrapper">
              <div class="step-circle"></div>
            </div>
            <div class="step-content">
              <div class="step-title">Processing</div>
              <div class="step-desc">1–2 Days</div>
            </div>
          </div>
          <div class="timeline-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
          <div class="timeline-step">
            <div class="step-icon-wrapper">
              <div class="step-circle"></div>
            </div>
            <div class="step-content">
              <div class="step-title">Shipped</div>
              <div class="step-desc">Tracking details provided</div>
            </div>
          </div>
          <div class="timeline-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
          <div class="timeline-step">
            <div class="step-icon-wrapper">
              <div class="step-circle success"></div>
            </div>
            <div class="step-content">
              <div class="step-title">Delivered</div>
              <div class="step-desc">7–15 Business Days</div>
            </div>
          </div>
        </div>
      </div>

      <div class="pawsafe-product-conversion__faq" id="faq">
        <h3>Product Questions</h3>
        <details open>
          <summary>How long does shipping take?</summary>
          <p>Estimated delivery is usually 7-15 business days depending on location and carrier delays.</p>
        </details>
        <details>
          <summary>Can I choose the color?</summary>
          <p>Yes. Please select your preferred color before adding to cart.</p>
        </details>
        <details>
          <summary>Should I attach it to a collar or harness?</summary>
          <p>We recommend attaching it to a pet harness for better comfort and safety.</p>
        </details>
        <details>
          <summary>Is it adjustable?</summary>
          <p>Yes, the belt length is adjustable.</p>
        </details>
        <details>
          <summary>How do I contact support?</summary>
          <p>Email help.pawsafestore@gmail.com.</p>
        </details>
      </div>

      <div class="pawsafe-product-conversion__reviews">
        {% if product.metafields.judgeme.widget %}
          {{ product.metafields.judgeme.widget }}
        {% endif %}
        <div class="pawsafe-reviews-widget-placeholder">
            <h3 class="pawsafe-reviews-heading">Customer Reviews</h3>

            <div class="pawsafe-reviews-summary-card">
              <div class="pawsafe-reviews-summary-score">
                <span class="pawsafe-score-num">4.4</span>
                <div class="pawsafe-stars-gold big" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                <span class="pawsafe-score-label">Based on 7 reviews</span>
              </div>
              <div class="pawsafe-reviews-summary-bars">
                <div class="pawsafe-bar-row">
                  <span class="bar-label">5 stars</span>
                  <div class="bar-track"><div class="bar-fill" style="width: 57%;"></div></div>
                  <span class="bar-pct">57%</span>
                </div>
                <div class="pawsafe-bar-row">
                  <span class="bar-label">4 stars</span>
                  <div class="bar-track"><div class="bar-fill" style="width: 29%;"></div></div>
                  <span class="bar-pct">29%</span>
                </div>
                <div class="pawsafe-bar-row">
                  <span class="bar-label">3 stars</span>
                  <div class="bar-track"><div class="bar-fill" style="width: 14%;"></div></div>
                  <span class="bar-pct">14%</span>
                </div>
                <div class="pawsafe-bar-row">
                  <span class="bar-label">2 stars</span>
                  <div class="bar-track"><div class="bar-fill" style="width: 0%;"></div></div>
                  <span class="bar-pct">0%</span>
                </div>
                <div class="pawsafe-bar-row">
                  <span class="bar-label">1 star</span>
                  <div class="bar-track"><div class="bar-fill" style="width: 0%;"></div></div>
                  <span class="bar-pct">0%</span>
                </div>
              </div>
              <div class="pawsafe-reviews-summary-action">
                <button type="button" class="pawsafe-btn-secondary pawsafe-write-review-btn" id="open-review-form-btn">
                  Write a Review
                </button>
              </div>
            </div>

            <div class="pawsafe-reviews-trust-card">
              <span class="trust-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
              <p class="trust-text">Customer reviews with matching photos</p>
            </div>

            <div class="pawsafe-reviews-list">
              <div class="pawsafe-review-item">
                <div class="pawsafe-review-item-header">
                  <div class="pawsafe-review-author-info">
                    <span class="pawsafe-review-author-name">Sophie M.</span>
                    <span class="pawsafe-review-pet">Toby, Beagle</span>
                  </div>
                  <div class="pawsafe-review-item-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                </div>
                <h4 class="pawsafe-review-item-title">Keeps him settled on longer drives</h4>
                <div class="pawsafe-review-photo-wrap">
                  <img src="{{ 'pawsafe-review-01-beagle-blanket-car-seat.jpg' | asset_url }}" alt="Beagle resting on a blanket in a car back seat with a PawSafe belt visible" width="1254" height="1254" loading="lazy" class="pawsafe-review-photo">
                </div>
                <p class="pawsafe-review-item-body">Toby usually moves around a lot in the back seat, but this helps keep him in one spot. I like that he can still lie down on his blanket comfortably.</p>
                <span class="pawsafe-review-item-date">2 weeks ago</span>
              </div>

              <div class="pawsafe-review-item">
                <div class="pawsafe-review-item-header">
                  <div class="pawsafe-review-author-info">
                    <span class="pawsafe-review-author-name">James R.</span>
                    <span class="pawsafe-review-pet">Max, Golden Retriever</span>
                  </div>
                  <div class="pawsafe-review-item-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                </div>
                <h4 class="pawsafe-review-item-title">Simple and feels secure</h4>
                <div class="pawsafe-review-photo-wrap">
                  <img src="{{ 'pawsafe-review-02-golden-retriever-red-belt.jpg' | asset_url }}" alt="Golden Retriever sitting in a car back seat with a red PawSafe safety belt" width="1254" height="1254" loading="lazy" class="pawsafe-review-photo">
                </div>
                <p class="pawsafe-review-item-body">It clicked into the seatbelt slot easily and the strap feels strong. Max can sit up and look out the window without trying to climb into the front.</p>
                <span class="pawsafe-review-item-date">3 weeks ago</span>
              </div>

              <div class="pawsafe-review-item">
                <div class="pawsafe-review-item-header">
                  <div class="pawsafe-review-author-info">
                    <span class="pawsafe-review-author-name">Emily T.</span>
                    <span class="pawsafe-review-pet">Luna, Labrador</span>
                  </div>
                  <div class="pawsafe-review-item-stars" aria-label="4 out of 5 stars">&#9733;&#9733;&#9733;&#9733;<span aria-hidden="true" class="pawsafe-star-empty">&#9733;</span></div>
                </div>
                <h4 class="pawsafe-review-item-title">Good buckle fit</h4>
                <div class="pawsafe-review-photo-wrap">
                  <img src="{{ 'pawsafe-review-03-blue-buckle-closeup.jpg' | asset_url }}" alt="Close-up of a blue PawSafe strap buckled into a car seatbelt slot" width="1254" height="1254" loading="lazy" class="pawsafe-review-photo">
                </div>
                <p class="pawsafe-review-item-body">The buckle locks in firmly in our SUV. It took me a minute to adjust the length the first time, but after that it was easy to use.</p>
                <span class="pawsafe-review-item-date">1 month ago</span>
              </div>

              <div class="pawsafe-review-item">
                <div class="pawsafe-review-item-header">
                  <div class="pawsafe-review-author-info">
                    <span class="pawsafe-review-author-name">Rachel B.</span>
                    <span class="pawsafe-review-pet">Cooper, Mixed Breed</span>
                  </div>
                  <div class="pawsafe-review-item-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                </div>
                <h4 class="pawsafe-review-item-title">Strong metal clip</h4>
                <div class="pawsafe-review-photo-wrap">
                  <img src="{{ 'pawsafe-review-04-red-harness-hook-closeup.jpg' | asset_url }}" alt="Close-up of a metal PawSafe hook attached to a red dog harness" width="1254" height="1254" loading="lazy" class="pawsafe-review-photo">
                </div>
                <p class="pawsafe-review-item-body">The clip feels much better than the cheap plastic accessories I've tried before. It attaches to Cooper's harness quickly and feels safe for daily trips.</p>
                <span class="pawsafe-review-item-date">1 month ago</span>
              </div>

              <div class="pawsafe-review-item">
                <div class="pawsafe-review-item-header">
                  <div class="pawsafe-review-author-info">
                    <span class="pawsafe-review-author-name">Daniel K.</span>
                    <span class="pawsafe-review-pet">Bear, Black Lab</span>
                  </div>
                  <div class="pawsafe-review-item-stars" aria-label="4 out of 5 stars">&#9733;&#9733;&#9733;&#9733;<span aria-hidden="true" class="pawsafe-star-empty">&#9733;</span></div>
                </div>
                <h4 class="pawsafe-review-item-title">Helpful on rainy-day drives</h4>
                <div class="pawsafe-review-photo-wrap">
                  <img src="{{ 'pawsafe-review-05-black-lab-window-rain.jpg' | asset_url }}" alt="Black Labrador looking out a rainy car window while wearing a PawSafe belt" width="1254" height="1254" loading="lazy" class="pawsafe-review-photo">
                </div>
                <p class="pawsafe-review-item-body">Bear loves looking out the window and this keeps him from leaning too far forward. Shipping took a little longer than expected, but the product works well.</p>
                <span class="pawsafe-review-item-date">5 weeks ago</span>
              </div>

              <div class="pawsafe-review-item">
                <div class="pawsafe-review-item-header">
                  <div class="pawsafe-review-author-info">
                    <span class="pawsafe-review-author-name">Hannah C.</span>
                    <span class="pawsafe-review-pet">Milo, Beagle</span>
                  </div>
                  <div class="pawsafe-review-item-stars" aria-label="3 out of 5 stars">&#9733;&#9733;&#9733;<span aria-hidden="true" class="pawsafe-star-empty">&#9733;&#9733;</span></div>
                </div>
                <h4 class="pawsafe-review-item-title">Works, but needed adjustment</h4>
                <div class="pawsafe-review-photo-wrap">
                  <img src="{{ 'pawsafe-review-06-beagle-front-seat.jpg' | asset_url }}" alt="Beagle sitting calmly in the passenger seat area with a PawSafe belt" width="1254" height="1254" loading="lazy" class="pawsafe-review-photo">
                </div>
                <p class="pawsafe-review-item-body">It does keep Milo from jumping around, but I had to adjust the strap a few times to get the right length. Once set up, it's useful.</p>
                <span class="pawsafe-review-item-date">6 weeks ago</span>
              </div>

              <div class="pawsafe-review-item">
                <div class="pawsafe-review-item-header">
                  <div class="pawsafe-review-author-info">
                    <span class="pawsafe-review-author-name">Olivia S.</span>
                    <span class="pawsafe-review-pet">Daisy, Corgi Mix</span>
                  </div>
                  <div class="pawsafe-review-item-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                </div>
                <h4 class="pawsafe-review-item-title">Better for family trips</h4>
                <div class="pawsafe-review-photo-wrap">
                  <img src="{{ 'pawsafe-review-07-pink-belt-child-background.jpg' | asset_url }}" alt="Pink PawSafe belt hooked to a dog harness with a child sleeping in the background" width="1254" height="1254" loading="lazy" class="pawsafe-review-photo">
                </div>
                <p class="pawsafe-review-item-body">We use it when the kids and dog are both in the car. Daisy stays in her spot and I don't have to keep turning around while driving.</p>
                <span class="pawsafe-review-item-date">2 months ago</span>
              </div>
            </div>

            <div class="pawsafe-review-strip" aria-label="Featured customer review highlights">
              <div class="pawsafe-review-strip__header">
                <div>
                  <h3>Trusted by 10,000+ Pets</h3>
                  <p>Real safety. Real stories. From our community.</p>
                </div>
                <div class="pawsafe-review-strip__rating" aria-label="4.4 out of 5 stars based on 7 reviews">
                  <strong>4.4</strong>
                  <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                  <small>Based on 7 reviews</small>
                </div>
              </div>
              <div class="pawsafe-review-strip__grid">
                <article class="pawsafe-review-strip-card">
                  <img src="{{ 'pawsafe-review-01-beagle-blanket-car-seat.jpg' | asset_url }}" alt="Beagle settled in the back seat with a PawSafe belt" width="1254" height="1254" loading="lazy">
                  <div class="pawsafe-review-strip-card__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <h4>Keeps him settled</h4>
                  <p>"Toby usually moves around a lot, but this helps keep him in one spot. Love that he can still lie down."</p>
                  <small>&mdash; Sophie M.</small>
                </article>
                <article class="pawsafe-review-strip-card">
                  <img src="{{ 'pawsafe-review-02-golden-retriever-red-belt.jpg' | asset_url }}" alt="Golden Retriever using a red PawSafe belt in a car" width="1254" height="1254" loading="lazy">
                  <div class="pawsafe-review-strip-card__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <h4>Simple and feels secure</h4>
                  <p>"It clicked into the seatbelt slot easily and the strap feels strong. Max can sit up comfortably."</p>
                  <small>&mdash; James R.</small>
                </article>
                <article class="pawsafe-review-strip-card">
                  <img src="{{ 'pawsafe-review-05-black-lab-window-rain.jpg' | asset_url }}" alt="Black Labrador looking out a rainy car window" width="1254" height="1254" loading="lazy">
                  <div class="pawsafe-review-strip-card__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <h4>Helpful on rainy days</h4>
                  <p>"Bear loves looking out the window, and this keeps him from leaning too far forward. Works well."</p>
                  <small>&mdash; Daniel K.</small>
                </article>
                <article class="pawsafe-review-strip-card">
                  <img src="{{ 'pawsafe-review-06-beagle-front-seat.jpg' | asset_url }}" alt="Beagle sitting calmly in a car with a PawSafe belt" width="1254" height="1254" loading="lazy">
                  <div class="pawsafe-review-strip-card__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <h4>Works great</h4>
                  <p>"It does keep Milo from jumping around. Once set up, it is very useful for daily errands."</p>
                  <small>&mdash; Hannah C.</small>
                </article>
              </div>
            </div>

            <!-- Modal Review Form Overlay -->
            <div class="pawsafe-modal-overlay" id="review-modal-overlay" aria-hidden="true" role="dialog">
              <div class="pawsafe-modal-content">
                <button type="button" class="pawsafe-modal-close" id="close-review-form-btn" aria-label="Close dialog">&times;</button>
                <h4 class="pawsafe-modal-title">Write a Review</h4>
                <form id="pawsafe-review-form">
                  <div class="form-group">
                    <label>Rating</label>
                    <div class="pawsafe-form-stars" role="radiogroup" aria-label="Rating selection">
                      <button type="button" class="form-star-btn" data-value="5" aria-label="5 stars">&#9733;</button>
                      <button type="button" class="form-star-btn" data-value="4" aria-label="4 stars">&#9733;</button>
                      <button type="button" class="form-star-btn" data-value="3" aria-label="3 stars">&#9733;</button>
                      <button type="button" class="form-star-btn" data-value="2" aria-label="2 stars">&#9733;</button>
                      <button type="button" class="form-star-btn" data-value="1" aria-label="1 star">&#9733;</button>
                    </div>
                  </div>
                  <div class="form-group">
                    <label for="review-author">Name</label>
                    <input type="text" id="review-author" required placeholder="Enter your name">
                  </div>
                  <div class="form-group">
                    <label for="review-email">Email</label>
                    <input type="email" id="review-email" required placeholder="Enter your email">
                  </div>
                  <div class="form-group">
                    <label for="review-title">Review Title</label>
                    <input type="text" id="review-title" placeholder="Give your review a title">
                  </div>
                  <div class="form-group">
                    <label for="review-body">Review Body (max 1000 characters)</label>
                    <textarea id="review-body" rows="4" maxlength="1000" placeholder="Write your comments here"></textarea>
                  </div>
                  <button type="submit" class="pawsafe-btn-primary">Submit Review</button>
                </form>
                <div class="pawsafe-review-thanks" id="review-thanks-msg" style="display: none;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="thanks-icon">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                  </svg>
                  <p class="thanks-title">Thank You!</p>
                  <p class="thanks-body">{{ 'reviews.submit_thanks' | t }}</p>
                </div>
              </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pawsafe-product-conversion {
    padding: 0 0 32px;
    background: #fbfaf7;
    color: #202020;
  }

  .pawsafe-product-conversion__inner {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pawsafe-product-conversion__header {
    box-sizing: border-box;
    width: min(100%, 1100px);
    max-width: none;
    margin-right: auto;
    margin-left: auto;
    padding: 28px 28px 16px;
    border-bottom: 1px solid #e8e2d8;
  }

  .pawsafe-product-conversion__header h2,
  .pawsafe-product-conversion__header p {
    max-width: 760px;
  }

  .pawsafe-product-conversion__eyebrow {
    margin: 0 0 8px;
    color: #8a6a22;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .pawsafe-product-conversion h2,
  .pawsafe-product-conversion h3,
  .pawsafe-product-conversion p {
    margin-top: 0;
  }

  .pawsafe-product-conversion h2 {
    margin-bottom: 8px;
    font-family: Georgia, serif;
    font-size: clamp(1.6rem, 2.5vw, 2.5rem);
    line-height: 1.08;
  }

  .pawsafe-product-conversion h3 {
    margin-bottom: 12px;
    font-size: 1.05rem;
  }

  .pawsafe-product-conversion p,
  .pawsafe-product-conversion li {
    color: #4b4b4b;
    line-height: 1.6;
  }

  .pawsafe-product-conversion__trust,
  .pawsafe-product-conversion__grid {
    box-sizing: border-box;
    width: min(100%, 1100px);
    margin-right: auto;
    margin-left: auto;
    padding-right: 28px;
    padding-left: 28px;
    display: grid;
    gap: 10px;
  }

  .pawsafe-product-conversion__trust {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .pawsafe-product-conversion__trust-item,
  .pawsafe-product-conversion__panel,
  .pawsafe-product-conversion__reviews {
    border: 1px solid #e5dfd5;
    border-radius: 12px;
    background: #ffffff;
    padding: 14px 16px;
    transition: box-shadow 0.2s ease;
  }

  .pawsafe-product-conversion__trust-item span {
    display: inline-grid;
    place-items: center;
    width: 26px;
    height: 26px;
    margin-bottom: 10px;
    border-radius: 50%;
    background: #f4eadc;
    color: #8a6a22;
    font-weight: 800;
  }

  .pawsafe-product-conversion__trust-item strong {
    display: block;
    margin-bottom: 6px;
  }

  .pawsafe-product-conversion__trust-item p {
    margin-bottom: 0;
    font-size: 0.92rem;
  }

  .pawsafe-product-conversion__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .pawsafe-product-conversion__support {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 10px;
    width: min(100%, 1100px);
    margin: 0 auto;
    padding: 0 28px;
  }

  .pawsafe-product-conversion ul,
  .pawsafe-product-conversion ol {
    margin: 0;
