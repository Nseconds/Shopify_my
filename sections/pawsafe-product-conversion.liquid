<script>
  document.addEventListener('DOMContentLoaded', () => {
    const openBtn = document.getElementById('open-review-form-btn');
    const closeBtn = document.getElementById('close-review-form-btn');
    const modal = document.getElementById('review-modal-overlay');
    const form = document.getElementById('pawsafe-review-form');
    const thanksMsg = document.getElementById('review-thanks-msg');
    
    if (openBtn && modal) {
      openBtn.addEventListener('click', () => {
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      });
    }
    
    const closeModal = () => {
      if (modal) {
        modal.classList.remove('active');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (form) form.reset();
        if (form) form.style.display = 'block';
        if (thanksMsg) thanksMsg.style.display = 'none';
        resetStarsTo(5);
      }
    };
    
    if (closeBtn) {
      closeBtn.addEventListener('click', closeModal);
    }
    
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModal();
        }
      });
    }
    
    const starBtns = document.querySelectorAll('.form-star-btn');
    let selectedRating = 5;
    
    const resetStarsTo = (rating) => {
      selectedRating = rating;
      starBtns.forEach(btn => {
        if (parseInt(btn.dataset.value) <= rating) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
    };
    
    resetStarsTo(5);
    
    starBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        resetStarsTo(parseInt(btn.dataset.value));
      });
    });
    
    if (form && thanksMsg) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.style.display = 'none';
        thanksMsg.style.display = 'flex';
      });
    }
  });
</script>

