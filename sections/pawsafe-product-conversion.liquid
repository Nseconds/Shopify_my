  /* Stitch design system: Premium Canine Protection */
  .pawsafe-product-conversion {
    --stitch-surface: #fbf9f5;
    --stitch-surface-card: #ffffff;
    --stitch-surface-soft: #f5f3ef;
    --stitch-primary: #0d3c26;
    --stitch-primary-deep: #002514;
    --stitch-primary-tint: #e9f3ed;
    --stitch-gold: #fed488;
    --stitch-gold-text: #775a19;
    --stitch-coral: #f47c5d;
    --stitch-text: #1b1c1a;
    --stitch-muted: #414943;
    --stitch-border: #c1c9c1;
    background: var(--stitch-surface);
    color: var(--stitch-text);
    font-family: Inter, var(--font-body--family), sans-serif;
  }

  .pawsafe-product-conversion h2,
  .pawsafe-product-conversion h3,
  .pawsafe-product-conversion__faq h3,
  .pawsafe-product-conversion__reviews h3,
