{% liquid
  assign promo_product = collections.all.products.first
  assign promo_shop_url = routes.all_products_collection_url
  if promo_product != blank
    assign promo_shop_url = promo_product.url
  endif
%}

<div class="custom-announcement-wrapper" style="color: {{ section.settings.text_color }};">
  <div class="custom-announcement-container">
    <span class="announcement-text-center">
      10% off your first order with code WELCOME10
    </span>
    <span class="custom-announcement-divider" aria-hidden="true">|</span>
    <a class="custom-announcement-link" href="{{ promo_shop_url }}">Shop Now</a>
  </div>
</div>

<style>
  .custom-announcement-wrapper {
    width: 100%;
    padding: 10px 16px;
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 14px;
    font-weight: 800;
    text-align: center;
    letter-spacing: .02em;
    background: linear-gradient(90deg, #10281f, #1f4a3d);
  }
  .custom-announcement-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .announcement-text-center {
    display: inline-block;
    max-width: 100%;
    line-height: 1.35;
    white-space: normal;
  }
  .custom-announcement-divider {
    display: inline-block;
    margin: 0 8px;
    color: rgba(255, 255, 255, 0.58);
  }
  .custom-announcement-link {
    color: #f7cf7a;
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
  }
  .custom-announcement-link:hover {
    color: #ffe5a6;
  }
  @media (max-width: 768px) {
    .custom-announcement-wrapper {
      font-size: 11px;
      padding: 8px 10px;
    }
    .custom-announcement-container {
      flex-wrap: wrap;
      gap: 0 6px;
      row-gap: 2px;
    }
    .announcement-text-center {
      flex: 1 1 100%;
    }
    .custom-announcement-divider {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Announcement Bar",
  "settings": [
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "10% off your first order with code WELCOME10 | Shop Now"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar"
    }
  ]
}
{% endschema %}
