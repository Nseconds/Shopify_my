<div class="custom-announcement-wrapper" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="custom-announcement-container">
    
    <!-- Left Text & Icon -->
    <span class="announcement-text-left">
      <span class="announcement-icon">🐾</span> 
      {{ section.settings.text_left }}
    </span>

    <!-- Countdown Timer Box -->
    <div class="announcement-timer" id="announcement-countdown" style="background-color: {{ section.settings.timer_bg_color }};">
      00:00:00
    </div>

    <!-- Right Text -->
    <span class="announcement-text-right">
      {{ section.settings.text_right }}
    </span>
    
  </div>
</div>

<style>
  .custom-announcement-wrapper {
    width: 100%;
    padding: 10px 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-align: center;
  }
  .custom-announcement-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .announcement-icon {
    margin-right: 5px;
    font-size: 16px;
  }
  .announcement-timer {
    padding: 4px 8px;
    border-radius: 4px;
    font-variant-numeric: tabular-nums;
    font-size: 13px;
    letter-spacing: 0.5px;
  }
  @media (max-width: 768px) {
    .custom-announcement-container {
      gap: 8px;
      font-size: 12px;
    }
    .announcement-timer {
      font-size: 11px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function updateTimer() {
      const now = new Date();
      const tomorrow = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
      const diff = tomorrow - now;

      if (diff <= 0) {
        document.getElementById('announcement-countdown').innerHTML = "00:00:00";
        return;
      }

      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((diff / (1000 * 60)) % 60);
      const seconds = Math.floor((diff / 1000) % 60);

      const displayHours = hours < 10 ? '0' + hours : hours;
      const displayMinutes = minutes < 10 ? '0' + minutes : minutes;
      const displaySeconds = seconds < 10 ? '0' + seconds : seconds;

      document.getElementById('announcement-countdown').innerHTML = `${displayHours}:${displayMinutes}:${displaySeconds}`;
    }

    updateTimer();
    setInterval(updateTimer, 1000);
  });
</script>

{% schema %}
{
  "name": "Custom Announcement Bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1e7145"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "timer_bg_color",
      "label": "Timer Background",
      "default": "#144d2f"
    },
    {
      "type": "text",
      "id": "text_left",
      "label": "Left Text",
      "default": "Keep your pet safe on every journey"
    },
    {
      "type": "text",
      "id": "text_right",
      "label": "Right Text",
      "default": "Free worldwide shipping on all orders"
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar"
    }
  ]
}
{% endschema %}