{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
    background-color: var(--color-background, {{ section.settings.section_background }});
    overflow: hidden;
  }

  .ai-reviews-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ section.settings.header_spacing }}px;
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ section.settings.title_size }}px;
    color: var(--color-foreground, {{ section.settings.title_color }});
    margin: 0 0 12px;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .ai-reviews-subtitle-{{ ai_gen_id }} {
    font-size: {{ section.settings.subtitle_size }}px;
    color: var(--color-foreground, {{ section.settings.subtitle_color }});
    margin: 0;
    font-weight: 300;
    opacity: 0.8;
  }

  .ai-reviews-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin: 0 -20px;
    padding: 0 20px;
  }

  .ai-reviews-carousel-{{ ai_gen_id }} {
    display: flex;
    gap: var(--style-gap-cards);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 8px 0 24px;
  }

  .ai-reviews-carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-reviews-card-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ section.settings.card_width }}px;
    background: var(--color-card-background, {{ section.settings.card_background }});
    border-radius: var(--style-border-radius-cards);
    padding: {{ section.settings.card_padding }}px;
    box-shadow: var(--style-shadow-card);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-reviews-card-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .ai-reviews-avatar-{{ ai_gen_id }} {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--color-primary, {{ section.settings.avatar_placeholder_bg }});
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-reviews-avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-reviews-avatar-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.avatar_size | divided_by: 2 }}px;
    color: var(--color-background, {{ section.settings.avatar_placeholder_color }});
    font-weight: 500;
  }

  .ai-reviews-customer-info-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-reviews-customer-name-{{ ai_gen_id }} {
    font-size: {{ section.settings.name_size }}px;
    color: var(--color-foreground, {{ section.settings.name_color }});
    margin: 0 0 4px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .ai-reviews-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-reviews-star-{{ ai_gen_id }} {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    color: var(--color-primary, {{ section.settings.star_color }});
  }

  .ai-reviews-testimonial-{{ ai_gen_id }} {
    font-size: {{ section.settings.testimonial_size }}px;
    line-height: 1.6;
    color: var(--color-foreground, {{ section.settings.testimonial_color }});
    margin: 0;
    font-weight: 300;
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-card-{{ ai_gen_id }} {
      width: {{ section.settings.card_width_mobile }}px;
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: {{ section.settings.title_size | times: 0.8 }}px;
    }

    .ai-reviews-subtitle-{{ ai_gen_id }} {
      font-size: {{ section.settings.subtitle_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div
  id="shopify-section-{{ section.id }}"
  class="ai-reviews-{{ ai_gen_id }} color-{{ section.settings.color_scheme }}"
  {{ section.shopify_attributes }}
>
  <div class="ai-reviews-container-{{ ai_gen_id }}">
    {% if section.settings.section_title != blank or section.settings.section_subtitle != blank %}
      <div class="ai-reviews-header-{{ ai_gen_id }}">
        {% if section.settings.section_title != blank %}
          <h2 class="ai-reviews-title-{{ ai_gen_id }}">{{ section.settings.section_title }}</h2>
        {% endif %}
        {% if section.settings.section_subtitle != blank %}
          <p class="ai-reviews-subtitle-{{ ai_gen_id }}">{{ section.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-reviews-carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-reviews-carousel-{{ ai_gen_id }}" data-carousel>
        {% for duplicate in (1..2) %}
        {% for i in (1..6) %}
          {% liquid
            assign review_enabled_key = 'review_' | append: i | append: '_enabled'
            assign customer_name_key = 'review_' | append: i | append: '_customer_name'
            assign testimonial_key = 'review_' | append: i | append: '_testimonial'
            assign avatar_key = 'review_' | append: i | append: '_avatar'

            assign review_enabled = section.settings[review_enabled_key]
            assign customer_name = section.settings[customer_name_key]
            assign testimonial = section.settings[testimonial_key]
            assign avatar = section.settings[avatar_key]
          %}

          {% if review_enabled %}
            <div class="ai-reviews-card-{{ ai_gen_id }}">
              <div class="ai-reviews-card-header-{{ ai_gen_id }}">
                <div class="ai-reviews-avatar-{{ ai_gen_id }}">
                  {% if avatar != blank %}
                    <img
                      src="{{ avatar | image_url: width: 100 }}"
                      alt="{{ customer_name | escape }}"
                      loading="lazy"
                      width="100"
                      height="100"
                    >
                  {% else %}
                    <div class="ai-reviews-avatar-placeholder-{{ ai_gen_id }}">
                      {% if customer_name != blank %}
                        {{ customer_name | slice: 0 | upcase }}
                      {% else %}
                        ?
                      {% endif %}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-reviews-customer-info-{{ ai_gen_id }}">
                  {% if customer_name != blank %}
                    <h3 class="ai-reviews-customer-name-{{ ai_gen_id }}">{{ customer_name }}</h3>
                  {% endif %}
                  <div class="ai-reviews-stars-{{ ai_gen_id }}">
                    {% for star in (1..5) %}
                      <svg class="ai-reviews-star-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                      </svg>
                    {% endfor %}
                  </div>
                </div>
              </div>

              {% if testimonial != blank %}
                <p class="ai-reviews-testimonial-{{ ai_gen_id }}">{{ testimonial }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const sectionElement = document.querySelector(`#shopify-section-${sectionId}`);
    
    if (!sectionElement) return;
    
    const carousel = sectionElement.querySelector('[data-carousel]');
    if (!carousel) return;
    
    const scrollSpeed = {{ section.settings.scroll_speed }};
    let scrollInterval = null;
    let isPaused = false;
    let isDragging = false;
    
    function setupTouchScroll() {
      let isDown = false;
      let startX;
      let scrollLeft;
      let startY;

      // Mouse events
      carousel.addEventListener('mousedown', (e) => {
        isDown = true;
        isDragging = true;
        carousel.style.cursor = 'grabbing';
        startX = e.pageX - carousel.offsetLeft;
        startY = e.pageY - carousel.offsetTop;
        scrollLeft = carousel.scrollLeft;
        isPaused = true;
      });

      carousel.addEventListener('mouseup', () => {
        if (isDown) {
          isDown = false;
          isDragging = false;
          carousel.style.cursor = 'grab';
          // Resume scrolling after a short delay
          setTimeout(() => {
            isPaused = false;
          }, 1000);
        }
      });

      carousel.addEventListener('mouseleave', () => {
        if (isDown) {
          isDown = false;
          isDragging = false;
          carousel.style.cursor = 'grab';
          // Resume scrolling after a short delay
          setTimeout(() => {
            isPaused = false;
          }, 1000);
        }
      });

      carousel.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - carousel.offsetLeft;
        const walk = (x - startX) * 2;
        carousel.scrollLeft = scrollLeft - walk;
      });

      // Touch events for mobile
      carousel.addEventListener('touchstart', (e) => {
        isDragging = true;
        isPaused = true;
        startX = e.touches[0].pageX - carousel.offsetLeft;
        scrollLeft = carousel.scrollLeft;
      }, { passive: true });

      carousel.addEventListener('touchend', () => {
        isDragging = false;
        setTimeout(() => {
          isPaused = false;
        }, 1000);
      }, { passive: true });

      carousel.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const x = e.touches[0].pageX - carousel.offsetLeft;
        const walk = (x - startX) * 2;
        carousel.scrollLeft = scrollLeft - walk;
      }, { passive: true });

      carousel.style.cursor = 'grab';
    }
    
    function startAutoScroll() {
      scrollInterval = setInterval(() => {
        if (isPaused || isDragging) return;

        const maxScroll = carousel.scrollWidth - carousel.clientWidth;
        
        // Don't scroll if content doesn't overflow
        if (maxScroll <= 0) return;
        
        // Reset at halfway point (content is duplicated) for seamless infinite loop
        const loopThreshold = carousel.scrollWidth / 2;
        if (carousel.scrollLeft >= loopThreshold - 1) {
          carousel.scrollLeft = 0;
        } else {
          carousel.scrollLeft += 1;
        }
      }, scrollSpeed);
    }
    
    function setupPauseOnHover() {
      carousel.addEventListener('mouseenter', () => {
        if (!isDragging) {
          isPaused = true;
        }
      });

      carousel.addEventListener('mouseleave', () => {
        if (!isDragging) {
          isPaused = false;
        }
      });
    }
    
    setupTouchScroll();
    
    {% if section.settings.enable_auto_scroll %}
      startAutoScroll();
      setupPauseOnHover();
    {% endif %}
  })();
</script>

