{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{%- if section.settings.use_custom_colors -%}
  {%- assign bg_c     = section.settings.background_color -%}
  {%- assign accent_c = section.settings.highlight_color -%}
{%- elsif settings.style_mode == 'gradient' -%}
  {%- assign bg_c     = 'var(--color-background)' -%}
  {%- assign accent_c = 'var(--color-gradient-1)' -%}
{%- else -%}
  {%- assign bg_c     = section.settings.color_scheme.settings.background -%}
  {%- assign accent_c = section.settings.color_scheme.settings.primary -%}
{%- endif -%}

{% style %}
  .service-promo-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: {{ bg_c }};
    padding: {{ section.settings.padding_vertical }}px 20px;
  }

  .service-promo-banner-container-{{ ai_gen_id }} {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--style-gap-cards);
  }

  .service-promo-banner-left-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .service-promo-banner-left-{{ ai_gen_id }} img {
    max-width: {{ section.settings.icon_size }}px;
    height: auto;
    display: block;
  }

  .service-promo-banner-middle-{{ ai_gen_id }} {
    flex-grow: 1;
    text-align: left;
  }

  .service-promo-banner-headline-{{ ai_gen_id }} {
    margin: 0 0 8px 0;
    font-size: {{ section.settings.headline_size }}px;
    font-weight: 700;
    line-height: 1.2;
  }

  .service-promo-banner-headline-highlight-{{ ai_gen_id }} {
    color: {{ accent_c }};
  }

  .service-promo-banner-headline-normal-{{ ai_gen_id }} {
    color: var(--color-foreground);
  }

  .service-promo-banner-subtext-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ section.settings.subtext_size }}px;
    color: var(--color-foreground-muted, var(--color-foreground));
    font-weight: 400;
    line-height: 1.5;
    max-width: 600px;
  }

  .service-promo-banner-right-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .service-promo-banner-badge-link-{{ ai_gen_id }} {
    display: inline-block;
    transition: transform 0.3s ease;
    cursor: pointer;
  }

  .service-promo-banner-badge-link-{{ ai_gen_id }}:hover {
    transform: scale(1.03);
  }

  .service-promo-banner-badge-link-{{ ai_gen_id }} img {
    max-width: {{ section.settings.badge_max_width }}px;
    height: auto;
    display: block;
  }

  .service-promo-banner-placeholder-{{ ai_gen_id }} {
    background-color: var(--color-border, #f4f4f4);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--style-border-radius-cards);
    padding: 20px;
  }

  .service-promo-banner-icon-placeholder-{{ ai_gen_id }} {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
  }

  .service-promo-banner-badge-placeholder-{{ ai_gen_id }} {
    width: {{ section.settings.badge_max_width }}px;
    height: 60px;
  }

  .service-promo-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .service-promo-banner-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 24px;
      {% if section.settings.mobile_alignment == 'center' %}
        text-align: center;
      {% else %}
        text-align: left;
      {% endif %}
    }

    .service-promo-banner-middle-{{ ai_gen_id }} {
      {% if section.settings.mobile_alignment == 'center' %}
        text-align: center;
      {% else %}
        text-align: left;
      {% endif %}
    }

    .service-promo-banner-headline-{{ ai_gen_id }} {
      font-size: calc({{ section.settings.headline_size }}px * 0.75);
    }

    .service-promo-banner-subtext-{{ ai_gen_id }} {
      font-size: calc({{ section.settings.subtext_size }}px * 0.9);
      max-width: 100%;
    }

    .service-promo-banner-left-{{ ai_gen_id }} img {
      max-width: calc({{ section.settings.icon_size }}px * 0.8);
    }

    .service-promo-banner-badge-link-{{ ai_gen_id }} img {
      max-width: calc({{ section.settings.badge_max_width }}px * 0.8);
    }
  }
{% endstyle %}

<div class="service-promo-banner-{{ ai_gen_id }} color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="service-promo-banner-container-{{ ai_gen_id }}">
    <div class="service-promo-banner-left-{{ ai_gen_id }}" data-forge-slot-id="left_icon"{% if section.settings.left_icon == blank %} data-forge-slot-blank="true"{% endif %}>
      {% if section.settings.left_icon %}
        <img
          src="{{ section.settings.left_icon | image_url: width: 200 }}"
          alt="{{ section.settings.left_icon.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.left_icon.width }}"
          height="{{ section.settings.left_icon.height }}"
        >
      {% else %}
        <div class="service-promo-banner-placeholder-{{ ai_gen_id }} service-promo-banner-icon-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="service-promo-banner-middle-{{ ai_gen_id }}">
      <h2 class="service-promo-banner-headline-{{ ai_gen_id }}">
        {% if section.settings.headline_highlight != blank %}
          <span class="service-promo-banner-headline-highlight-{{ ai_gen_id }}">{{ section.settings.headline_highlight }}</span>
        {% endif %}
        {% if section.settings.headline_normal != blank %}
          <span class="service-promo-banner-headline-normal-{{ ai_gen_id }}">{{ section.settings.headline_normal }}</span>
        {% endif %}
      </h2>
      {% if section.settings.supporting_text != blank %}
        <div class="service-promo-banner-subtext-{{ ai_gen_id }}">
          {{ section.settings.supporting_text }}
        </div>
      {% endif %}
    </div>

    <div class="service-promo-banner-right-{{ ai_gen_id }}" data-forge-slot-id="right_badge"{% if section.settings.right_badge == blank %} data-forge-slot-blank="true"{% endif %}>
      {% if section.settings.right_badge %}
        {% if section.settings.badge_link != blank %}
          <a href="{{ section.settings.badge_link }}" class="service-promo-banner-badge-link-{{ ai_gen_id }}">
            <img
              src="{{ section.settings.right_badge | image_url: width: 400 }}"
              alt="{{ section.settings.right_badge.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.right_badge.width }}"
              height="{{ section.settings.right_badge.height }}"
            >
          </a>
        {% else %}
          <div class="service-promo-banner-badge-link-{{ ai_gen_id }}">
            <img
              src="{{ section.settings.right_badge | image_url: width: 400 }}"
              alt="{{ section.settings.right_badge.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.right_badge.width }}"
              height="{{ section.settings.right_badge.height }}"
            >
          </div>
        {% endif %}
      {% else %}
        <div class="service-promo-banner-placeholder-{{ ai_gen_id }} service-promo-banner-badge-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Service promo banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "header",
      "content": "Left icon"
    },
    {
      "type": "image_picker",
      "id": "left_icon",
      "label": "Icon image"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline_highlight",
      "label": "Highlight text",
      "default": "Free Shipping"
    },
    {
      "type": "text",
      "id": "headline_normal",
      "label": "Normal text",
      "default": "On Orders Over $50"
    },
    {
      "type": "richtext",
      "id": "supporting_text",
      "label": "Supporting text",
      "default": "<p>Fast and secure delivery nationwide. Your orders are carefully packaged.</p>"
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Headline size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Subtext size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Right badge"
    },
    {
      "type": "image_picker",
      "id": "right_badge",
      "label": "Badge image"
    },
    {
      "type": "url",
      "id": "badge_link",
      "label": "Badge link"
    },
    {
      "type": "range",
      "id": "badge_max_width",
      "label": "Badge max width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#ff9a0e"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Padding top/bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Mobile alignment",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Service promo banner"
    }
  ]
}
{% endschema %}
