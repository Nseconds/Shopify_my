{%- liquid
  if section.settings.use_custom_colors
    assign sc_bg     = section.settings.background_color
    assign sc_text   = section.settings.heading_color
    assign sc_body   = section.settings.question_color
    assign sc_accent = section.settings.icon_color
  elsif settings.style_mode == 'gradient'
    assign sc_bg     = 'var(--color-background)'
    assign sc_text   = 'var(--color-foreground)'
    assign sc_body   = 'var(--color-foreground)'
    assign sc_accent = 'var(--color-gradient-1)'
  else
    assign sc_bg     = section.settings.color_scheme.settings.background
    assign sc_text   = section.settings.color_scheme.settings.foreground
    assign sc_body   = section.settings.color_scheme.settings.foreground
    assign sc_accent = section.settings.color_scheme.settings.primary
  endif
-%}
{% style %}
  .faq-with-image-{{ section.id }} {
    display: block;
    width: 100%;
    background: {{ sc_bg }};
    padding: {{ section.settings.section_padding }}px 20px;
  }

  .faq-with-image-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--style-gap-cards);
    align-items: start;
  }

  .faq-with-image-image-column-{{ section.id }} {
    position: sticky;
    top: 20px;
  }

  .faq-with-image-image-wrapper-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    border-radius: var(--style-border-radius-images);
    background-color: {{ section.settings.image_background }};
  }

  .faq-with-image-image-wrapper-{{ section.id }} img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    {% if section.settings.image_aspect_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif section.settings.image_aspect_ratio == 'portrait' %}
      aspect-ratio: 3 / 4;
    {% elsif section.settings.image_aspect_ratio == 'landscape' %}
      aspect-ratio: 4 / 3;
    {% elsif section.settings.image_aspect_ratio == 'wide' %}
      aspect-ratio: 16 / 9;
    {% endif %}
  }

  .faq-with-image-image-placeholder-{{ section.id }} {
    width: 100%;
    {% if section.settings.image_aspect_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif section.settings.image_aspect_ratio == 'portrait' %}
      aspect-ratio: 3 / 4;
    {% elsif section.settings.image_aspect_ratio == 'landscape' %}
      aspect-ratio: 4 / 3;
    {% elsif section.settings.image_aspect_ratio == 'wide' %}
      aspect-ratio: 16 / 9;
    {% endif %}
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.image_background }};
  }

  .faq-with-image-image-placeholder-{{ section.id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.2;
  }

  .faq-with-image-content-column-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.content_spacing }}px;
  }

  .faq-with-image-heading-{{ section.id }} {
    font-family: var(--font-heading--family);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ sc_text }};
    margin: 0;
    letter-spacing: -0.02em;
  }

  .faq-with-image-accordion-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }

  .faq-with-image-item-{{ section.id }} {
    border-bottom: {{ section.settings.divider_width }}px solid {{ section.settings.divider_color }};
  }

  .faq-with-image-item-{{ section.id }}:last-child {
    border-bottom: none;
  }

  .faq-with-image-question-{{ section.id }} {
    width: 100%;
    background: none;
    border: none;
    padding: {{ section.settings.item_padding }}px 0;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    font-family: var(--font-heading--family);
    font-size: {{ section.settings.question_size }}px;
    line-height: 1.4;
    color: {{ sc_body }};
    transition: color 0.2s ease;
  }

  .faq-with-image-question-{{ section.id }}:hover {
    color: {{ sc_accent }};
  }

  .faq-with-image-question-text-{{ section.id }} {
    flex: 1;
  }

  .faq-with-image-icon-{{ section.id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    position: relative;
    transition: transform 0.3s ease;
  }

  .faq-with-image-icon-{{ section.id }}::before,
  .faq-with-image-icon-{{ section.id }}::after {
    content: '';
    position: absolute;
    background-color: {{ sc_accent }};
    transition: transform 0.3s ease;
  }

  .faq-with-image-icon-{{ section.id }}::before {
    width: 100%;
    height: 1px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .faq-with-image-icon-{{ section.id }}::after {
    width: 1px;
    height: 100%;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }

  .faq-with-image-item-{{ section.id }}.active .faq-with-image-icon-{{ section.id }}::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .faq-with-image-answer-{{ section.id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    font-family: var(--font-body--family);
    font-size: {{ section.settings.answer_size }}px;
    line-height: 1.6;
    color: {{ sc_body }};
  }

  .faq-with-image-answer-content-{{ section.id }} {
    padding-bottom: {{ section.settings.item_padding }}px;
  }

  .faq-with-image-item-{{ section.id }}.active .faq-with-image-answer-{{ section.id }} {
    max-height: 1000px;
  }

  @media screen and (max-width: 989px) {
    .faq-with-image-container-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .faq-with-image-image-column-{{ section.id }} {
      position: relative;
      top: 0;
    }

    .faq-with-image-heading-{{ section.id }} {
      font-size: {{ section.settings.heading_size | times: 0.8 }}px;
    }

    .faq-with-image-question-{{ section.id }} {
      font-size: {{ section.settings.question_size | times: 0.9 }}px;
    }

    .faq-with-image-answer-{{ section.id }} {
      font-size: {{ section.settings.answer_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<faq-with-image-{{ section.id | downcase | replace: '_', '-' }} class="faq-with-image-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="faq-with-image-container-{{ section.id }}">
    <div class="faq-with-image-image-column-{{ section.id }}">
      <div class="faq-with-image-image-wrapper-{{ section.id }}" data-forge-slot-id="image"{% if section.settings.image == blank %} data-forge-slot-blank="true"{% endif %}>
        {% if section.settings.image %}
          <img
            src="{{ section.settings.image | image_url: width: 1000 }}"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {% else %}
          <div class="faq-with-image-image-placeholder-{{ section.id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="faq-with-image-content-column-{{ section.id }}">
      {% if section.settings.heading != blank %}
        <h2 class="faq-with-image-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="faq-with-image-accordion-{{ section.id }}">
        {% for i in (1..6) %}
          {% liquid
            assign question_key = 'question_' | append: i
            assign answer_key = 'answer_' | append: i
            assign question = section.settings[question_key]
            assign answer = section.settings[answer_key]
          %}

          {% if question != blank and answer != blank %}
            <div class="faq-with-image-item-{{ section.id }}" data-faq-item>
              <button
                class="faq-with-image-question-{{ section.id }}"
                aria-expanded="false"
                data-faq-button
              >
                <span class="faq-with-image-question-text-{{ section.id }}">{{ question }}</span>
                <span class="faq-with-image-icon-{{ section.id }}" aria-hidden="true"></span>
              </button>
              <div class="faq-with-image-answer-{{ section.id }}" data-faq-answer>
                <div class="faq-with-image-answer-content-{{ section.id }}">
                  {{ answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</faq-with-image-{{ section.id | downcase | replace: '_', '-' }}>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const tagName = 'faq-with-image-' + sectionId.toLowerCase().replace(/_/g, '-');
    
    class FaqWithImage extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('[data-faq-button]');
          const answer = item.querySelector('[data-faq-answer]');

          button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            this.items.forEach((otherItem) => {
              if (otherItem !== item) {
                otherItem.classList.remove('active');
                const otherButton = otherItem.querySelector('[data-faq-button]');
                otherButton.setAttribute('aria-expanded', 'false');
              }
            });

            if (isActive) {
              item.classList.remove('active');
              button.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              button.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define(tagName, FaqWithImage);
  })();
</script>

{%- capture faq_ld -%}
{%- assign faq_first = true -%}
{%- for faq_i in (1..6) -%}
{%- assign faq_qk = 'question_' | append: faq_i -%}{%- assign faq_ak = 'answer_' | append: faq_i -%}
{%- assign faq_fq = section.settings[faq_qk] -%}{%- assign faq_fa = section.settings[faq_ak] -%}
{%- if faq_fq != blank and faq_fa != blank -%}
{%- unless faq_first -%},{%- endunless -%}
{"@type":"Question","name":{{ faq_fq | json }},"acceptedAnswer":{"@type":"Answer","text":{{ faq_fa | strip_html | json }}}}
{%- assign faq_first = false -%}
{%- endif -%}
{%- endfor -%}
{%- endcapture -%}
{%- assign faq_ld_s = faq_ld | strip -%}
{%- if faq_ld_s != '' -%}
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{{ faq_ld_s }}]}
</script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ with image",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 800,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Content spacing",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "square",
          "label": "Square (1:1)"
        },
        {
          "value": "portrait",
          "label": "Portrait (3:4)"
        },
        {
          "value": "landscape",
          "label": "Landscape (4:3)"
        },
        {
          "value": "wide",
          "label": "Wide (16:9)"
        }
      ],
      "default": "portrait"
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Background",
      "default": "#f5f5f0"
    ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Your questions, answered</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#141414"
    ,
      "visible_if": "{{ section.settings.use_custom_colors }}"
    },
    {
      "type": "header",
      "content": "Questions"
    },
    {
      "type": "inline_richtext",
      "id": "question_1",
      "label": "Question 1"
    },
    {
      "type": "richtext",
      "id": "answer_1",
      "label": "Answer 1"
    },
    {
      "type": "inline_richtext",
      "id": "question_2",
      "label": "Question 2"
    },
    {
      "type": "richtext",
      "id": "answer_2",
      "label": "Answer 2"
    },
    {
      "type": "inline_richtext",
      "id": "question_3",
      "label": "Question 3"
    },
    {
      "type": "richtext",
      "id": "answer_3",
      "label": "Answer 3"
    },
    {
      "type": "inline_richtext",
      "id": "question_4",
      "label": "Question 4"
    },
    {
      "type": "richtext",
      "id": "answer_4",
      "label": "Answer 4"
    },
    {
      "type": "inline_richtext",
      "id": "question_5",
      "label": "Question 5"
    },
    {
      "type": "richtext",
      "id": "answer_5",
      "label": "Answer 5"
    },
    {
      "type": "inline_richtext",
      "id": "question_6",
      "label": "Question 6"
    },
    {
      "type": "richtext",
      "id": "answer_6",
      "label": "Answer 6"
    },
    {
      "type": "header",
