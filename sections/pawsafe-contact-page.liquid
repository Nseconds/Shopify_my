{% liquid
  assign pawsafe_product = collections.all.products.first
  assign pawsafe_product_url = pawsafe_product.url | default: "/products/dog-car-seat-belt"
%}
<section class="pawsafe-support-page">
  <div class="pawsafe-support-hero">
    <p>Serene Guardian Support</p>
    <h1>We're here for you and your companion.</h1>
    <span>Reach out for safety inquiries, product assistance, or to track your pet's latest gear.</span>
  </div>

  <div class="pawsafe-support-grid">
    <aside class="pawsafe-support-sidebar">
      <div class="pawsafe-track-card">
        <span class="pawsafe-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="7" cy="18" r="2"/><circle cx="18" cy="18" r="2"/></svg>
        </span>
        <h2>Track Your Order</h2>
        <p>Input your tracking number on our secure carrier portal to see where your PawSafe gear is currently located.</p>
        <a href="https://h6g7rjzw.aftership.com/">Go to Tracking Portal <span aria-hidden="true">-></span></a>
      </div>

      <div class="pawsafe-direct-card">
        <h2>Direct Contact</h2>
        <div>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
          <p>Email Support <strong>help.pawsafestore@gmail.com</strong></p>
        </div>
        <div>
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          <p>Hours <strong>Mon - Fri: 9am - 6pm EST</strong></p>
        </div>
      </div>

      <div class="pawsafe-trust-photo">
        <img src="{{ 'pawsafe-review-02-golden-retriever-red-belt.jpg' | asset_url }}" alt="Dog riding safely in a car with PawSafe gear" width="720" height="480" loading="lazy">
        <strong>Built for Trust.</strong>
      </div>
    </aside>

    <div class="pawsafe-message-card">
      <h2>Send us a Message</h2>
      <p>Have a question about our safety gear? Our team of pet safety specialists typically responds within 24 business hours.</p>

      {% form 'contact', class: 'pawsafe-message-form' %}
        {% if form.posted_successfully? %}
          <div class="pawsafe-form-note pawsafe-form-note--success">Thanks. Your message has been sent.</div>
        {% endif %}
        {% if form.errors %}
          <div class="pawsafe-form-note pawsafe-form-note--error">{{ form.errors | default_errors }}</div>
        {% endif %}

        <div class="pawsafe-field-row">
          <label for="ContactFormName">Full Name</label>
          <input id="ContactFormName" type="text" name="contact[name]" autocomplete="name" placeholder="Enter your name" value="{% if form.name %}{{ form.name }}{% endif %}">
        </div>
        <div class="pawsafe-field-row">
          <label for="ContactFormEmail">Email Address</label>
          <input id="ContactFormEmail" type="email" name="contact[email]" autocomplete="email" placeholder="name@example.com" value="{% if form.email %}{{ form.email }}{% endif %}" required>
        </div>
        <div class="pawsafe-field-row pawsafe-field-row--wide">
          <label for="ContactFormPhone">Phone Number</label>
          <input id="ContactFormPhone" type="tel" name="contact[phone]" autocomplete="tel" placeholder="(555) 000-0000">
        </div>
        <div class="pawsafe-field-row pawsafe-field-row--wide">
          <label for="ContactFormMessage">Your Message</label>
          <textarea id="ContactFormMessage" rows="7" name="contact[body]" placeholder="How can we help you and your pet today?" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        <button type="submit">Submit Inquiry</button>
      {% endform %}

      <div class="pawsafe-contact-badges" aria-label="Support promises">
        <div><span>Secure</span></div>
        <div><span>Reliable</span></div>
        <div><span>Human Lead</span></div>
      </div>
    </div>
  </div>

  <div class="pawsafe-partners" aria-label="Trusted safety partners">
    <p>Trusted Safety Partners</p>
    <div>
      <span>Pet Safe Certified</span>
      <span>Heritage Guarantee</span>
      <span>Premium Materials</span>
      <span>Global Shipping</span>
    </div>
  </div>

  <footer class="pawsafe-contact-footer" role="contentinfo">
    <div class="pawsafe-contact-footer__grid">
      <div>
        <h2>PawSafe</h2>
        <p>Dedicated to the safety and heritage of pet care. Your pet's serene guardian since 2024.</p>
      </div>

      <nav aria-label="Shop links">
        <h3>Shop</h3>
        <a href="/collections/all">Shop All</a>
        <a href="{{ pawsafe_product_url }}">Safety Gear</a>
      </nav>

      <nav aria-label="Company links">
        <h3>Company</h3>
        <a href="/pages/about-us">Our Mission</a>
        <a href="/pages/contact" aria-current="page">Contact Support</a>
      </nav>

      <nav aria-label="Legal links">
        <h3>Legal</h3>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Service</a>
      </nav>
    </div>

    <div class="pawsafe-contact-footer__bottom">
      &copy; 2024 PawSafe. All rights reserved. Your pet's serene guardian.
    </div>
  </footer>
</section>

<style>
  .pawsafe-support-page {
    --ps-green: #003d25;
    --ps-deep: #002514;
    --ps-gold: #d0ad5d;
    --ps-cream: #fbf8f1;
    background: var(--ps-cream);
    color: var(--ps-deep);
    font-family: Inter, var(--font-body--family), sans-serif;
  }

  .pawsafe-support-hero {
    max-width: 920px;
    margin: 0 auto;
    padding: 92px 24px 24px;
    text-align: center;
  }

  .pawsafe-support-hero p,
  .pawsafe-partners p {
    margin: 0 0 26px;
    color: #a57518;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .pawsafe-support-hero h1 {
    max-width: 760px;
    margin: 0 auto 28px;
    font-family: Montserrat, var(--font-heading--family), sans-serif;
    font-size: clamp(2.45rem, 5vw, 4.2rem);
    font-weight: 900;
    line-height: 1.12;
  }

  .pawsafe-support-hero span {
    display: block;
    color: #2d3933;
    font-size: 1.12rem;
    line-height: 1.6;
  }

  .pawsafe-support-grid {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: 28px;
    width: min(100% - 48px, 1380px);
    margin: 0 auto;
    padding: 0 0 86px;
  }

  .pawsafe-support-sidebar {
    display: grid;
    gap: 28px;
  }

  .pawsafe-track-card,
  .pawsafe-direct-card,
  .pawsafe-message-card,
  .pawsafe-trust-photo {
    border: 1px solid #dfd9cc;
    border-radius: 12px;
    box-shadow: 0 14px 36px rgba(0, 37, 20, 0.08);
  }

  .pawsafe-track-card {
    padding: 36px;
    background: linear-gradient(135deg, #073f27, #0b4d2d);
    color: #ffffff;
  }

  .pawsafe-icon {
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    margin-bottom: 32px;
    border-radius: 8px;
    background: var(--ps-gold);
    color: var(--ps-deep);
  }

  .pawsafe-icon svg,
  .pawsafe-direct-card svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .pawsafe-track-card h2,
  .pawsafe-direct-card h2,
  .pawsafe-message-card h2 {
    margin: 0 0 24px;
    font-family: Montserrat, var(--font-heading--family), sans-serif;
    font-size: clamp(1.7rem, 2.6vw, 2.15rem);
    font-weight: 850;
  }

  .pawsafe-track-card p,
  .pawsafe-message-card > p {
    margin: 0 0 28px;
    line-height: 1.65;
  }

  .pawsafe-track-card a,
  .pawsafe-message-form button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    width: 100%;
    min-height: 58px;
    border: 0;
    border-radius: 8px;
    background: var(--ps-gold);
    color: var(--ps-deep);
    font-size: 0.86rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    cursor: pointer;
  }

  .pawsafe-direct-card {
    padding: 36px;
    background: #ffffff;
  }

  .pawsafe-direct-card div {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 18px;
    margin-top: 24px;
    color: #a57518;
  }

  .pawsafe-direct-card p {
    margin: 0;
    color: #1f2924;
    font-size: 0.88rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pawsafe-direct-card strong {
    display: block;
    margin-top: 10px;
    color: var(--ps-deep);
    font-size: 1.12rem;
    letter-spacing: 0.04em;
    text-transform: none;
  }

  .pawsafe-trust-photo {
    position: relative;
    overflow: hidden;
    min-height: 292px;
    background: var(--ps-deep);
  }

  .pawsafe-trust-photo img {
    width: 100%;
    height: 100%;
    min-height: 292px;
    object-fit: cover;
    opacity: 0.86;
  }

  .pawsafe-trust-photo strong {
    position: absolute;
    left: 30px;
    bottom: 28px;
    color: #ffffff;
    font-family: Montserrat, var(--font-heading--family), sans-serif;
    font-size: 1.8rem;
  }

  .pawsafe-message-card {
    padding: clamp(34px, 5vw, 58px);
    background: #ffffff;
  }

  .pawsafe-message-card > p {
    max-width: 600px;
    color: #34453c;
  }

  .pawsafe-message-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px 28px;
  }

  .pawsafe-field-row {
    display: grid;
    gap: 10px;
  }

  .pawsafe-field-row--wide,
  .pawsafe-message-form button,
  .pawsafe-form-note {
    grid-column: 1 / -1;
  }

  .pawsafe-message-form label {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pawsafe-message-form input,
  .pawsafe-message-form textarea {
    width: 100%;
    border: 1px solid #d8d3ca;
    border-radius: 8px;
    background: #f6f4ef;
    color: var(--ps-deep);
    font: inherit;
    font-size: 1rem;
    padding: 17px 20px;
  }

  .pawsafe-message-form textarea {
    resize: vertical;
  }

  .pawsafe-message-form button {
    margin-top: 12px;
    background: var(--ps-green);
    color: #ffffff;
    box-shadow: 0 6px 0 rgba(0, 37, 20, 0.18);
  }

  .pawsafe-contact-badges {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 56px;
    padding-top: 36px;
    border-top: 1px solid #e4ded3;
    text-align: center;
  }

  .pawsafe-contact-badges span {
    color: var(--ps-deep);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pawsafe-form-note {
    border-radius: 8px;
    padding: 14px 16px;
    font-weight: 700;
  }

  .pawsafe-form-note--success {
    background: #e9f5ee;
    color: #0a4a2b;
  }

  .pawsafe-form-note--error {
    background: #fff0eb;
    color: #8a2d16;
  }

  .pawsafe-partners {
    padding: 72px 24px 78px;
    background: #f6f3ec;
    text-align: center;
  }

  .pawsafe-partners div {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    width: min(100%, 1080px);
    margin: 0 auto;
  }

  .pawsafe-partners span {
    color: #72746e;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pawsafe-contact-footer {
    background: #0b432b;
    color: #e6f3eb;
    font-family: Inter, var(--font-body--family), sans-serif;
  }

  .pawsafe-contact-footer__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.7fr 0.8fr 0.8fr;
    gap: 70px;
    width: min(100% - 64px, 1260px);
    margin: 0 auto;
    padding: 76px 0 78px;
  }

  .pawsafe-contact-footer h2,
  .pawsafe-contact-footer h3,
  .pawsafe-contact-footer p {
    margin-top: 0;
  }

  .pawsafe-contact-footer h2 {
    margin-bottom: 28px;
    color: var(--ps-gold);
    font-family: Montserrat, var(--font-heading--family), sans-serif;
    font-size: 2rem;
    font-weight: 900;
  }

  .pawsafe-contact-footer h3 {
    margin-bottom: 22px;
    color: var(--ps-gold);
    font-size: 0.86rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pawsafe-contact-footer p {
    max-width: 280px;
    color: #d4e5dc;
    line-height: 1.65;
  }

  .pawsafe-contact-footer nav {
    display: grid;
    align-content: start;
    gap: 14px;
  }

  .pawsafe-contact-footer a {
    color: #e6f3eb;
    font-size: 0.96rem;
    text-decoration: none;
  }

  .pawsafe-contact-footer a[aria-current="page"] {
    color: var(--ps-gold);
    font-weight: 900;
  }

  .pawsafe-contact-footer__bottom {
    border-top: 1px solid rgba(230, 243, 235, 0.16);
    padding: 30px 20px;
    color: #bdd5ca;
    font-size: 0.86rem;
    text-align: center;
  }

  @media screen and (max-width: 900px) {
    .pawsafe-support-grid {
      grid-template-columns: 1fr;
      width: min(100% - 32px, 680px);
    }

    .pawsafe-message-form,
    .pawsafe-contact-badges,
    .pawsafe-partners div,
    .pawsafe-contact-footer__grid {
      grid-template-columns: 1fr;
    }

    .pawsafe-contact-footer__grid {
      width: min(100% - 36px, 680px);
      gap: 32px;
      padding: 52px 0;
    }
  }
</style>

{% schema %}
{
  "name": "PawSafe contact page",
  "settings": [],
  "presets": [
    {
      "name": "PawSafe contact page"
    }
  ]
}
{% endschema %}
