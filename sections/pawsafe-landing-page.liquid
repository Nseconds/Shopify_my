{{ 'pawsafe-landing.css' | asset_url | stylesheet_tag }}

{% liquid
  assign pawsafe_product = section.settings.product

  if pawsafe_product == blank
    assign pawsafe_product = collections.all.products.first
  endif

  assign pawsafe_variant = pawsafe_product.selected_or_first_available_variant
  assign pawsafe_product_url = pawsafe_product.url | default: '/products/dog-car-seat-belt'
  assign pawsafe_can_add = false

  if pawsafe_variant and pawsafe_variant.available
    assign pawsafe_can_add = true
  endif
%}

<main>
  <section class="pawsafe-hero">
    <div class="orb orb1"></div>
    <div class="heroText">
      <div class="pill">Premium pet travel safety</div>
      <h1>Keep your dog safe on every car ride.</h1>
      <p class="lead">PawSafe Store helps protect your pet from sudden stops, unsafe movement, and driver distraction with a secure clip-in design that installs in seconds.</p>
      <div class="heroCtas">
        <a class="btn primary" href="{{ pawsafe_product_url }}" id="hero-primary-btn">Protect My Dog</a>
        <a class="btn secondary" href="#how-it-works" id="hero-secondary-btn">Watch Demo</a>
      </div>
      <div class="microTrust"><b>30-Day Return Support</b> - PayPal accepted at checkout.</div>
      <div class="featuresLine"><span>Adjustable Fit</span><span>Easy Clip-On Design</span><span>Customer Support Available</span></div>
    </div>
    <div class="heroVisual">
      <div class="imageFrame mainFrame">
        <img id="hero-main-img" src="{{ 'hero.jpg' | asset_url }}" alt="Dog secured with PawSafe Store in car" width="900" height="900" loading="eager" fetchpriority="high">
      </div>
      <div class="floatingCard cardTop"><strong>3-sec install</strong><small>Clip - Adjust - Drive</small></div>
      <div class="floatingCard cardBottom"><strong>Reduces distraction</strong><small>Keeps pets positioned safely</small></div>
      <div class="productBadge">
        <span class="productBadgeIcon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M5.5 16.5h13l-1.3-4.5a2.4 2.4 0 0 0-2.3-1.7H9.1A2.4 2.4 0 0 0 6.8 12l-1.3 4.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
            <path d="M7.2 10.3 8.4 7.4A2.2 2.2 0 0 1 10.4 6h3.2a2.2 2.2 0 0 1 2 1.4l1.2 2.9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
            <path d="M4.5 16.5v2.2c0 .7.5 1.2 1.2 1.2h.8c.7 0 1.2-.5 1.2-1.2v-.5h8.6v.5c0 .7.5 1.2 1.2 1.2h.8c.7 0 1.2-.5 1.2-1.2v-2.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
            <path d="M8 14.3h.1M15.9 14.3h.1" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"></path>
            <path d="m19 5 1.5 1.5L23 4" stroke="#c9a961" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </span>
        <span class="productBadgeText">
          <strong>Universal Car Fit</strong>
          <small>Works with most vehicles</small>
        </span>
      </div>
    </div>
  </section>

  <section class="logoStrip">
    <span>Secure restraint</span><span>Adjustable comfort</span><span>Daily travel ready</span><span>Multiple colors</span>
  </section>

  <section id="how-it-works" class="videoSection">
    <div class="videoCopy"><span class="eyebrow">Watch it work</span><h2>From loose and risky to clipped-in and calm.</h2><p>See how quickly PawSafe Store creates a calmer, safer travel setup before every drive.</p></div>
    <div class="videoShell"><video src="{{ 'video.mp4' | asset_url }}" autoplay muted loop playsinline controls></video></div>
  </section>

  <section class="productShowcase">
    <div class="gallery">
      <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View PawSafe belt product page"><img src="{{ 'hero2.jpg' | asset_url }}" alt="PawSafe Store product in use" width="640" height="640" loading="lazy"></a>
      <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View PawSafe belt product page"><img src="{{ 'seat2.jpg' | asset_url }}" alt="Pet safety belt attached to seat" width="640" height="640" loading="lazy"></a>
      <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View PawSafe belt product page"><img src="{{ 'cat.jpg' | asset_url }}" alt="Pet secured for travel" width="640" height="640" loading="lazy"></a>
      <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View PawSafe belt product page"><img src="{{ 'multi.jpg' | asset_url }}" alt="PawSafe Store color options" width="640" height="640" loading="lazy"></a>
    </div>
    <div class="productPanel">
      <span class="eyebrow">PawSafe Store Original</span>
      <h2>Premium adjustable dog car safety belt</h2>
      <div class="productFacts"><span>Adjustable length</span><span>Cloth and metal build</span><span>7 color options</span></div>
      <p>Built for daily drives, vet visits, errands, and short rides where your pet needs a calmer, more controlled travel setup.</p>
      <div class="swatches">
        <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View red PawSafe belt"><img src="{{ 'red.jpg' | asset_url }}" alt="Red PawSafe Store belt" width="120" height="120" loading="lazy"></a>
        <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View black PawSafe belt"><img src="{{ 'black.jpg' | asset_url }}" alt="Black PawSafe Store belt" width="120" height="120" loading="lazy"></a>
        <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View blue PawSafe belt"><img src="{{ 'blue.jpg' | asset_url }}" alt="Blue PawSafe Store belt" width="120" height="120" loading="lazy"></a>
        <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View pink PawSafe belt"><img src="{{ 'pink.jpg' | asset_url }}" alt="Pink PawSafe Store belt" width="120" height="120" loading="lazy"></a>
        <a class="productMediaLink" href="{{ pawsafe_product_url }}" aria-label="View green PawSafe belt"><img src="{{ 'green.jpg' | asset_url }}" alt="Green PawSafe Store belt" width="120" height="120" loading="lazy"></a>
      </div>
      <a class="btn primary wide" href="{{ pawsafe_product_url }}" id="showcase-cta-btn">Choose Color</a>
      <div class="afterpay">PayPal accepted at checkout.</div>
    </div>
  </section>

  <section class="compare pawsafe-section">
    <span class="eyebrow">Why it helps</span><h2>A small travel habit that adds control.</h2>
    <table><tr><th>Feature</th><th>PawSafe Store</th><th>Loose travel</th></tr><tr><td>Helps limit roaming inside the car</td><td>Yes</td><td>No</td></tr><tr><td>Adjustable comfort length</td><td>Yes</td><td>No</td></tr><tr><td>Easy clip-on buckle design</td><td>Yes</td><td>No</td></tr><tr><td>Multiple colors available</td><td>Yes</td><td>No</td></tr><tr><td>30-day return support</td><td>Yes</td><td>No</td></tr></table>
