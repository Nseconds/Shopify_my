        {% endif %}
      </article>
      <article class="bundle">
        <div class="tag">Maximum Savings</div>
        <h3>Family Pack</h3>
        <p>Maximum value for multi-pet homes.</p>
        <div class="price">$39.99 <span class="bundle-was">was $59.97</span></div>
        <div class="bundle-savings">Save $19.98 — $13.33 per belt</div>
        {% if pawsafe_can_add %}
          <a class="btn secondary wide" id="add-bundle-family" href="/cart/{{ pawsafe_variant.id }}:3?discount=BUNDLE3">Add 3 — Save $19.98</a>
        {% else %}
          <a class="btn secondary wide" id="add-bundle-family" role="link" aria-disabled="true">Unavailable</a>
        {% endif %}
      </article>
