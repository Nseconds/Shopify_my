</main>

<style>
  .pawsafe-home-footer-cta {
    padding: 82px 24px 86px;
    background: #0b462d;
    color: #ffffff;
    font-family: Inter, var(--font-body--family), sans-serif;
    text-align: center;
  }

  .pawsafe-home-footer-cta h2 {
    max-width: 650px;
    margin: 0 auto 26px;
    color: #ffffff;
    font-family: Montserrat, var(--font-heading--family), sans-serif;
    font-size: clamp(2.25rem, 4vw, 3.7rem);
    font-weight: 900;
    line-height: 1.12;
  }

  .pawsafe-home-footer-cta p {
    max-width: 620px;
    margin: 0 auto 36px;
    color: #dbe9e2;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .pawsafe-home-footer-cta div {
    display: flex;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .pawsafe-home-footer-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 185px;
    min-height: 58px;
    border-radius: 7px;
    background: #ff7a0a;
    color: #ffffff;
    font-size: 0.92rem;
    font-weight: 900;
    text-decoration: none;
  }

  .pawsafe-home-footer-cta a:last-child {
    background: rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .pawsafe-home-footer-cta small {
    display: block;
    color: #b9cbc2;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 640px) {
    .pawsafe-home-footer-cta {
      padding: 62px 18px 68px;
    }

    .pawsafe-home-footer-cta a {
      width: 100%;
      max-width: 310px;
    }
  }
</style>

<div class="stickyBar" id="sticky-cta-bar"><div><b>PawSafe Store Original</b><span>Estimated delivery: 7&ndash;15 business days</span></div><a class="btn primary" href="{{ pawsafe_product_url }}">Shop Now</a></div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const id = a.getAttribute('href');
      if (id === '#') {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else if (id.length > 1) {
        e.preventDefault();
        document.querySelector(id)?.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  const stickyBar = document.getElementById('sticky-cta-bar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) {
      stickyBar.classList.add('visible');
    } else {
      stickyBar.classList.remove('visible');
    }
  });
});
</script>

