{% stylesheet %}
  .pawsafe-footer {
    background: #102f23;
    color: #d4e6dc;
    font-family: Inter, var(--font-body--family), sans-serif;
  }

  .pawsafe-footer__main {
    width: min(100%, 1240px);
    margin: 0 auto;
    padding: 72px 28px 38px;
  }

  .pawsafe-footer__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 100px;
    align-items: start;
  }

  .pawsafe-footer h2,
  .pawsafe-footer h3,
  .pawsafe-footer p {
    margin-top: 0;
  }

  .pawsafe-footer h2 {
    margin-bottom: 18px;
    color: #d3ad56;
    font-family: Montserrat, var(--font-heading--family), sans-serif;
    font-size: 1.42rem;
    font-weight: 800;
    line-height: 1.05;
  }

  .pawsafe-footer h3 {
    margin-bottom: 18px;
    color: #ffffff;
    font-family: Montserrat, var(--font-heading--family), sans-serif;
    font-size: 1.28rem;
    font-weight: 900;
    letter-spacing: 0;
  }

  .pawsafe-footer p {
    max-width: 280px;
    margin-bottom: 18px;
    color: #c3d6cb;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .pawsafe-footer__socials {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 22px;
  }

  .pawsafe-social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 0;
    color: #ffffff !important;
    background: transparent;
    transition: all 0.2s ease;
    opacity: 0.78;
  }

  .pawsafe-social-icon svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
  }

  .pawsafe-social-icon:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff !important;
  }

  /* Reset margin at the page bottom */
  .shopify-section-group-footer-group {
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
  }

  .pawsafe-footer a {
    color: #c3d6cb;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .pawsafe-footer a:hover,
  .pawsafe-footer a:focus-visible {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .pawsafe-footer ul {
    display: grid;
    gap: 18px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pawsafe-footer li {
    color: #c3d6cb;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .pawsafe-footer__bottom {
    margin-top: 60px;
    padding-top: 28px;
    border-top: 1px solid rgba(161, 209, 179, 0.18);
    color: rgba(195, 214, 203, 0.8);
    font-size: 0.72rem;
    text-align: center;
  }

  .pawsafe-footer__bottom nav {
    display: flex;
    justify-content: center;
    gap: 34px;
    margin-top: 18px;
    font-size: 0.72rem;
  }

  @media screen and (max-width: 989px) {
    .pawsafe-footer__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 32px 28px;
    }

    .pawsafe-footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 749px) {
    .pawsafe-footer__grid {
      grid-template-columns: 1fr;
    }

    .pawsafe-footer__main {
      padding: 40px 18px 22px;
    }

    .pawsafe-footer__grid {
      gap: 22px;
    }

    .pawsafe-footer h2 {
      font-size: 1.5rem;
    }

    .pawsafe-footer__bottom {
      margin-top: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "tag": "footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "PawSafe premium footer"
    }
  ]
}
{% endschema %}
