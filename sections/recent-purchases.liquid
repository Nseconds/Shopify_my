{% assign section_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .recent-purchases-{{ section_id }} {
    padding: {{ section.settings.padding_y }}px 20px;
    background: var(--color-background, {{ section.settings.background_color }});
    overflow: hidden;
  }

  .recent-purchases__container-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .recent-purchases__heading-{{ section_id }} {
    font-size: {{ section.settings.heading_size }}px;
    color: var(--color-foreground-heading, {{ section.settings.heading_color }});
    font-weight: 600;
    margin: 0 0 16px;
    text-align: {{ section.settings.text_align }};
    letter-spacing: -0.02em;
  }

  .recent-purchases__feed-{{ section_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.item_gap }}px;
  }

  .recent-purchases__item-{{ section_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: {{ section.settings.item_padding }}px 16px;
    background: var(--color-background, {{ section.settings.item_bg_color }});
    border: 1px solid {{ section.settings.item_border_color }};
    border-radius: {{ section.settings.item_border_radius }}px;
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .recent-purchases__item-{{ section_id }}.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  .recent-purchases__dot-{{ section_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: {{ section.settings.dot_color }};
    flex-shrink: 0;
    animation: pulse-dot-{{ section_id }} 2s ease-in-out infinite;
  }

  @keyframes pulse-dot-{{ section_id }} {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  .recent-purchases__text-{{ section_id }} {
    font-size: {{ section.settings.item_text_size }}px;
    color: var(--color-foreground, {{ section.settings.item_text_color }});
    line-height: 1.4;
    flex: 1;
  }

  .recent-purchases__name-{{ section_id }} {
    font-weight: 600;
    color: var(--color-foreground-heading, {{ section.settings.name_color }});
  }

  .recent-purchases__time-{{ section_id }} {
    font-size: {{ section.settings.time_size }}px;
    color: {{ section.settings.time_color }};
    flex-shrink: 0;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .recent-purchases__item-{{ section_id }} {
      padding: {{ section.settings.item_padding | times: 0.85 }}px 12px;
    }

    .recent-purchases__heading-{{ section_id }} {
      font-size: {{ section.settings.heading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="recent-purchases-{{ section_id }} color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="recent-purchases__container-{{ section_id }}">
    {%- if section.settings.heading != blank -%}
      <p class="recent-purchases__heading-{{ section_id }}">{{ section.settings.heading }}</p>
    {%- endif -%}

    <div class="recent-purchases__feed-{{ section_id }}" id="recent-feed-{{ section_id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'purchase' -%}
          <div class="recent-purchases__item-{{ section_id }}" data-delay="{{ forloop.index0 | times: 150 }}" {{ block.shopify_attributes }}>
            <div class="recent-purchases__dot-{{ section_id }}"></div>
            <div class="recent-purchases__text-{{ section_id }}">
              <span class="recent-purchases__name-{{ section_id }}">{{ block.settings.buyer_name }}</span>
              {%- if block.settings.location != blank -%}
                {{ ' ' }}from {{ block.settings.location }}
              {%- endif -%}
              {{ ' ' }}{{ block.settings.action_text }}
            </div>
            <span class="recent-purchases__time-{{ section_id }}">{{ block.settings.time_ago }}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function() {
    const feed = document.getElementById('recent-feed-{{ section_id }}');
    if (!feed) return;

    const items = feed.querySelectorAll('.recent-purchases__item-{{ section_id }}');

    // Stagger reveal on scroll into view
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          const delay = parseInt(entry.target.dataset.delay || '0');
          setTimeout(function() {
            entry.target.classList.add('is-visible');
          }, delay);
        }
      });
    }, { threshold: 0.1 });

    items.forEach(function(item) {
      observer.observe(item);
    });
  })();
</script>

{% schema %}
{
  "name": "Recent Purchases",
  "tag": "section",
  "class": "section-recent-purchases",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "🔥 Recent purchases"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Section padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 900
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap between items",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Item padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "item_border_radius",
      "label": "Item border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "item_text_size",
      "label": "Item text size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "time_size",
      "label": "Time text size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "item_bg_color",
      "label": "Item background",
      "default": "#F9F9F9"
    },
    {
      "type": "color",
      "id": "item_border_color",
      "label": "Item border color",
      "default": "#EBEBEB"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Activity dot color",
      "default": "#22C55E"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "item_text_color",
      "label": "Item text color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Buyer name color",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "time_color",
      "label": "Time ago color",
      "default": "#888888"
    }
  ],
  "blocks": [
    {
      "type": "purchase",
      "name": "Purchase notification",
      "settings": [
        {
          "type": "text",
          "id": "buyer_name",
          "label": "Buyer name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Buyer location",
          "default": "New York",
          "info": "City or country. Leave blank to hide."
        },
        {
          "type": "text",
          "id": "action_text",
          "label": "Action text",
          "default": "just purchased this",
          "info": "Text after the name and location (e.g. 'just purchased this', 'ordered 2 of these')"
        },
        {
          "type": "text",
          "id": "time_ago",
          "label": "Time ago",
          "default": "2 hours ago"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Recent Purchases",
      "blocks": [
        {
          "type": "purchase",
          "settings": {
            "buyer_name": "Sarah M.",
            "location": "New York",
            "action_text": "just purchased this",
            "time_ago": "1 hour ago"
          }
        },
        {
          "type": "purchase",
          "settings": {
            "buyer_name": "James K.",
            "location": "London",
            "action_text": "ordered 2 of these",
            "time_ago": "3 hours ago"
          }
        },
        {
          "type": "purchase",
          "settings": {
            "buyer_name": "Emma T.",
            "location": "Sydney",
            "action_text": "just purchased this",
            "time_ago": "5 hours ago"
          }
        }
      ]
    }
  ]
}
{% endschema %}
