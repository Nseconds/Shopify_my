{% assign ai_gen_id = section.id | replace: '_', '-' | downcase %}
{% assign ai_gen_id_js = section.id | replace: '_', '' | replace: '-', '' | downcase %}

{% style %}
  .ai-ugc-strip-{{ ai_gen_id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ section.settings.spacing_top }}px 0 {{ section.settings.spacing_bottom }}px;
    background-color: var(--color-background, {{ section.settings.background_color }});
  }

  .ai-ugc-strip__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-ugc-strip__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ section.settings.gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 {{ section.settings.side_padding }}px;
  }

  .ai-ugc-strip__track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-ugc-strip__item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ section.settings.item_width }}px;
    aspect-ratio: 9 / 16;
    position: relative;
    border-radius: var(--style-border-radius-images);
    overflow: hidden;
    {% if section.settings.show_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    {% endif %}
    {% if section.settings.show_border %}
      border: 1px solid var(--color-border, {{ section.settings.border_color }});
    {% endif %}
  }

  .ai-ugc-strip__media-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-ugc-strip__video-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: transform 0.2s ease;
  }

  .ai-ugc-strip__item-{{ ai_gen_id }}:hover .ai-ugc-strip__video-overlay-{{ ai_gen_id }} {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-ugc-strip__play-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    margin-left: 3px;
  }

  .ai-ugc-strip__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background-color: var(--color-primary);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .ai-ugc-strip__nav-{{ ai_gen_id }} svg {
    stroke: var(--color-primary-button-text, #fff);
  }

  .ai-ugc-strip__nav-{{ ai_gen_id }}:hover {
    background-color: var(--color-primary-hover, var(--color-primary));
  }

  .ai-ugc-strip__nav-{{ ai_gen_id }}--prev {
    left: 10px;
  }

  .ai-ugc-strip__nav-{{ ai_gen_id }}--next {
    right: 10px;
  }

  .ai-ugc-strip__nav-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  .ai-ugc-strip__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }

  .ai-ugc-strip__dot-{{ ai_gen_id }} {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-foreground, {{ section.settings.dot_color }});
    opacity: 0.3;
    transition: opacity 0.2s ease;
    cursor: pointer;
    border: none;
    padding: 0;
  }

  .ai-ugc-strip__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-ugc-strip__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: var(--color-border, #f5f5f5);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-ugc-strip__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-ugc-strip__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: var(--color-foreground-muted, #999);
    text-align: center;
    white-space: nowrap;
  }

  @media screen and (min-width: 750px) {
    .ai-ugc-strip__nav-{{ ai_gen_id }} {
      display: flex;
    }

    .ai-ugc-strip__item-{{ ai_gen_id }} {
      width: {{ section.settings.item_width_desktop }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ugc-strip__track-{{ ai_gen_id }} {
      padding: 0 16px;
    }
  }
{% endstyle %}

<ugc-media-strip-{{ ai_gen_id }} class="ai-ugc-strip-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  <div class="ai-ugc-strip__container-{{ ai_gen_id }}">
    <div class="ai-ugc-strip__track-{{ ai_gen_id }}" data-track>
      {% for i in (1..6) %}
        {% liquid
          assign media_type_key = 'media_' | append: i | append: '_type'
          assign image_key = 'media_' | append: i | append: '_image'
          assign video_key = 'media_' | append: i | append: '_video'

          assign media_type = section.settings[media_type_key]
          assign image = section.settings[image_key]
          assign video = section.settings[video_key]
        %}

        <div class="ai-ugc-strip__item-{{ ai_gen_id }}">
          {% if media_type == 'image' %}
            {% if image %}
              <img
                src="{{ image | image_url: width: 400 }}"
                alt="{{ image.alt | escape }}"
                class="ai-ugc-strip__media-{{ ai_gen_id }}"
                loading="lazy"
                width="400"
                height="711"
              >
            {% else %}
              <div class="ai-ugc-strip__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-ugc-strip__empty-state-{{ ai_gen_id }}">Add image {{ i }}</div>
              </div>
            {% endif %}
          {% elsif media_type == 'video' %}
            {% if video %}
              <video
                src="{{ video.sources[0].url }}"
                class="ai-ugc-strip__media-{{ ai_gen_id }}"
                playsinline
                muted
                loop
              ></video>
              <div class="ai-ugc-strip__video-overlay-{{ ai_gen_id }}">
                <svg class="ai-ugc-strip__play-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </div>
            {% else %}
              <div class="ai-ugc-strip__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-ugc-strip__empty-state-{{ ai_gen_id }}">Add video {{ i }}</div>
              </div>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <button class="ai-ugc-strip__nav-{{ ai_gen_id }} ai-ugc-strip__nav-{{ ai_gen_id }}--prev" data-prev aria-label="Previous">
      <svg class="ai-ugc-strip__nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button class="ai-ugc-strip__nav-{{ ai_gen_id }} ai-ugc-strip__nav-{{ ai_gen_id }}--next" data-next aria-label="Next">
      <svg class="ai-ugc-strip__nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>

  {% if section.settings.show_dots %}
    <div class="ai-ugc-strip__dots-{{ ai_gen_id }}" data-dots>
      {% for i in (1..6) %}
        <button class="ai-ugc-strip__dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" data-dot="{{ i }}" aria-label="Go to slide {{ i }}"></button>
      {% endfor %}
    </div>
  {% endif %}
</ugc-media-strip-{{ ai_gen_id }}>

<script>
  (function() {
    class UgcMediaStrip{{ ai_gen_id_js }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('[data-track]');
        this.prevBtn = this.querySelector('[data-prev]');
        this.nextBtn = this.querySelector('[data-next]');
        this.dots = this.querySelectorAll('[data-dot]');
        this.items = this.querySelectorAll('.ai-ugc-strip__item-{{ ai_gen_id }}');
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.setupNavigation();
        this.setupVideoPlayback();
        this.setupDots();
        this.setupScrollTracking();
      }

      setupNavigation() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.scroll('prev'));
        }
        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.scroll('next'));
        }
      }

      setupVideoPlayback() {
        this.items.forEach((item) => {
          const video = item.querySelector('video');
          if (video) {
            item.addEventListener('click', () => {
              if (video.paused) {
                this.items.forEach((other) => {
                  const otherVideo = other.querySelector('video');
                  if (otherVideo && otherVideo !== video) {
                    otherVideo.pause();
                    otherVideo.muted = true;
                    const otherOverlay = other.querySelector('.ai-ugc-strip__video-overlay-{{ ai_gen_id }}');
                    if (otherOverlay) otherOverlay.style.opacity = '1';
                  }
                });
                video.muted = false;
                video.play().catch(() => {});
                const overlay = item.querySelector('.ai-ugc-strip__video-overlay-{{ ai_gen_id }}');
                if (overlay) overlay.style.opacity = '0';
              } else {
                video.pause();
                video.muted = true;
                const overlay = item.querySelector('.ai-ugc-strip__video-overlay-{{ ai_gen_id }}');
                if (overlay) overlay.style.opacity = '1';
              }
            });

            video.addEventListener('ended', () => {
              const overlay = item.querySelector('.ai-ugc-strip__video-overlay-{{ ai_gen_id }}');
              if (overlay) overlay.style.opacity = '1';
            });
          }
        });
      }

      setupDots() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.scrollToIndex(index);
          });
        });
      }

      setupScrollTracking() {
        let scrollTimeout;
        this.track.addEventListener('scroll', () => {
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => {
            this.updateActiveDot();
          }, 100);
        });
      }

      scroll(direction) {
        const itemWidth = this.items[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const scrollAmount = itemWidth + gap;

        if (direction === 'prev') {
          this.track.scrollLeft -= scrollAmount;
        } else {
          this.track.scrollLeft += scrollAmount;
        }
      }

      scrollToIndex(index) {
        const itemWidth = this.items[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const scrollAmount = (itemWidth + gap) * index;
        this.track.scrollLeft = scrollAmount;
      }

      updateActiveDot() {
        const scrollLeft = this.track.scrollLeft;
        const itemWidth = this.items[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const index = Math.round(scrollLeft / (itemWidth + gap));

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('ugc-media-strip-{{ ai_gen_id }}', UgcMediaStrip{{ ai_gen_id_js }});
  })();
</script>

