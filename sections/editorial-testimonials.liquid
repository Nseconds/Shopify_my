{% liquid
  if section.settings.use_custom_colors
    assign et_text_color = section.settings.text_color
    assign et_card_bg = section.settings.card_bg
    assign et_stars = section.settings.star_color
  else
    assign et_text_color = section.settings.color_scheme.settings.foreground
    assign et_card_bg = section.settings.color_scheme.settings.foreground | color_modify: 'alpha', 0.04
    assign et_stars = section.settings.color_scheme.settings.foreground
  endif
%}

{% style %}
  #shopify-section-{{ section.id }} {
    --et-text-color: {{ et_text_color }};
    --et-card-bg: {{ et_card_bg }};
    --et-stars: {{ et_stars }};
  }
{% endstyle %}

<div class="editorial-testimonials section section--full-width spacing-style color-{{ section.settings.color_scheme }}" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="editorial-testimonials__header">
    {% if section.settings.heading != blank %}
      <h2 class="editorial-testimonials__heading">{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  <div class="editorial-testimonials__track">
    <div class="editorial-testimonials__inner">
      {% for i in (1..2) %}
        {% for block in section.blocks %}
          <div class="et-card" {% if i == 1 %}{{ block.shopify_attributes }}{% endif %}>
            <div class="et-card__inner">
              <div class="et-card__stars">
                {% for j in (1..block.settings.stars) %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>
              <h3 class="et-card__title">{{ block.settings.title }}</h3>
              <p class="et-card__quote">{{ block.settings.quote }}</p>
              <p class="et-card__author">- {{ block.settings.author }}</p>
              {% if block.settings.product_info != blank %}
                <p class="et-card__product">{{ block.settings.product_info }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .editorial-testimonials {
    width: 100%;
  }

  .editorial-testimonials__header {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--page-margin, 24px) 32px;
    text-align: center;
  }

  .editorial-testimonials__heading {
    margin: 0;
    font-family: var(--font-heading--family, inherit);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
  }

  .editorial-testimonials__track {
    overflow: hidden;
    padding: 0 0 24px;
  }

  .editorial-testimonials__inner {
    display: flex;
    gap: 16px;
    animation: etScroll 120s linear infinite;
    flex-shrink: 0;
  }

  .editorial-testimonials__track:hover .editorial-testimonials__inner {
    animation-play-state: paused;
  }

  @keyframes etScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .et-card {
    flex: 0 0 320px;
  }

  .et-card__inner {
    background: var(--et-card-bg);
    padding: 32px;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border, rgba(0,0,0,0.05));
    border-radius: var(--style-border-radius-cards, 0px);
  }

  .et-card__stars {
    display: flex;
    gap: 2px;
    color: var(--et-stars);
    margin-bottom: 16px;
  }

  .et-card__title {
    margin: 0 0 12px 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--et-text-color);
  }

  .et-card__quote {
    margin: 0 0 24px 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--et-text-color);
    opacity: 0.85;
    flex-grow: 1;
  }

  .et-card__author {
    margin: 0 0 4px 0;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--et-text-color);
  }

  .et-card__product {
    margin: 0;
    font-size: 0.75rem;
    color: var(--et-text-color);
    opacity: 0.5;
  }

  @media screen and (max-width: 749px) {
    .editorial-testimonials__header {
      padding: 0 16px 24px;
    }
    .editorial-testimonials__inner {
      gap: 12px;
    }
    .et-card {
      flex: 0 0 280px;
    }
    .et-card__inner {
      padding: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial Testimonials",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reviews"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Use custom colors",
      "info": "Override the color scheme for cards.",
      "default": false
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top margin",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom margin",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Perfect Fit"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "The quality and fit of these clothes are unmatched. Highly recommended."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Michael D."
        },
        {
          "type": "text",
          "id": "product_info",
          "label": "Product text (optional)",
          "default": "Verified Buyer - The Vito Overshirt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Testimonials",
      "blocks": [
        { "type": "review" },
        { "type": "review", "settings": { "title": "Premium Quality", "quote": "Finally found clothes that fit perfectly right out of the box." } },
        { "type": "review", "settings": { "title": "My New Go-To", "quote": "The stretch fabric is incredibly comfortable while looking sharp." } }
      ]
    }
  ]
}
{% endschema %}
